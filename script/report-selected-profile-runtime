#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 0 ]]; then
  die "usage: script/report-selected-profile-runtime"
fi

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "DNS-mediated selected-profile runtime late reporting runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "DNS-mediated selected-profile runtime late reporting requires Linux x86_64"
fi

require_cmd python3

suffix="${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}-${SELECTED_PROFILE_RUNTIME_REPLICA:-trial}"
invocation="selected-profile-${GITHUB_RUN_ATTEMPT:-attempt}-${SELECTED_PROFILE_RUNTIME_REPLICA:-trial}"
directory="/run/fence-selected-profile-runtime-${suffix}/$invocation"
report="$directory/report.json"
dns_report="$directory/dns-report.json"
production_ready="/run/fence/$invocation/ready.json"

for sample in 1 2 3 4; do
  sleep 5
  echo "collecting bounded late DNS-mediated selected-profile evidence ($sample/4)"
done
python3 - "$report" "$dns_report" "$production_ready" <<'PY'
import json
import pathlib
import re
import sys

report_path, dns_path, production_path = (pathlib.Path(item) for item in sys.argv[1:])
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
assert report["status"] == "selected_profile_runtime_test_only", report
assert report["runtime_evidence_schema_version"] == 4, report
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
assert report["critical_findings"] == [], report
assert dns["status"] == "selected_profile_runtime_test_only", dns
assert dns["runtime_evidence_schema_version"] == 4, dns
assert report["platform_profile_id"] == "github_hosted_workflow_bootstrap_v3", report
assert dns["platform_profile_id"] == "github_hosted_workflow_bootstrap_v3", dns
assert report["policy_hash_schema_version"] == 6, report
assert re.fullmatch(r"[0-9a-f]{64}", report["policy_hash"]), report
assert re.fullmatch(r"[0-9a-f]{64}", report["base_ruleset_hash"]), report
assert re.fullmatch(r"[0-9a-f]{64}", report["ruleset_hash"]), report
assert not production_path.exists()

observations = dns["observations"]
derived_cname_authorizations = dns["derived_cname_authorizations"]
summary = {
    "schema_version": 1,
    "runtime_evidence_schema_version": report["runtime_evidence_schema_version"],
    "status": "selected_profile_runtime_late_report_test_only",
    "profile_realization_id": dns["profile_realization_id"],
    "platform_profile_id": dns["platform_profile_id"],
    "policy_hash_schema_version": report["policy_hash_schema_version"],
    "policy_hash": report["policy_hash"],
    "base_ruleset_hash": report["base_ruleset_hash"],
    "active_ruleset_hash": report["ruleset_hash"],
    "bootstrap_hostnames": dns["bootstrap_hostnames"],
    "excluded_unretained_query_count": dns["excluded_unretained_query_count"],
    "blocked_non_profile_query_count": dns["blocked_non_profile_query_count"],
    "materialization_batch_count": dns["materialization_batch_count"],
    "materialization_request_rejections": dns["materialization_request_rejections"],
    "results_storage_authorizations": dns["runner_authorized_results_storage"][:4],
    "results_storage_authorizations_truncated": dns["runner_authorized_results_storage_truncated"],
    "results_storage_attribution_failures": dns["results_storage_attribution_failures"],
    "results_storage_request_rejections": dns["results_storage_request_rejections"],
    "materialization_update_max_milliseconds": dns["materialization_update_max_milliseconds"],
    "hostname_refresh_warnings": dns["hostname_refresh_warnings"],
    "network_counters": report["counters"],
    "network_findings": report["findings"][:64],
    "network_findings_truncated": report["findings_truncated"] or len(report["findings"]) > 64,
    "critical_findings": report["critical_findings"][:64],
    "critical_findings_truncated": (
        report["critical_findings_truncated"]
        or len(report["critical_findings"]) > 64
    ),
    "observations": observations[:64],
    "observations_truncated": dns["observations_truncated"] or len(observations) > 64,
    "bounded_actions_suffix_authorizations": dns["bounded_actions_suffix_authorizations"][:8],
    "bounded_actions_suffix_authorizations_truncated": (
        dns["bounded_actions_suffix_authorizations_truncated"]
        or len(dns["bounded_actions_suffix_authorizations"]) > 8
    ),
    "derived_cname_authorizations": derived_cname_authorizations[:32],
    "derived_cname_authorizations_truncated": (
        dns["derived_cname_authorizations_truncated"]
        or len(derived_cname_authorizations) > 32
    ),
    "protection_available": False,
    "limitations": [
        "bounded_late_step_dns_evidence_only",
        "no_public_activation_or_runtime_materialization",
    ],
}
encoded = json.dumps(summary, sort_keys=True, separators=(",", ":"))
assert len(encoded.encode("utf-8")) <= 256 * 1024
print(encoded)
PY

echo -e "${GREEN}bounded late DNS-mediated selected-profile evidence emitted${OFF}"
