#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 0 ]]; then
  die "usage: script/test-composed"
fi

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "composed lifecycle evidence runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "composed lifecycle evidence requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd docker
require_cmd ip
require_cmd python3
require_cmd sudo

for required in /usr/bin/systemctl /usr/bin/systemd-run /usr/sbin/nft /usr/sbin/ip; do
  if [[ ! -x "$required" ]]; then
    die "composed lifecycle evidence requires executable $required"
  fi
done

suffix="${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}"
namespace="fence-composed-${suffix}"
invocation="composed-standard-${suffix}"
unit="fence-evidence-${invocation}.service"
runtime_root="/run/fence-composed-evidence-${suffix}"
report="$runtime_root/$invocation/report.json"
ready="$runtime_root/$invocation/ready.json"
production_ready="/run/fence/$invocation/ready.json"
target_root="$RUNNER_TEMP/fence-composed-target"

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo test --frozen --test composed --no-run

shopt -s nullglob
test_binaries=()
for candidate in "$target_root"/debug/deps/composed-*; do
  if [[ -f "$candidate" && -x "$candidate" ]]; then
    test_binaries+=("$candidate")
  fi
done
if [[ "${#test_binaries[@]}" -ne 1 ]]; then
  die "expected exactly one compiled composed lifecycle test binary"
fi

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "composed lifecycle evidence requires absent host inet fence_v0 table"
fi
sudo /usr/sbin/ip netns add "$namespace"
sudo /usr/sbin/ip -n "$namespace" link set lo up
sudo /usr/sbin/ip netns exec "$namespace" /usr/sbin/nft list ruleset >/dev/null

# The transient service enters the disposable namespace before applying the
# block ruleset. Its sudo/container mutation is host-visible and deliberately
# remains installed after test readiness until this ephemeral VM is destroyed.
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  --setenv=FENCE_COMPOSED_WORKER=1 \
  "--setenv=FENCE_COMPOSED_UNIT=$unit" \
  "--setenv=FENCE_COMPOSED_ROOT=$runtime_root" \
  "--setenv=FENCE_COMPOSED_INVOCATION=$invocation" \
  /usr/sbin/ip netns exec "$namespace" \
  "${test_binaries[0]}" --ignored --exact composed_standard_service_worker --nocapture

python3 - "$report" "$ready" "$production_ready" <<'PY'
import json
import pathlib
import sys
import time

report_path, ready_path, production_ready_path = (pathlib.Path(item) for item in sys.argv[1:])
deadline = time.monotonic() + 20
ready = None
report = None
while time.monotonic() < deadline:
    if ready_path.exists() and report_path.exists():
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        report = json.loads(report_path.read_text(encoding="utf-8"))
        if (
            report.get("setup_status") == "resident_composed_test_only"
            and report.get("readiness_status") == "composed_test_only_ready_no_protection"
        ):
            break
    time.sleep(0.1)
assert ready is not None, "composed test-only readiness was not emitted"
assert report is not None, "composed evidence report was not emitted"
assert ready["status"] == "composed_test_only_ready_no_protection"
assert ready["protection_available"] is False
assert report["status"] == "composed_lifecycle_test_only"
assert report["mode"] == "block"
assert report["setup_status"] == "resident_composed_test_only"
assert report["network_application_status"] == "applied"
assert report["network_verification_status"] == "verified"
assert report["sudo_status"] == "disabled_verified"
assert report["container_status"] == "disabled_verified"
assert report["readiness_status"] == "composed_test_only_ready_no_protection"
assert report["protection_available"] is False
assert "network_policy_is_namespace_isolated_not_host_protection" in report["limitations"]
assert not production_ready_path.exists()
PY

if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
  die "composed lifecycle evidence did not disable runner passwordless sudo"
fi
if docker ps --quiet >/dev/null 2>&1; then
  die "composed lifecycle evidence did not disable runner Docker access"
fi

sleep 6
python3 - "$report" <<'PY'
import json
import pathlib
import sys

report = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
assert report["critical_findings"] == [], report
PY

echo -e "${GREEN}composed namespace-network and host-lockdown test evidence verified${OFF}"
