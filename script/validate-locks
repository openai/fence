readme = (root / "README.md").read_text(encoding="utf-8")
ci_badges = [
    f"[![{name}](https://github.com/openai/fence/actions/workflows/{name}.yml/badge.svg)](https://github.com/openai/fence/actions/workflows/{name}.yml)"
    for name in ["lint", "test", "build", "acceptance"]
]
release_canary_badge = "[![released action / ubuntu-24.04 + ubuntu-latest](https://github.com/openai/fence/actions/workflows/action-drift-canary.yml/badge.svg?branch=main&event=schedule)](https://github.com/openai/fence/actions/workflows/action-drift-canary.yml?query=branch%3Amain+event%3Aschedule)"
nightly_badge = "[![main / ubuntu-latest](https://github.com/openai/fence/actions/workflows/action-acceptance-ubuntu-latest.yml/badge.svg?branch=main&event=schedule)](https://github.com/openai/fence/actions/workflows/action-acceptance-ubuntu-latest.yml?query=branch%3Amain+event%3Aschedule)"
for name, badge in zip(["lint", "test", "build", "acceptance"], ci_badges):
    require(
        readme.count(badge) == 1
        and readme.count(f"actions/workflows/{name}.yml/badge.svg") == 1,
        f"README must expose exactly one {name} CI badge",
    )
require(
    readme.count(release_canary_badge) == 1
    and readme.count("actions/workflows/action-drift-canary.yml/badge.svg") == 1,
    "README must expose exactly one scheduled published-release canary badge",
