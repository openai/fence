aggregate_result_env = indented_block(
    aggregate_result_gate,
    "        env:",
    "Action acceptance result environment must be unique",
)
require(
    scalar_mapping(aggregate_result_env, 10)
    == {
        "PREPARE_RESULT": "${{ needs.prepare-candidate.result }}",
        "ACTION_RESULT": "${{ needs.action.result }}",
        "ZERO_INPUT_RESULT": "${{ needs.zero-input.result }}",
        "NESTED_LAYOUT_RESULT": "${{ needs.nested-layout.result }}",
        "SETUP_FAILURE_RESULT": "${{ needs.setup-failure.result }}",
        "TAMPER_RESULT": "${{ needs.tamper.result }}",
        "FINALIZATION_RESULT": "${{ needs.action-finalization.result }}",
        "FINALIZATION_CHECKOUT_OUTCOME": "${{ steps.finalization-checkout.outcome }}",
        "FINALIZATION_VERIFIER_OUTCOME": "${{ steps.finalization-verifier.outcome }}",
    }
    and literal_run_body(
        aggregate_result_gate,
        "Action acceptance result gate must use a literal run body",
    )
    == (
        "          for result in \\\n"
        '            "$PREPARE_RESULT" \\\n'
        '            "$ACTION_RESULT" \\\n'
        '            "$ZERO_INPUT_RESULT" \\\n'
        '            "$NESTED_LAYOUT_RESULT" \\\n'
        '            "$SETUP_FAILURE_RESULT" \\\n'
        '            "$TAMPER_RESULT" \\\n'
        '            "$FINALIZATION_RESULT" \\\n'
        '            "$FINALIZATION_CHECKOUT_OUTCOME" \\\n'
        '            "$FINALIZATION_VERIFIER_OUTCOME"\n'
        "          do\n"
        '            if [[ "$result" != "success" ]]; then\n'
        "              exit 1\n"
        "            fi\n"
        "          done\n"
        '          echo "bundled Action acceptance passed"\n'
    ),
    "Action acceptance result gate must reject every unsuccessful prerequisite or verifier outcome",
)
for forbidden in ["verify-action-finalization:", "continue-on-error", "actions/cache", "contents: write"]:
    require(forbidden not in workflow, "Action acceptance contains a forbidden redundant or mutable surface")

