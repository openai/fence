#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

ci=false
case "${1:-}" in
  --ci)
    ci=true
    ;;
  ""|--offline)
    ;;
  *)
    die "usage: script/validate-locks [--ci|--offline]"
    ;;
esac

validate_direct_dependencies_exact() {
  awk '
    /^\[dependencies\]/ {
      in_deps = 1
      next
    }
    /^\[/ {
      if (in_deps) {
        exit
      }
    }
    in_deps {
      line = $0
      sub(/[[:space:]]*#.*/, "", line)
      if (line ~ /^[[:space:]]*$/) {
        next
      }
      if (line !~ /^[[:space:]]*[A-Za-z0-9_-]+[[:space:]]*=/) {
        next
      }
      if (line ~ /=[[:space:]]*"=/ || line ~ /version[[:space:]]*=[[:space:]]*"=/) {
        next
      }
      print line
      bad = 1
    }
    END {
      exit bad ? 1 : 0
    }
  ' "$DIR/Cargo.toml"
}

validate_workflow_uses_pinned() {
  local workflow
  local line
  local value
  local ref
  local failed=false

  for workflow in "$DIR"/.github/workflows/*.yml; do
    while IFS= read -r line; do
      value="${line#*uses:}"
      value="${value%%#*}"
      value="$(printf '%s' "$value" | sed "s/^[[:space:]]*//; s/[[:space:]]*$//; s/^[\"']//; s/[\"']$//")"
      [[ -n "$value" ]] || continue
      case "$value" in
        ./*) continue ;;
        *@*)
          ref="${value##*@}"
          if ! [[ "$ref" =~ ^[0-9a-f]{40}$ ]]; then
            echo "${workflow#$DIR/}: uses ref is not a full commit SHA: $value" >&2
            failed=true
          fi
          ;;
        *)
          echo "${workflow#$DIR/}: uses ref is missing @<sha>: $value" >&2
          failed=true
          ;;
      esac
    done < <(grep -nE '^[[:space:]]*uses:[[:space:]]*' "$workflow" || true)

    if grep -nE '^[[:space:]]*image:[[:space:]]*[^#[:space:]]' "$workflow" | grep -v '@sha256:' >&2; then
      failed=true
    fi
    if grep -nE '^[[:space:]]*container:[[:space:]]*[^#{[:space:]]' "$workflow" | grep -v '@sha256:' >&2; then
      failed=true
    fi
  done

  if [[ "$failed" == "true" ]]; then
    die "workflow actions and images must be pinned to immutable SHAs or digests"
  fi
}

validate_cargo_vendor_surface() {
  if [[ ! -f "$DIR/Cargo.lock" ]]; then
    die "missing Cargo.lock"
  fi
  if [[ ! -f "$DIR/.cargo/config.toml" ]]; then
    die "missing .cargo/config.toml"
  fi
  if ! grep -q 'replace-with[[:space:]]*=[[:space:]]*"vendored-sources"' "$DIR/.cargo/config.toml"; then
    die ".cargo/config.toml must replace crates.io with vendored sources"
  fi
  if ! grep -q 'offline[[:space:]]*=[[:space:]]*true' "$DIR/.cargo/config.toml"; then
    die ".cargo/config.toml must keep Cargo offline by default"
  fi
  if [[ ! -d "$VENDOR_DIR" || -z "$(ls -A "$VENDOR_DIR" 2>/dev/null)" ]]; then
    die "vendor cache is empty; run script/update while online"
  fi
  if ! find "$VENDOR_DIR" -mindepth 2 -maxdepth 2 -name .cargo-checksum.json -print -quit | grep -q .; then
    die "vendor cache is missing Cargo checksum metadata"
  fi
  if ! validate_direct_dependencies_exact; then
    die "Cargo.toml direct dependencies must use exact versions"
  fi
  if [[ -e "$DIR/vendor/update-tools" ]] && { [[ ! -d "$DIR/vendor/update-tools" ]] || find "$DIR/vendor/update-tools" -mindepth 1 -print -quit | grep -q .; }; then
    die "update-tool dependency locks belong in ${UPDATE_TOOLS_LOCK#$DIR/}; do not commit vendor/update-tools"
  fi
}

validate_ci_evidence() {
  python3 -E - "$DIR" <<'PY'
import ast
import pathlib
import re
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message):
    if not condition:
        raise SystemExit(message)

root = pathlib.Path(sys.argv[1])
validator_paths = [
    "script/test-action-acceptance",
    "script/test-action-tamper",
    "script/test-lockdown",
    "script/test-protected-run",
    "script/test-selected-profile-runtime",
    "script/report-selected-profile-runtime",
]

for relative in validator_paths:
    source = (root / relative).read_text(encoding="utf-8")
    invocations = [
        line
        for line in source.splitlines()
        if re.match(r"^\s*python3(?:\s|$)", line)
    ]
    require(invocations, f"{relative}: missing Python evidence validator")
    require(
        all(re.match(r"^\s*python3 -E(?:\s|$)", line) for line in invocations),
        f"{relative}: Python evidence validators must ignore environment options",
    )

    blocks = re.findall(r"<<'PY'\n(.*?)\nPY(?:\n|$)", source, re.DOTALL)
    require(blocks, f"{relative}: missing inline Python evidence validator")
    for block in blocks:
        tree = ast.parse(block, filename=relative)
        require(
            not any(isinstance(node, ast.Assert) for node in ast.walk(tree)),
            f"{relative}: evidence validation must not use Python assert",
        )
        uses_require = any(
            isinstance(node, ast.Call)
            and isinstance(node.func, ast.Name)
            and node.func.id == "require"
            for node in ast.walk(tree)
        )
        if uses_require:
            require(
                "sys.flags.optimize != 0" in block
                and 'raise SystemExit("Python optimization must be disabled")' in block,
                f"{relative}: evidence validator must reject optimized Python",
            )

workflow = (root / ".github/workflows/action-acceptance.yml").read_text(encoding="utf-8")
marker = "\n  acceptance:\n"
require(workflow.count(marker) == 1, "Action acceptance aggregate must be unique")
aggregate = workflow.split(marker, 1)[1]
required_fragments = [
    "needs: [action, zero-input, nested-layout, setup-failure, tamper, verify-action-finalization]",
    "if: ${{ always() && !cancelled() }}",
    "ACTION_RESULT: ${{ needs.action.result }}",
    "ZERO_INPUT_RESULT: ${{ needs.zero-input.result }}",
    "NESTED_LAYOUT_RESULT: ${{ needs.nested-layout.result }}",
    "SETUP_FAILURE_RESULT: ${{ needs.setup-failure.result }}",
    "TAMPER_RESULT: ${{ needs.tamper.result }}",
    "FINALIZATION_RESULT: ${{ needs.verify-action-finalization.result }}",
    'if [[ "$result" != "success" ]]; then',
]
for fragment in required_fragments:
    require(fragment in aggregate, "Action acceptance aggregate must fail closed")
require(aggregate.count("exit 1") == 1, "Action acceptance aggregate must reject unsuccessful jobs")

canary_path = root / ".github/workflows/action-drift-canary.yml"
require(canary_path.is_file(), "Action drift canary workflow is missing")
canary = canary_path.read_text(encoding="utf-8")
trigger_marker = "\non:\n"
permissions_marker = "\npermissions:\n"
defaults_marker = "\ndefaults:\n"
concurrency_marker = "\nconcurrency:\n"
jobs_marker = "\njobs:\n"
for marker in [
    trigger_marker,
    permissions_marker,
    defaults_marker,
    concurrency_marker,
    jobs_marker,
]:
    require(canary.count(marker) == 1, "Action drift canary top-level contract is invalid")
triggers = canary.split(trigger_marker, 1)[1].split(permissions_marker, 1)[0]
permissions = canary.split(permissions_marker, 1)[1].split(defaults_marker, 1)[0]
concurrency = canary.split(concurrency_marker, 1)[1].split(jobs_marker, 1)[0]
require(
    triggers == '  schedule:\n    - cron: "23 13 * * *"\n  workflow_dispatch:\n',
    "Action drift canary triggers must remain fixed",
)
require(permissions == "  contents: read\n", "Action drift canary permissions must be read-only")
require(
    concurrency == "  group: action-drift-canary-${{ github.sha }}\n  cancel-in-progress: false\n",
    "Action drift canary concurrency must be commit-scoped and non-cancelling",
)
canary_fragments = [
    "runs-on: ubuntu-24.04",
    "uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd",
    "persist-credentials: false",
    "run: script/validate-locks --ci",
    "run: script/test-action-wrapper",
    "run: script/observe-hosted-runner",
    "id: bundle-host",
    "run: script/classify-action-bundle-host",
]
for fragment in canary_fragments:
    require(fragment in canary, "Action drift canary contract is incomplete")

require(canary.count("runs-on: ubuntu-24.04") == 1, "Action drift canary must use one fixed runner")
require(canary.count("uses: ./") == 1, "Action drift canary must activate the bundle exactly once")
require(
    canary.count("script/test-action-acceptance standard") == 1,
    "Action drift canary must validate one standard lifecycle",
)

for forbidden in [
    "continue-on-error",
    "actions/upload-artifact",
    "journalctl",
    "systemctl status",
    "ubuntu-latest",
]:
    require(forbidden not in canary, "Action drift canary contains a forbidden escape path")
require(
    re.search(r"(?m)^[ \t]+if:[ \t]*", canary) is None,
    "Action drift canary steps must be unconditional",
)

guard_marker = "\n      - name: require bundled Action activation\n"
activation_marker = "\n      - name: activate bundled Fence agent with strict defaults\n"
verification_marker = "\n      - name: verify zero-input Action lifecycle\n"
require(canary.count(guard_marker) == 1, "Action drift canary classifier guard must be unique")
require(canary.count(activation_marker) == 1, "Action drift canary activation step must be unique")
require(canary.count(verification_marker) == 1, "Action drift canary lifecycle step must be unique")
guard = canary.split(guard_marker, 1)[1].split(activation_marker, 1)[0]
activation = canary.split(activation_marker, 1)[1].split(verification_marker, 1)[0]
verification = canary.split(verification_marker, 1)[1]
expected_guard = (
    "        env:\n"
    "          RUN_BUNDLE: ${{ steps.bundle-host.outputs.run_bundle }}\n"
    "          CLASSIFICATION: ${{ steps.bundle-host.outputs.classification }}\n"
    "        run: |\n"
    '          if [[ "$RUN_BUNDLE" != "true" || "$CLASSIFICATION" != "bundle_compatible" ]]; then\n'
    '            echo "::error::bundled Action host classification did not authorize activation"\n'
    "            exit 1\n"
    "          fi\n"
)
require(guard == expected_guard, "Action drift canary classifier guard must fail closed")
require(activation == "        uses: ./\n", "Action drift canary activation must use zero inputs")
require(
    verification
    == '        run: script/test-action-acceptance standard "fence-${GITHUB_RUN_ID}-${GITHUB_RUN_ATTEMPT}"\n',
    "Action drift canary lifecycle validation must be unconditional",
)
PY

  if PYTHONOPTIMIZE=1 python3 -E - <<'PY' >/dev/null 2>&1
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message):
    if not condition:
        raise SystemExit(message)

require(False, "synthetic malformed evidence")
PY
  then
    die "environment optimization bypassed unconditional evidence validation"
  fi

  if python3 -O - <<'PY' >/dev/null 2>&1
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")
PY
  then
    die "optimized Python bypassed the evidence validation guard"
  fi
}

validate_tooling_layout() {
  local required=(
    "$RUST_TOOLCHAIN_LOCK"
    "$UPDATE_TOOLS_LOCK"
    "$RELEASE_TOOLS_LOCK"
    "$TEST_TOOLS_LOCK"
    "$ZIG_VERSION_FILE"
    "$CARGO_ZIGBUILD_VERSION_FILE"
    "$CARGO_LLVM_COV_VERSION_FILE"
    "$CARGO_AUDIT_VERSION_FILE"
    "$CARGO_DENY_VERSION_FILE"
  )
  local old=(
    "$DIR/rust-toolchain.lock.toml"
    "$DIR/update-tools.lock.toml"
    "$DIR/release-tools.lock.toml"
    "$DIR/test-tools.lock.toml"
    "$DIR/.zig-version"
    "$DIR/.cargo-zigbuild-version"
    "$DIR/.cargo-llvm-cov-version"
    "$DIR/.cargo-audit-version"
    "$DIR/.cargo-deny-version"
  )
  local file

  for file in "${required[@]}"; do
    if [[ ! -f "$file" ]]; then
      die "missing tooling metadata: ${file#$DIR/}"
    fi
  done

  for file in "${old[@]}"; do
    if [[ -e "$file" ]]; then
      die "obsolete root tooling metadata is not allowed: ${file#$DIR/}; use .cargo/tooling/"
    fi
  done
}

validate_tooling_layout

if [[ "$ci" == "true" ]]; then
  script/validate-rust-toolchain --ci
  script/validate-update-tools --ci
else
  script/validate-rust-toolchain
  script/validate-update-tools
fi

script/validate-release-tools
script/validate-test-tools
script/validate-action-bundle
validate_cargo_vendor_surface
validate_workflow_uses_pinned
validate_ci_evidence

echo -e "${GREEN}lock surfaces verified${OFF}"
