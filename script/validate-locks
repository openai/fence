#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

ci=false
case "${1:-}" in
  --ci)
    ci=true
    ;;
  ""|--offline)
    ;;
  *)
    die "usage: script/validate-locks [--ci|--offline]"
    ;;
esac

validate_direct_dependencies_exact() {
  awk '
    /^\[dependencies\]/ {
      in_deps = 1
      next
    }
    /^\[/ {
      if (in_deps) {
        exit
      }
    }
    in_deps {
      line = $0
      sub(/[[:space:]]*#.*/, "", line)
      if (line ~ /^[[:space:]]*$/) {
        next
      }
      if (line !~ /^[[:space:]]*[A-Za-z0-9_-]+[[:space:]]*=/) {
        next
      }
      if (line ~ /=[[:space:]]*"=/ || line ~ /version[[:space:]]*=[[:space:]]*"=/) {
        next
      }
      print line
      bad = 1
    }
    END {
      exit bad ? 1 : 0
    }
  ' "$DIR/Cargo.toml"
}

validate_workflow_uses_pinned() {
  local workflow
  local line
  local value
  local ref
  local failed=false

  for workflow in "$DIR"/.github/workflows/*.yml; do
    while IFS= read -r line; do
      value="${line#*uses:}"
      value="${value%%#*}"
      value="$(printf '%s' "$value" | sed "s/^[[:space:]]*//; s/[[:space:]]*$//; s/^[\"']//; s/[\"']$//")"
      [[ -n "$value" ]] || continue
      case "$value" in
        ./*) continue ;;
        *@*)
          ref="${value##*@}"
          if ! [[ "$ref" =~ ^[0-9a-f]{40}$ ]]; then
            echo "${workflow#$DIR/}: uses ref is not a full commit SHA: $value" >&2
            failed=true
          fi
          ;;
        *)
          echo "${workflow#$DIR/}: uses ref is missing @<sha>: $value" >&2
          failed=true
          ;;
      esac
    done < <(grep -nE '^[[:space:]]*uses:[[:space:]]*' "$workflow" || true)

    if grep -nE '^[[:space:]]*image:[[:space:]]*[^#[:space:]]' "$workflow" | grep -v '@sha256:' >&2; then
      failed=true
    fi
    if grep -nE '^[[:space:]]*container:[[:space:]]*[^#{[:space:]]' "$workflow" | grep -v '@sha256:' >&2; then
      failed=true
    fi
  done

  if [[ "$failed" == "true" ]]; then
    die "workflow actions and images must be pinned to immutable SHAs or digests"
  fi
}

validate_cargo_vendor_surface() {
  if [[ ! -f "$DIR/Cargo.lock" ]]; then
    die "missing Cargo.lock"
  fi
  if [[ ! -f "$DIR/.cargo/config.toml" ]]; then
    die "missing .cargo/config.toml"
  fi
  if ! grep -q 'replace-with[[:space:]]*=[[:space:]]*"vendored-sources"' "$DIR/.cargo/config.toml"; then
    die ".cargo/config.toml must replace crates.io with vendored sources"
  fi
  if ! grep -q 'offline[[:space:]]*=[[:space:]]*true' "$DIR/.cargo/config.toml"; then
    die ".cargo/config.toml must keep Cargo offline by default"
  fi
  if [[ ! -d "$VENDOR_DIR" || -z "$(ls -A "$VENDOR_DIR" 2>/dev/null)" ]]; then
    die "vendor cache is empty; run script/update while online"
  fi
  if ! find "$VENDOR_DIR" -mindepth 2 -maxdepth 2 -name .cargo-checksum.json -print -quit | grep -q .; then
    die "vendor cache is missing Cargo checksum metadata"
  fi
  if ! validate_direct_dependencies_exact; then
    die "Cargo.toml direct dependencies must use exact versions"
  fi
  if [[ -e "$DIR/vendor/update-tools" ]] && { [[ ! -d "$DIR/vendor/update-tools" ]] || find "$DIR/vendor/update-tools" -mindepth 1 -print -quit | grep -q .; }; then
    die "update-tool dependency locks belong in ${UPDATE_TOOLS_LOCK#$DIR/}; do not commit vendor/update-tools"
  fi
}

validate_ci_evidence() {
  python3 -E - "$DIR" <<'PY'
import ast
import pathlib
import re
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message):
    if not condition:
        raise SystemExit(message)

def indented_block(source, header, message):
    lines = source.splitlines()
    header_pattern = re.compile(rf"^{re.escape(header)}(?:[ \t]+#.*)?$")
    matches = [
        index for index, line in enumerate(lines) if header_pattern.fullmatch(line)
    ]
    require(len(matches) == 1, message)
    start = matches[0]
    indentation = len(header) - len(header.lstrip())
    end = len(lines)
    for index in range(start + 1, len(lines)):
        line = lines[index]
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        if len(line) - len(line.lstrip()) <= indentation:
            end = index
            break
    return "\n".join(lines[start:end]) + "\n"

def direct_mapping_keys(block, indentation):
    prefix = " " * indentation
    keys = re.findall(
        rf"(?m)^{prefix}([A-Za-z0-9_-]+):[^\n]*$",
        block,
    )
    require(
        len(keys) == len(set(keys)),
        "Workflow mappings must not contain duplicate keys",
    )
    return keys

def require_exact_mapping_keys(block, indentation, expected, message):
    keys = direct_mapping_keys(block, indentation)
    require(
        len(keys) == len(expected) and set(keys) == set(expected),
        message,
    )

def scalar_mapping(block, indentation):
    prefix = " " * indentation
    entries = []
    for match in re.finditer(
        rf"(?m)^{prefix}([A-Za-z0-9_-]+):[ \t]+(.+?)[ \t]*$",
        block,
    ):
        value = re.sub(r"[ \t]+#.*$", "", match.group(2)).rstrip()
        entries.append((match.group(1), value))
    require(
        len(entries) == len(dict(entries)),
        "Workflow scalar mappings must not contain duplicate keys",
    )
    return dict(entries)

root = pathlib.Path(sys.argv[1])
validator_paths = [
    "script/test-action-acceptance",
    "script/test-action-tamper",
    "script/test-lockdown",
    "script/test-protected-run",
    "script/test-selected-profile-runtime",
    "script/report-selected-profile-runtime",
]

for relative in validator_paths:
    source = (root / relative).read_text(encoding="utf-8")
    invocations = [
        line
        for line in source.splitlines()
        if re.match(r"^\s*python3(?:\s|$)", line)
    ]
    require(invocations, f"{relative}: missing Python evidence validator")
    require(
        all(re.match(r"^\s*python3 -E(?:\s|$)", line) for line in invocations),
        f"{relative}: Python evidence validators must ignore environment options",
    )

    blocks = re.findall(r"<<'PY'\n(.*?)\nPY(?:\n|$)", source, re.DOTALL)
    require(blocks, f"{relative}: missing inline Python evidence validator")
    for block in blocks:
        tree = ast.parse(block, filename=relative)
        require(
            not any(isinstance(node, ast.Assert) for node in ast.walk(tree)),
            f"{relative}: evidence validation must not use Python assert",
        )
        uses_require = any(
            isinstance(node, ast.Call)
            and isinstance(node.func, ast.Name)
            and node.func.id == "require"
            for node in ast.walk(tree)
        )
        if uses_require:
            require(
                "sys.flags.optimize != 0" in block
                and 'raise SystemExit("Python optimization must be disabled")' in block,
                f"{relative}: evidence validator must reject optimized Python",
            )

workflow = (root / ".github/workflows/action-acceptance.yml").read_text(encoding="utf-8")
require_exact_mapping_keys(
    workflow,
    0,
    ["name", "on", "permissions", "defaults", "concurrency", "jobs"],
    "Action acceptance top-level workflow contract must remain narrowly scoped",
)
require(
    scalar_mapping(workflow, 0) == {"name": "action acceptance"},
    "Action acceptance workflow name must remain stable",
)
marker = "\n  acceptance:\n"
require(workflow.count(marker) == 1, "Action acceptance aggregate must be unique")
aggregate = workflow.split(marker, 1)[1]
required_fragments = [
    "needs: [prepare-candidate, action, zero-input, nested-layout, setup-failure, tamper, verify-action-finalization]",
    "if: ${{ always() && !cancelled() }}",
    "PREPARE_RESULT: ${{ needs.prepare-candidate.result }}",
    "ACTION_RESULT: ${{ needs.action.result }}",
    "ZERO_INPUT_RESULT: ${{ needs.zero-input.result }}",
    "NESTED_LAYOUT_RESULT: ${{ needs.nested-layout.result }}",
    "SETUP_FAILURE_RESULT: ${{ needs.setup-failure.result }}",
    "TAMPER_RESULT: ${{ needs.tamper.result }}",
    "FINALIZATION_RESULT: ${{ needs.verify-action-finalization.result }}",
    'if [[ "$result" != "success" ]]; then',
]
for fragment in required_fragments:
    require(fragment in aggregate, "Action acceptance aggregate must fail closed")
require(aggregate.count("exit 1") == 1, "Action acceptance aggregate must reject unsuccessful jobs")
for fragment in [
    "workflow_call:",
    "action_ref:",
    "candidate_kind:",
    "ref: ${{ steps.candidate.outputs.action_ref }}",
    "script/assemble-action-bundle",
    "script/validate-action-bundle --root \"$candidate_root\"",
    "run: script/validate-action-bundle",
]:
    require(fragment in workflow, "Reusable Action acceptance candidate contract is incomplete")
require(
    workflow.count("- name: require bundled Action activation") == 5,
    "Action acceptance must fail closed at every classifier-backed activation boundary",
)
require(
    workflow.count('CLASSIFICATION: ${{ steps.bundle-host.outputs.classification }}') == 5,
    "Action acceptance classifier guards are incomplete",
)

workflow_triggers = indented_block(
    workflow,
    "on:",
    "Action acceptance must have one top-level trigger contract",
)
require_exact_mapping_keys(
    workflow_triggers,
    2,
    ["push", "pull_request", "workflow_call"],
    "Action acceptance triggers must remain fixed to main pushes, main pull requests, and reusable calls",
)
for trigger_name in ["push", "pull_request"]:
    trigger = indented_block(
        workflow_triggers,
        f"  {trigger_name}:",
        f"Action acceptance {trigger_name} trigger must be unique",
    )
    require_exact_mapping_keys(
        trigger,
        4,
        ["branches"],
        f"Action acceptance {trigger_name} trigger must contain only a branch filter",
    )
    require(
        re.findall(
            r"(?m)^      - ([^#\n]+?)(?:[ \t]+#.*)?[ \t]*$",
            trigger,
        )
        == ["main"],
        f"Action acceptance {trigger_name} trigger must remain limited to main",
    )

workflow_call = indented_block(
    workflow_triggers,
    "  workflow_call:",
    "Action acceptance reusable-call contract must be unique",
)
require_exact_mapping_keys(
    workflow_call,
    4,
    ["inputs"],
    "Action acceptance reusable call may expose only its reviewed inputs",
)
workflow_inputs = indented_block(
    workflow_call,
    "    inputs:",
    "Action acceptance reusable inputs must be unique",
)
require_exact_mapping_keys(
    workflow_inputs,
    6,
    ["action_ref", "candidate_kind", "acceptance_runner"],
    "Action acceptance reusable inputs must remain narrowly scoped",
)
runner_input = indented_block(
    workflow_inputs,
    "      acceptance_runner:",
    "Action acceptance runner input must be unique",
)
require_exact_mapping_keys(
    runner_input,
    8,
    ["description", "required", "default", "type"],
    "Action acceptance runner input fields must remain narrowly scoped",
)
runner_input_fields = scalar_mapping(runner_input, 8)
require(
    runner_input_fields.get("required") == "false"
    and runner_input_fields.get("default") == "ubuntu-24.04"
    and runner_input_fields.get("type") == "string",
    "Action acceptance runner input must be an optional string defaulting to ubuntu-24.04",
)

jobs = indented_block(workflow, "jobs:", "Action acceptance jobs contract must be unique")
target_jobs = [
    "action",
    "zero-input",
    "nested-layout",
    "setup-failure",
    "tamper",
    "action-finalization",
]
support_jobs = ["prepare-candidate", "verify-action-finalization", "acceptance"]
require_exact_mapping_keys(
    jobs,
    2,
    target_jobs + support_jobs,
    "Action acceptance must retain six target job definitions and three fixed support jobs",
)

prepare = indented_block(
    jobs,
    "  prepare-candidate:",
    "Action acceptance candidate preparation job must be unique",
)
select_candidate = indented_block(
    prepare,
    "      - name: select candidate",
    "Action acceptance candidate selection step must be unique",
)
require(
    prepare.index("      - name: select candidate")
    < prepare.index("      - name: checkout candidate source"),
    "Action acceptance runner validation must happen before checkout",
)
for fragment in [
    "acceptance_runner: ${{ steps.candidate.outputs.acceptance_runner }}",
    "INPUT_ACCEPTANCE_RUNNER: ${{ inputs.acceptance_runner }}",
    'acceptance_runner="${INPUT_ACCEPTANCE_RUNNER:-ubuntu-24.04}"',
    'echo "acceptance_runner=$acceptance_runner" >> "$GITHUB_OUTPUT"',
]:
    require(fragment in prepare, "Action acceptance validated runner output contract is incomplete")

runner_case_match = re.search(
    r'(?ms)^          case "\$acceptance_runner" in\n(.*?)^          esac$',
    select_candidate,
)
require(runner_case_match is not None, "Action acceptance runner allowlist must be explicit")
runner_case = runner_case_match.group(1)
expected_runner_case = (
    "            ubuntu-24.04) ;;\n"
    "            ubuntu-latest)\n"
    '              if [[ "$GITHUB_REF" != "refs/heads/main" ]]; then\n'
    '                echo "ubuntu-latest acceptance must run from refs/heads/main" >&2\n'
    "                exit 1\n"
    "              fi\n"
    "              ;;\n"
    "            *)\n"
    '              echo "acceptance_runner must be ubuntu-24.04 or ubuntu-latest" >&2\n'
    "              exit 1\n"
    "              ;;\n"
)
require(
    runner_case == expected_runner_case,
    "Action acceptance runner allowlist and main-only ubuntu-latest guard must fail closed",
)

validated_runner = "${{ needs.prepare-candidate.outputs.acceptance_runner }}"
for job_name in target_jobs:
    job = indented_block(
        jobs,
        f"  {job_name}:",
        f"Action acceptance {job_name} job must be unique",
    )
    require(
        scalar_mapping(job, 4).get("runs-on") == validated_runner,
        f"Action acceptance {job_name} must use only the validated runner output",
    )
for job_name in support_jobs:
    job = indented_block(
        jobs,
        f"  {job_name}:",
        f"Action acceptance {job_name} job must be unique",
    )
    require(
        scalar_mapping(job, 4).get("runs-on") == "ubuntu-24.04",
        f"Action acceptance {job_name} must remain fixed to ubuntu-24.04",
    )
require(
    "inputs.acceptance_runner" not in "\n".join(
        re.findall(r"(?m)^.*runs-on:.*$", workflow)
    ),
    "Action acceptance must not interpolate the raw runner input into runs-on",
)
require(
    workflow.count(f"runs-on: {validated_runner}") == len(target_jobs)
    and workflow.count("runs-on: ubuntu-24.04") == len(support_jobs),
    "Action acceptance runner routing must remain complete and exclusive",
)

nightly_path = root / ".github/workflows/action-acceptance-ubuntu-latest.yml"
require(nightly_path.is_file(), "Nightly ubuntu-latest acceptance workflow is missing")
nightly = nightly_path.read_text(encoding="utf-8")
require_exact_mapping_keys(
    nightly,
    0,
    ["name", "on", "permissions", "concurrency", "jobs"],
    "Nightly ubuntu-latest workflow must remain a minimal reusable-workflow caller",
)
require(
    scalar_mapping(nightly, 0) == {"name": "nightly"},
    "Nightly ubuntu-latest workflow name must remain stable",
)

nightly_triggers = indented_block(
    nightly,
    "on:",
    "Nightly ubuntu-latest trigger contract must be unique",
)
require_exact_mapping_keys(
    nightly_triggers,
    2,
    ["schedule", "workflow_dispatch"],
    "Nightly ubuntu-latest may run only on schedule or manual dispatch",
)
nightly_schedule = indented_block(
    nightly_triggers,
    "  schedule:",
    "Nightly ubuntu-latest schedule must be unique",
)
nightly_schedule_lines = [
    line
    for line in nightly_schedule.splitlines()[1:]
    if line.strip() and not line.lstrip().startswith("#")
]
require(
    len(nightly_schedule_lines) == 1
    and re.fullmatch(
        r'''    - cron: ["']17 9 \* \* \*["'](?:[ \t]+#.*)?''',
        nightly_schedule_lines[0],
    )
    is not None,
    "Nightly ubuntu-latest schedule must run daily at 09:17 UTC",
)
nightly_dispatch = indented_block(
    nightly_triggers,
    "  workflow_dispatch:",
    "Nightly ubuntu-latest manual trigger must be unique",
)
require(
    all(
        not line.strip() or line.lstrip().startswith("#")
        for line in nightly_dispatch.splitlines()[1:]
    ),
    "Nightly ubuntu-latest manual dispatch must not accept inputs",
)

nightly_permissions_block = indented_block(
    nightly,
    "permissions:",
    "Nightly ubuntu-latest permissions contract must be unique",
)
require_exact_mapping_keys(
    nightly_permissions_block,
    2,
    ["actions", "contents"],
    "Nightly ubuntu-latest permissions must remain narrowly scoped",
)
nightly_permissions = scalar_mapping(nightly_permissions_block, 2)
require(
    nightly_permissions == {"actions": "read", "contents": "read"},
    "Nightly ubuntu-latest permissions must be limited to read-only actions and contents",
)
nightly_concurrency_block = indented_block(
    nightly,
    "concurrency:",
    "Nightly ubuntu-latest concurrency contract must be unique",
)
require_exact_mapping_keys(
    nightly_concurrency_block,
    2,
    ["group", "cancel-in-progress"],
    "Nightly ubuntu-latest concurrency fields must remain narrowly scoped",
)
nightly_concurrency = scalar_mapping(nightly_concurrency_block, 2)
require(
    nightly_concurrency
    == {"group": "nightly-ubuntu-latest", "cancel-in-progress": "false"},
    "Nightly ubuntu-latest concurrency must be distinct and non-cancelling",
)

nightly_jobs = indented_block(
    nightly,
    "jobs:",
    "Nightly ubuntu-latest jobs contract must be unique",
)
require_exact_mapping_keys(
    nightly_jobs,
    2,
    ["acceptance"],
    "Nightly ubuntu-latest must contain exactly one caller job",
)
nightly_job = indented_block(
    nightly_jobs,
    "  acceptance:",
    "Nightly ubuntu-latest caller job must be unique",
)
require_exact_mapping_keys(
    nightly_job,
    4,
    ["name", "uses", "with"],
    "Nightly ubuntu-latest caller may contain only its name, reusable call, and reviewed inputs",
)
require(
    scalar_mapping(nightly_job, 4)
    == {
        "name": "ubuntu-latest action acceptance",
        "uses": "./.github/workflows/action-acceptance.yml",
    },
    "Nightly ubuntu-latest caller job must remain an unconditional local reusable-workflow call",
)
nightly_with = indented_block(
    nightly_job,
    "    with:",
    "Nightly ubuntu-latest caller inputs must be unique",
)
require_exact_mapping_keys(
    nightly_with,
    6,
    ["action_ref", "candidate_kind", "acceptance_runner"],
    "Nightly ubuntu-latest caller inputs must remain narrowly scoped",
)
require(
    scalar_mapping(nightly_with, 6)
    == {
        "action_ref": "${{ github.sha }}",
        "candidate_kind": "source",
        "acceptance_runner": "ubuntu-latest",
    },
    "Nightly ubuntu-latest must validate the exact current source SHA on the floating label",
)
for forbidden in [
    "continue-on-error",
    "runs-on:",
    "steps:",
    "::warning::",
]:
    require(
        forbidden not in nightly,
        "Nightly ubuntu-latest caller contains duplicated implementation or a warning-only escape path",
    )

readme = (root / "README.md").read_text(encoding="utf-8")
nightly_badge = "[![nightly](https://github.com/GrantBirki/fence/actions/workflows/action-acceptance-ubuntu-latest.yml/badge.svg?branch=main)](https://github.com/GrantBirki/fence/actions/workflows/action-acceptance-ubuntu-latest.yml)"
require(
    readme.count(nightly_badge) == 1,
    "README must expose exactly one main-branch nightly ubuntu-latest status badge",
)

canary_path = root / ".github/workflows/action-drift-canary.yml"
require(canary_path.is_file(), "Action drift canary workflow is missing")
canary = canary_path.read_text(encoding="utf-8")
trigger_marker = "\non:\n"
permissions_marker = "\npermissions:\n"
defaults_marker = "\ndefaults:\n"
concurrency_marker = "\nconcurrency:\n"
jobs_marker = "\njobs:\n"
for marker in [
    trigger_marker,
    permissions_marker,
    defaults_marker,
    concurrency_marker,
    jobs_marker,
]:
    require(canary.count(marker) == 1, "Action drift canary top-level contract is invalid")
triggers = canary.split(trigger_marker, 1)[1].split(permissions_marker, 1)[0]
permissions = canary.split(permissions_marker, 1)[1].split(defaults_marker, 1)[0]
concurrency = canary.split(concurrency_marker, 1)[1].split(jobs_marker, 1)[0]
for fragment in [
    '  schedule:\n    - cron: "23 13 * * *"',
    "  workflow_dispatch:\n    inputs:\n      action_ref:",
    "  workflow_call:\n    inputs:\n      action_ref:",
]:
    require(fragment in triggers, "Action drift canary triggers must remain fixed and reusable")
for forbidden_trigger in ["  push:", "  pull_request:", "  repository_dispatch:"]:
    require(forbidden_trigger not in triggers, "Action drift canary contains an unreviewed trigger")
require(permissions == "  contents: read\n", "Action drift canary permissions must be read-only")
require(
    concurrency == "  group: action-drift-canary-${{ inputs.action_ref || github.sha }}\n  cancel-in-progress: false\n",
    "Action drift canary concurrency must be commit-scoped and non-cancelling",
)
canary_fragments = [
    "runs-on: ubuntu-24.04",
    "uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd",
    "persist-credentials: false",
    "run: script/validate-locks --ci",
    "run: script/validate-action-bundle",
    "run: script/test-action-wrapper",
    "run: script/observe-hosted-runner",
    "id: bundle-host",
    "run: script/classify-action-bundle-host",
    "--exclude-pre-releases",
    "--exclude-drafts",
    "action-release.json",
    '"release-candidate/$tag" "release-verified/$tag"',
    "wasSignedByGitHub",
    "mapped Action commit parent mismatch",
    "mapped Action commit diff mismatch",
    "mapped bundle manifest mismatch",
]
for fragment in canary_fragments:
    require(fragment in canary, "Action drift canary contract is incomplete")

require(canary.count("runs-on: ubuntu-24.04") == 1, "Action drift canary must use one fixed runner")
require(canary.count("uses: ./") == 1, "Action drift canary must activate the bundle exactly once")
require(
    canary.count("script/test-action-acceptance standard") == 1,
    "Action drift canary must validate one standard lifecycle",
)

for forbidden in [
    "continue-on-error",
    "actions/upload-artifact",
    "journalctl",
    "systemctl status",
    "ubuntu-latest",
]:
    require(forbidden not in canary, "Action drift canary contains a forbidden escape path")
require(
    re.findall(r"(?m)^        if:[ \t]*(.+)$", canary)
    == ["steps.resolve.outputs.mapped_release == 'true'"],
    "Action drift canary may condition only the mapped-release provenance gate",
)

guard_marker = "\n      - name: require bundled Action activation\n"
activation_marker = "\n      - name: activate bundled Fence agent with strict defaults\n"
verification_marker = "\n      - name: verify zero-input Action lifecycle\n"
require(canary.count(guard_marker) == 1, "Action drift canary classifier guard must be unique")
require(canary.count(activation_marker) == 1, "Action drift canary activation step must be unique")
require(canary.count(verification_marker) == 1, "Action drift canary lifecycle step must be unique")
guard = canary.split(guard_marker, 1)[1].split(activation_marker, 1)[0]
activation = canary.split(activation_marker, 1)[1].split(verification_marker, 1)[0]
verification = canary.split(verification_marker, 1)[1]
expected_guard = (
    "        env:\n"
    "          RUN_BUNDLE: ${{ steps.bundle-host.outputs.run_bundle }}\n"
    "          CLASSIFICATION: ${{ steps.bundle-host.outputs.classification }}\n"
    "        run: |\n"
    '          if [[ "$RUN_BUNDLE" != "true" || "$CLASSIFICATION" != "bundle_compatible" ]]; then\n'
    '            echo "::error::bundled Action host classification did not authorize activation"\n'
    "            exit 1\n"
    "          fi\n"
)
require(guard == expected_guard, "Action drift canary classifier guard must fail closed")
require(activation == "        uses: ./\n", "Action drift canary activation must use zero inputs")
require(
    verification
    == '        run: script/test-action-acceptance standard "fence-${GITHUB_RUN_ID}-${GITHUB_RUN_ATTEMPT}"\n',
    "Action drift canary lifecycle validation must be unconditional",
)

release = (root / ".github/workflows/release.yml").read_text(encoding="utf-8")
for fragment in [
    "group: release",
    "createCommitOnBranch",
    "expectedHeadOid",
    "wasSignedByGitHub",
    "action/bin/fence",
    "action/bundle-manifest.json",
    "uses: ./.github/workflows/action-acceptance.yml",
    "uses: ./.github/workflows/action-drift-canary.yml",
    "action-release.json",
    'gh release create "$VERSION_TAG" "${assets[@]}" "${release_args[@]}"',
    'echo "- uses: GrantBirki/fence@$ACTION_COMMIT"',
]:
    require(fragment in release, "One-PR Action release workflow contract is incomplete")
require(
    release.count("uses: ./.github/workflows/action-acceptance.yml") == 1,
    "Release workflow must invoke Action acceptance exactly once",
)
release_acceptance = indented_block(
    release,
    "  candidate-action-acceptance:",
    "Release Action acceptance caller must be unique",
)
release_acceptance_with = indented_block(
    release_acceptance,
    "    with:",
    "Release Action acceptance inputs must be unique",
)
require_exact_mapping_keys(
    release_acceptance_with,
    6,
    ["action_ref", "candidate_kind"],
    "Release Action acceptance inputs must retain the fixed default runner",
)
require(
    scalar_mapping(release_acceptance_with, 6)
    == {
        "action_ref": "${{ needs.create-candidate.outputs.action_commit }}",
        "candidate_kind": "distribution",
    },
    "Release Action acceptance must retain the fixed default runner",
)
for required_check in [
    '"build"',
    '"coverage"',
    '"lint (macos-14)"',
    '"lint (ubuntu-24.04)"',
    '"acceptance"',
    '"action acceptance"',
    '"integration"',
    '"test (macos-14)"',
    '"test (ubuntu-24.04)"',
]:
    require(required_check in release, "Release workflow is missing a protected source check")
require("workflow_dispatch:" not in release, "Release workflow must not be manually dispatchable")
require(release.count("      contents: write") == 3, "Only candidate, publication, and guarded cleanup jobs may write contents")
require(release.count("    environment: release") == 3, "Every release mutation must use the protected release environment")
require(release.count("      id-token: write") == 1, "Only release attestation may mint an OIDC token")
require(release.count("      attestations: write") == 1, "Only the attestation job may write attestations")
require(
    release.count("uses: actions/checkout@") == release.count("persist-credentials: false"),
    "Every release checkout must disable persisted credentials",
)
PY

  if PYTHONOPTIMIZE=1 python3 -E - <<'PY' >/dev/null 2>&1
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message):
    if not condition:
        raise SystemExit(message)

require(False, "synthetic malformed evidence")
PY
  then
    die "environment optimization bypassed unconditional evidence validation"
  fi

  if python3 -O - <<'PY' >/dev/null 2>&1
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")
PY
  then
    die "optimized Python bypassed the evidence validation guard"
  fi
}

validate_tooling_layout() {
  local required=(
    "$RUST_TOOLCHAIN_LOCK"
    "$UPDATE_TOOLS_LOCK"
    "$RELEASE_TOOLS_LOCK"
    "$TEST_TOOLS_LOCK"
    "$ZIG_VERSION_FILE"
    "$CARGO_ZIGBUILD_VERSION_FILE"
    "$CARGO_LLVM_COV_VERSION_FILE"
    "$CARGO_AUDIT_VERSION_FILE"
    "$CARGO_DENY_VERSION_FILE"
  )
  local old=(
    "$DIR/rust-toolchain.lock.toml"
    "$DIR/update-tools.lock.toml"
    "$DIR/release-tools.lock.toml"
    "$DIR/test-tools.lock.toml"
    "$DIR/.zig-version"
    "$DIR/.cargo-zigbuild-version"
    "$DIR/.cargo-llvm-cov-version"
    "$DIR/.cargo-audit-version"
    "$DIR/.cargo-deny-version"
  )
  local file

  for file in "${required[@]}"; do
    if [[ ! -f "$file" ]]; then
      die "missing tooling metadata: ${file#$DIR/}"
    fi
  done

  for file in "${old[@]}"; do
    if [[ -e "$file" ]]; then
      die "obsolete root tooling metadata is not allowed: ${file#$DIR/}; use .cargo/tooling/"
    fi
  done
}

validate_tooling_layout

if [[ "$ci" == "true" ]]; then
  script/validate-rust-toolchain --ci
  script/validate-update-tools --ci
else
  script/validate-rust-toolchain
  script/validate-update-tools
fi

script/validate-release-tools
script/validate-test-tools
script/validate-action-bundle --allow-source
validate_cargo_vendor_surface
validate_workflow_uses_pinned
validate_ci_evidence

echo -e "${GREEN}lock surfaces verified${OFF}"
