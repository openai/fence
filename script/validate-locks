#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

ci=false
case "${1:-}" in
  --ci)
    ci=true
    ;;
  ""|--offline)
    ;;
  *)
    die "usage: script/validate-locks [--ci|--offline]"
    ;;
esac

validate_direct_dependencies_exact() {
  awk '
    /^\[dependencies\]/ {
      in_deps = 1
      next
    }
    /^\[/ {
      if (in_deps) {
        exit
      }
    }
    in_deps {
      line = $0
      sub(/[[:space:]]*#.*/, "", line)
      if (line ~ /^[[:space:]]*$/) {
        next
      }
      if (line !~ /^[[:space:]]*[A-Za-z0-9_-]+[[:space:]]*=/) {
        next
      }
      if (line ~ /=[[:space:]]*"=/ || line ~ /version[[:space:]]*=[[:space:]]*"=/) {
        next
      }
      print line
      bad = 1
    }
    END {
      exit bad ? 1 : 0
    }
  ' "$DIR/Cargo.toml"
}

validate_workflow_uses_pinned() {
  local workflow
  local line
  local value
  local ref
  local failed=false

  for workflow in "$DIR"/.github/workflows/*.yml "$DIR"/.github/workflows/*.yaml; do
    [[ -e "$workflow" ]] || continue
    while IFS= read -r line; do
      value="${line#*uses:}"
      value="${value%%#*}"
      value="$(printf '%s' "$value" | sed "s/^[[:space:]]*//; s/[[:space:]]*$//; s/^[\"']//; s/[\"']$//")"
      [[ -n "$value" ]] || continue
      case "$value" in
        ./*) continue ;;
        *@*)
          ref="${value##*@}"
          if ! [[ "$ref" =~ ^[0-9a-f]{40}$ ]]; then
            echo "${workflow#$DIR/}: uses ref is not a full commit SHA: $value" >&2
            failed=true
          fi
          ;;
        *)
          echo "${workflow#$DIR/}: uses ref is missing @<sha>: $value" >&2
          failed=true
          ;;
      esac
    done < <(grep -nE '^[[:space:]]*uses:[[:space:]]*' "$workflow" || true)

    if grep -nE '^[[:space:]]*image:[[:space:]]*[^#[:space:]]' "$workflow" | grep -v '@sha256:' >&2; then
      failed=true
    fi
    if grep -nE '^[[:space:]]*container:[[:space:]]*[^#{[:space:]]' "$workflow" | grep -v '@sha256:' >&2; then
      failed=true
    fi
  done

  if [[ "$failed" == "true" ]]; then
    die "workflow actions and images must be pinned to immutable SHAs or digests"
  fi
}

validate_cargo_vendor_surface() {
  if [[ ! -f "$DIR/Cargo.lock" ]]; then
    die "missing Cargo.lock"
  fi
  if [[ ! -f "$DIR/.cargo/config.toml" ]]; then
    die "missing .cargo/config.toml"
  fi
  if ! grep -q 'replace-with[[:space:]]*=[[:space:]]*"vendored-sources"' "$DIR/.cargo/config.toml"; then
    die ".cargo/config.toml must replace crates.io with vendored sources"
  fi
  if ! grep -q 'offline[[:space:]]*=[[:space:]]*true' "$DIR/.cargo/config.toml"; then
    die ".cargo/config.toml must keep Cargo offline by default"
  fi
  if [[ ! -d "$VENDOR_DIR" || -z "$(ls -A "$VENDOR_DIR" 2>/dev/null)" ]]; then
    die "vendor cache is empty; run script/update while online"
  fi
  if ! find "$VENDOR_DIR" -mindepth 2 -maxdepth 2 -name .cargo-checksum.json -print -quit | grep -q .; then
    die "vendor cache is missing Cargo checksum metadata"
  fi
  if ! validate_direct_dependencies_exact; then
    die "Cargo.toml direct dependencies must use exact versions"
  fi
  if [[ -e "$DIR/vendor/update-tools" ]] && { [[ ! -d "$DIR/vendor/update-tools" ]] || find "$DIR/vendor/update-tools" -mindepth 1 -print -quit | grep -q .; }; then
    die "update-tool dependency locks belong in ${UPDATE_TOOLS_LOCK#$DIR/}; do not commit vendor/update-tools"
  fi
}

validate_ci_evidence() {
  python3 -E - "$DIR" <<'PY'
import ast
import collections
import contextlib
import io
import json
import os
import pathlib
import re
import sys
import textwrap
import time
import urllib.parse
import urllib.request

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message):
    if not condition:
        raise SystemExit(message)

def indented_block(source, header, message):
    lines = source.splitlines()
    header_pattern = re.compile(rf"^{re.escape(header)}(?:[ \t]+#.*)?$")
    matches = [
        index for index, line in enumerate(lines) if header_pattern.fullmatch(line)
    ]
    require(len(matches) == 1, message)
    start = matches[0]
    indentation = len(header) - len(header.lstrip())
    end = len(lines)
    for index in range(start + 1, len(lines)):
        line = lines[index]
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        if len(line) - len(line.lstrip()) <= indentation:
            end = index
            break
    return "\n".join(lines[start:end]) + "\n"

def direct_mapping_keys(block, indentation):
    prefix = " " * indentation
    keys = re.findall(
        rf"(?m)^{prefix}([A-Za-z0-9_-]+):[^\n]*$",
        block,
    )
    require(
        len(keys) == len(set(keys)),
        "Workflow mappings must not contain duplicate keys",
    )
    return keys

def require_exact_mapping_keys(block, indentation, expected, message):
    keys = direct_mapping_keys(block, indentation)
    require(
        len(keys) == len(expected) and set(keys) == set(expected),
        message,
    )

def scalar_mapping(block, indentation):
    prefix = " " * indentation
    entries = []
    for match in re.finditer(
        rf"(?m)^{prefix}([A-Za-z0-9_-]+):[ \t]+(.+?)[ \t]*$",
        block,
    ):
        value = re.sub(r"[ \t]+#.*$", "", match.group(2)).rstrip()
        entries.append((match.group(1), value))
    require(
        len(entries) == len(dict(entries)),
        "Workflow scalar mappings must not contain duplicate keys",
    )
    return dict(entries)

def require_step_contract(job, name, expected_keys, expected_scalars, message):
    step = indented_block(
        job,
        f"      - name: {name}",
        f"{message} must be unique",
    )
    require_exact_mapping_keys(step, 8, expected_keys, f"{message} fields changed")
    require(
        scalar_mapping(step, 8) == expected_scalars,
        f"{message} scalar contract changed",
    )
    return step

def literal_run_body(step, message):
    marker = "        run: |\n"
    require(step.count(marker) == 1, message)
    return step.split(marker, 1)[1].rstrip() + "\n"

def workflow_uses(source):
    return collections.Counter(
        re.findall(
            r"(?m)^[ \t]+uses:[ \t]+([^#\s]+)(?:[ \t]+#.*)?$",
            source,
        )
    )

def require_no_write_permissions(source, message):
    require(
        re.search(
            r'''(?m)^[ \t]+[A-Za-z0-9_-]+:[ \t]+["']?write["']?(?:[ \t]+#.*)?$''',
            source,
        )
        is None,
        message,
    )

root = pathlib.Path(sys.argv[1])
workflow_dir = root / ".github/workflows"
workflow_paths = sorted(
    [*workflow_dir.glob("*.yml"), *workflow_dir.glob("*.yaml")],
    key=lambda path: path.name,
)
workflow_sources = {
    path.name: path.read_text(encoding="utf-8") for path in workflow_paths
}
checkout_actions = {
    action
    for source in workflow_sources.values()
    for action in workflow_uses(source)
    if action.startswith("actions/checkout@")
}
require(
    len(checkout_actions) == 1
    and re.fullmatch(r"actions/checkout@[0-9a-f]{40}", next(iter(checkout_actions)))
    is not None,
    "Workflow checkout actions must share one immutable full commit SHA",
)
checkout_action = next(iter(checkout_actions))
for source in workflow_sources.values():
    require(
        len(re.findall(r"(?m)^on:(?:[ \t]+#.*)?$", source)) == 1,
        "Workflow triggers must use one explicit top-level mapping",
    )
    require(
        re.search(r'''(?m)^ {0,10}["'][A-Za-z0-9_-]+["'][ \t]*:''', source)
        is None,
        "Workflow structural keys must remain unquoted",
    )
pull_request_workflows = {
    name for name, source in workflow_sources.items() if re.search(r"(?m)^  pull_request:", source)
}
require(
    pull_request_workflows
    == {
        "lint.yml",
        "test.yml",
        "build.yml",
        "acceptance.yml",
        "action-acceptance.yml",
        "integration.yml",
    },
    "Pull requests must run exactly the six reviewed CI workflows",
)
pull_request_sources = {
    name: source
    for name, source in workflow_sources.items()
    if name in pull_request_workflows
}
require(
    all("macos-" not in source for source in pull_request_sources.values()),
    "Pull-request workflows must not claim pre-merge macOS assurance",
)
for source in pull_request_sources.values():
    require_no_write_permissions(
        source,
        "Pull-request workflows must not grant write permissions",
    )

validator_paths = [
    "script/test-action-acceptance",
    "script/test-action-tamper",
    "script/test-lockdown",
    "script/test-protected-run",
    "script/test-selected-profile-runtime",
    "script/report-selected-profile-runtime",
]

for relative in validator_paths:
    source = (root / relative).read_text(encoding="utf-8")
    invocations = [
        line
        for line in source.splitlines()
        if re.match(r"^\s*python3(?:\s|$)", line)
    ]
    require(invocations, f"{relative}: missing Python evidence validator")
    require(
        all(re.match(r"^\s*python3 -E(?:\s|$)", line) for line in invocations),
        f"{relative}: Python evidence validators must ignore environment options",
    )

    blocks = re.findall(r"<<'PY'\n(.*?)\nPY(?:\n|$)", source, re.DOTALL)
    require(blocks, f"{relative}: missing inline Python evidence validator")
    for block in blocks:
        tree = ast.parse(block, filename=relative)
        require(
            not any(isinstance(node, ast.Assert) for node in ast.walk(tree)),
            f"{relative}: evidence validation must not use Python assert",
        )
        uses_require = any(
            isinstance(node, ast.Call)
            and isinstance(node.func, ast.Name)
            and node.func.id == "require"
            for node in ast.walk(tree)
        )
        if uses_require:
            require(
                "sys.flags.optimize != 0" in block
                and 'raise SystemExit("Python optimization must be disabled")' in block,
                f"{relative}: evidence validator must reject optimized Python",
            )

ci_specs = {
    "lint": {
        "steps": [
            "checkout",
            "validate locks",
            "prepare rust",
            "bootstrap",
            "lint",
        ],
        "commands": [
            ("validate locks", "script/validate-locks --ci"),
            ("prepare rust", "script/prepare-rust"),
            ("bootstrap", "script/bootstrap"),
            ("lint", "script/lint"),
        ],
    },
    "test": {
        "steps": [
            "checkout",
            "validate locks",
            "prepare rust",
            "install test tools",
            "bootstrap",
            "test with coverage",
        ],
        "commands": [
            ("validate locks", "script/validate-locks --ci"),
            ("prepare rust", "script/prepare-rust"),
            ("install test tools", "script/install-test-tools"),
            ("bootstrap", "script/bootstrap"),
            ("test with coverage", "script/test --coverage"),
        ],
    },
    "build": {
        "steps": [
            "checkout",
            "validate locks",
            "prepare rust",
            "bootstrap",
            "build Linux x64 binary",
        ],
        "commands": [
            ("validate locks", "script/validate-locks --ci"),
            ("prepare rust", "script/prepare-rust"),
            ("bootstrap", "script/bootstrap"),
            ("build Linux x64 binary", "script/build"),
        ],
    },
    "acceptance": {
        "steps": [
            "checkout",
            "validate locks",
            "prepare rust",
            "bootstrap",
            "install retained cross-build tools",
            "verify retained cross-build tools",
            "build packaged Linux x64 artifact",
            "verify packaged artifact checksum",
            "exercise packaged public contract",
        ],
        "commands": [
            ("validate locks", "script/validate-locks --ci"),
            ("prepare rust", "script/prepare-rust"),
            ("bootstrap", "script/bootstrap"),
            ("install retained cross-build tools", "script/install-zig"),
            ("verify retained cross-build tools", "script/verify-release-toolchain"),
        ],
    },
}
ci_sources = {}
for workflow_name, spec in ci_specs.items():
    ci_path = root / ".github/workflows" / f"{workflow_name}.yml"
    require(ci_path.is_file(), f"{workflow_name} CI workflow is missing")
    ci_workflow = ci_path.read_text(encoding="utf-8")
    ci_sources[workflow_name] = ci_workflow
    label = f"{workflow_name} CI"

    require(
        workflow_uses(ci_workflow)
        == collections.Counter(
            {checkout_action: 1}
        ),
        f"{label} may use only the reviewed checkout step",
    )
    require_exact_mapping_keys(
        ci_workflow,
        0,
        ["name", "on", "permissions", "defaults", "concurrency", "jobs"],
        f"{label} top-level workflow contract must remain narrowly scoped",
    )
    require(
        scalar_mapping(ci_workflow, 0) == {"name": workflow_name},
        f"{label} workflow name must match its filename",
    )

    ci_triggers = indented_block(
        ci_workflow,
        "on:",
        f"{label} trigger contract must be unique",
    )
    require_exact_mapping_keys(
        ci_triggers,
        2,
        ["push", "pull_request"],
        f"{label} must run only on main pushes and pull requests",
    )
    for trigger_name in ["push", "pull_request"]:
        trigger = indented_block(
            ci_triggers,
            f"  {trigger_name}:",
            f"{label} {trigger_name} trigger must be unique",
        )
        require_exact_mapping_keys(
            trigger,
            4,
            ["branches"],
            f"{label} {trigger_name} trigger must contain only a branch filter",
        )
        require(
            re.findall(
                r"(?m)^      - ([^#\n]+?)(?:[ \t]+#.*)?[ \t]*$",
                trigger,
            )
            == ["main"],
            f"{label} {trigger_name} trigger must remain limited to main",
        )

    ci_permissions = indented_block(
        ci_workflow,
        "permissions:",
        f"{label} permissions must be unique",
    )
    require_exact_mapping_keys(
        ci_permissions,
        2,
        ["contents"],
        f"{label} permissions must remain narrowly scoped",
    )
    require(
        scalar_mapping(ci_permissions, 2) == {"contents": "read"},
        f"{label} permissions must remain read-only",
    )

    ci_defaults = indented_block(
        ci_workflow,
        "defaults:",
        f"{label} defaults must be unique",
    )
    require_exact_mapping_keys(
        ci_defaults,
        2,
        ["run"],
        f"{label} defaults may configure only run steps",
    )
    ci_run_defaults = indented_block(
        ci_defaults,
        "  run:",
        f"{label} run defaults must be unique",
    )
    require_exact_mapping_keys(
        ci_run_defaults,
        4,
        ["shell"],
        f"{label} run defaults may configure only the shell",
    )
    require(
        scalar_mapping(ci_run_defaults, 4) == {"shell": "bash"},
        f"{label} run steps must use bash",
    )

    ci_concurrency = indented_block(
        ci_workflow,
        "concurrency:",
        f"{label} concurrency must be unique",
    )
    require_exact_mapping_keys(
        ci_concurrency,
        2,
        ["group", "cancel-in-progress"],
        f"{label} concurrency fields must remain narrowly scoped",
    )
    require(
        scalar_mapping(ci_concurrency, 2)
        == {
            "group": "${{ github.workflow }}-${{ github.event.pull_request.number || github.sha }}",
            "cancel-in-progress": "true",
        },
        f"{label} must cancel superseded PR work without cancelling distinct main commits",
    )

    ci_jobs = indented_block(
        ci_workflow,
        "jobs:",
        f"{label} jobs contract must be unique",
    )
    require_exact_mapping_keys(
        ci_jobs,
        2,
        [workflow_name],
        f"{label} must contain exactly its same-named job",
    )
    job = indented_block(
        ci_jobs,
        f"  {workflow_name}:",
        f"{label} job must be unique",
    )
    require_exact_mapping_keys(
        job,
        4,
        ["name", "timeout-minutes", "runs-on", "steps"],
        f"{label} job fields must remain narrowly scoped",
    )
    require(
        scalar_mapping(job, 4)
        == {
            "name": workflow_name,
            "timeout-minutes": "15",
            "runs-on": "ubuntu-24.04",
        },
        f"{label} job must remain bounded on fixed ubuntu-24.04",
    )

    step_names = re.findall(r"(?m)^      - name: ([^\n]+)$", job)
    require(
        step_names == spec["steps"]
        and len(re.findall(r"(?m)^      - ", job)) == len(step_names),
        f"{label} steps must remain complete, named, and ordered",
    )
    checkout = require_step_contract(
        job,
        "checkout",
        ["uses", "with"],
        {"uses": checkout_action},
        f"{label} checkout",
    )
    checkout_with = indented_block(
        checkout,
        "        with:",
        f"{label} checkout inputs must be unique",
    )
    require_exact_mapping_keys(
        checkout_with,
        10,
        ["persist-credentials"],
        f"{label} checkout may configure only credential persistence",
    )
    require(
        scalar_mapping(checkout_with, 10) == {"persist-credentials": "false"},
        f"{label} checkout must disable persisted credentials",
    )
    for step_name, command in spec["commands"]:
        require_step_contract(
            job,
            step_name,
            ["run"],
            {"run": command},
            f"{label} {step_name} step",
        )

    require(
        ci_workflow.count("uses: actions/checkout@") == 1
        and ci_workflow.count("persist-credentials: false") == 1,
        f"{label} must contain exactly one credential-safe checkout",
    )
    require(
        ci_workflow.count("runs-on: ubuntu-24.04") == 1
        and "runs-on: ${{" not in ci_workflow
        and "macos-" not in ci_workflow,
        f"{label} must run only on literal fixed ubuntu-24.04",
    )
    for forbidden in [
        "continue-on-error",
        "actions/cache",
        "pull_request_target",
        "workflow_dispatch",
        "contents: write",
    ]:
        require(
            forbidden not in ci_workflow,
            f"{label} contains a forbidden escape or mutable surface",
        )

acceptance = indented_block(
    indented_block(
        ci_sources["acceptance"],
        "jobs:",
        "acceptance CI jobs contract must be unique",
    ),
    "  acceptance:",
    "acceptance CI job must be unique",
)
packaged_build = require_step_contract(
    acceptance,
    "build packaged Linux x64 artifact",
    ["env", "run"],
    {
        "run": 'script/build --release --targets "x86_64-unknown-linux-gnu" --dist-dir "$RUNNER_TEMP/fence-acceptance-dist"',
    },
    "acceptance CI packaged build step",
)
packaged_build_env = indented_block(
    packaged_build,
    "        env:",
    "acceptance CI packaged build environment must be unique",
)
require_exact_mapping_keys(
    packaged_build_env,
    10,
    ["BUILD_VERSION"],
    "acceptance CI packaged build environment must remain narrowly scoped",
)
require(
    scalar_mapping(packaged_build_env, 10) == {"BUILD_VERSION": "acceptance"},
    "acceptance CI packaged build version must remain deterministic",
)
checksum_step = require_step_contract(
    acceptance,
    "verify packaged artifact checksum",
    ["run"],
    {"run": "|"},
    "acceptance CI package checksum step",
)
require(
    literal_run_body(checksum_step, "acceptance CI package checksum gate must use a literal run body")
    == (
        '          cd "$RUNNER_TEMP/fence-acceptance-dist"\n'
        "          grep -Eq 'fence_acceptance_linux-amd64$' checksums.txt\n"
        "          sha256sum -c checksums.txt\n"
    ),
    "acceptance CI package checksum gate is incomplete",
)
require_step_contract(
    acceptance,
    "exercise packaged public contract",
    ["run"],
    {"run": 'script/test-package-smoke "$RUNNER_TEMP/fence-acceptance-dist/fence_acceptance_linux-amd64"'},
    "acceptance CI package smoke step",
)

workflow = (root / ".github/workflows/action-acceptance.yml").read_text(encoding="utf-8")
require(
    workflow_uses(workflow)
    == collections.Counter(
        {
            checkout_action: 8,
            "actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a": 2,
            "actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c": 6,
            "./": 3,
            "./target/action-layout/owner/project/revision": 1,
        }
    ),
    "Action acceptance external and local Action uses must match the reviewed allowlist",
)
require_exact_mapping_keys(
    workflow,
    0,
    ["name", "on", "permissions", "defaults", "concurrency", "jobs"],
    "Action acceptance top-level workflow contract must remain narrowly scoped",
)
require(
    scalar_mapping(workflow, 0) == {"name": "action acceptance"},
    "Action acceptance workflow name must remain stable",
)
marker = "\n  acceptance:\n"
require(workflow.count(marker) == 1, "Action acceptance aggregate must be unique")
aggregate = workflow.split(marker, 1)[1]
for fragment in [
    "workflow_call:",
    "action_ref:",
    "candidate_kind:",
    "ref: ${{ steps.candidate.outputs.action_ref }}",
    "script/assemble-action-bundle",
    "script/validate-action-bundle --root \"$candidate_root\"",
    "run: script/validate-action-bundle",
]:
    require(fragment in workflow, "Reusable Action acceptance candidate contract is incomplete")

workflow_triggers = indented_block(
    workflow,
    "on:",
    "Action acceptance must have one top-level trigger contract",
)
require_exact_mapping_keys(
    workflow_triggers,
    2,
    ["push", "pull_request", "workflow_call"],
    "Action acceptance triggers must remain fixed to main pushes, main pull requests, and reusable calls",
)
for trigger_name in ["push", "pull_request"]:
    trigger = indented_block(
        workflow_triggers,
        f"  {trigger_name}:",
        f"Action acceptance {trigger_name} trigger must be unique",
    )
    require_exact_mapping_keys(
        trigger,
        4,
        ["branches"],
        f"Action acceptance {trigger_name} trigger must contain only a branch filter",
    )
    require(
        re.findall(
            r"(?m)^      - ([^#\n]+?)(?:[ \t]+#.*)?[ \t]*$",
            trigger,
        )
        == ["main"],
        f"Action acceptance {trigger_name} trigger must remain limited to main",
    )

workflow_call = indented_block(
    workflow_triggers,
    "  workflow_call:",
    "Action acceptance reusable-call contract must be unique",
)
require_exact_mapping_keys(
    workflow_call,
    4,
    ["inputs"],
    "Action acceptance reusable call may expose only its reviewed inputs",
)
workflow_inputs = indented_block(
    workflow_call,
    "    inputs:",
    "Action acceptance reusable inputs must be unique",
)
require_exact_mapping_keys(
    workflow_inputs,
    6,
    ["action_ref", "candidate_kind", "acceptance_runner"],
    "Action acceptance reusable inputs must remain narrowly scoped",
)
runner_input = indented_block(
    workflow_inputs,
    "      acceptance_runner:",
    "Action acceptance runner input must be unique",
)
require_exact_mapping_keys(
    runner_input,
    8,
    ["description", "required", "default", "type"],
    "Action acceptance runner input fields must remain narrowly scoped",
)
runner_input_fields = scalar_mapping(runner_input, 8)
require(
    runner_input_fields.get("required") == "false"
    and runner_input_fields.get("default") == "ubuntu-24.04"
    and runner_input_fields.get("type") == "string",
    "Action acceptance runner input must be an optional string defaulting to ubuntu-24.04",
)

jobs = indented_block(workflow, "jobs:", "Action acceptance jobs contract must be unique")
target_jobs = [
    "action",
    "zero-input",
    "nested-layout",
    "setup-failure",
    "tamper",
    "action-finalization",
]
support_jobs = ["prepare-candidate", "acceptance"]
require_exact_mapping_keys(
    jobs,
    2,
    target_jobs + support_jobs,
    "Action acceptance must retain six target job definitions and two fixed support jobs",
)

prepare = indented_block(
    jobs,
    "  prepare-candidate:",
    "Action acceptance candidate preparation job must be unique",
)
require_exact_mapping_keys(
    prepare,
    4,
    ["name", "runs-on", "timeout-minutes", "outputs", "steps"],
    "Action acceptance candidate preparation fields must remain narrowly scoped",
)
require(
    scalar_mapping(prepare, 4)
    == {
        "name": "prepare Action candidate",
        "runs-on": "ubuntu-24.04",
        "timeout-minutes": "15",
    },
    "Action acceptance candidate preparation must remain bounded on fixed ubuntu-24.04",
)
require(
    re.findall(r"(?m)^      - name: ([^\n]+)$", prepare)
    == [
        "select candidate",
        "checkout candidate source",
        "require exact checkout",
        "validate source locks",
        "test Action wrapper",
        "require source-only candidate",
        "prepare rust",
        "bootstrap",
        "build and assemble source candidate",
        "validate committed distribution candidate",
        "upload assembled Action bundle",
    ],
    "Action acceptance candidate preparation steps must remain complete and ordered",
)
require(
    prepare.count("run: script/validate-locks --ci") == 1
    and prepare.count("run: script/test-action-wrapper") == 1,
    "Action acceptance commit-global validation must run once during candidate preparation",
)
prepare_checkout = require_step_contract(
    prepare,
    "checkout candidate source",
    ["uses", "with"],
    {"uses": checkout_action},
    "Action acceptance candidate checkout",
)
prepare_checkout_with = indented_block(
    prepare_checkout,
    "        with:",
    "Action acceptance candidate checkout inputs must be unique",
)
require(
    scalar_mapping(prepare_checkout_with, 10)
    == {
        "ref": "${{ steps.candidate.outputs.action_ref }}",
        "fetch-depth": "0",
        "persist-credentials": "false",
    },
    "Action acceptance candidate checkout must use the exact candidate without persisted credentials",
)
require_step_contract(
    prepare,
    "validate source locks",
    ["run"],
    {"run": "script/validate-locks --ci"},
    "Action acceptance source lock validation",
)
require_step_contract(
    prepare,
    "test Action wrapper",
    ["run"],
    {"run": "script/test-action-wrapper"},
    "Action acceptance wrapper validation",
)
candidate_upload = require_step_contract(
    prepare,
    "upload assembled Action bundle",
    ["if", "uses", "with"],
    {
        "if": "steps.candidate.outputs.source_candidate == 'true'",
        "uses": "actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a",
    },
    "Action acceptance candidate bundle upload",
)
candidate_upload_with = indented_block(
    candidate_upload,
    "        with:",
    "Action acceptance candidate bundle upload inputs must be unique",
)
require(
    scalar_mapping(candidate_upload_with, 10)
    == {
        "name": "${{ steps.candidate.outputs.artifact_name }}",
        "path": "|",
        "retention-days": "1",
        "if-no-files-found": "error",
    }
    and re.findall(r"(?m)^            ([^\n]+)$", candidate_upload_with)
    == [
        "${{ runner.temp }}/fence-action-candidate/action/bin/fence",
        "${{ runner.temp }}/fence-action-candidate/action/bundle-manifest.json",
    ],
    "Action acceptance may upload only the bounded source candidate bundle",
)
select_candidate = indented_block(
    prepare,
    "      - name: select candidate",
    "Action acceptance candidate selection step must be unique",
)
require(
    prepare.index("      - name: select candidate")
    < prepare.index("      - name: checkout candidate source"),
    "Action acceptance runner validation must happen before checkout",
)
for fragment in [
    "acceptance_runner: ${{ steps.candidate.outputs.acceptance_runner }}",
    "INPUT_ACCEPTANCE_RUNNER: ${{ inputs.acceptance_runner }}",
    'acceptance_runner="${INPUT_ACCEPTANCE_RUNNER:-ubuntu-24.04}"',
    'echo "acceptance_runner=$acceptance_runner" >> "$GITHUB_OUTPUT"',
]:
    require(fragment in prepare, "Action acceptance validated runner output contract is incomplete")

runner_case_match = re.search(
    r'(?ms)^          case "\$acceptance_runner" in\n(.*?)^          esac$',
    select_candidate,
)
require(runner_case_match is not None, "Action acceptance runner allowlist must be explicit")
runner_case = runner_case_match.group(1)
expected_runner_case = (
    "            ubuntu-24.04) ;;\n"
    "            ubuntu-latest)\n"
    '              if [[ "$GITHUB_REF" != "refs/heads/main" ]]; then\n'
    '                echo "ubuntu-latest acceptance must run from refs/heads/main" >&2\n'
    "                exit 1\n"
    "              fi\n"
    "              ;;\n"
    "            *)\n"
    '              echo "acceptance_runner must be ubuntu-24.04 or ubuntu-latest" >&2\n'
    "              exit 1\n"
    "              ;;\n"
)
require(
    runner_case == expected_runner_case,
    "Action acceptance runner allowlist and main-only ubuntu-latest guard must fail closed",
)

validated_runner = "${{ needs.prepare-candidate.outputs.acceptance_runner }}"
target_job_keys = {
    "action": ["name", "needs", "strategy", "timeout-minutes", "runs-on", "steps"],
    "zero-input": ["name", "needs", "timeout-minutes", "runs-on", "steps"],
    "nested-layout": ["name", "needs", "timeout-minutes", "runs-on", "steps"],
    "setup-failure": ["name", "needs", "timeout-minutes", "runs-on", "steps"],
    "tamper": ["name", "needs", "timeout-minutes", "runs-on", "steps"],
    "action-finalization": ["name", "needs", "strategy", "timeout-minutes", "runs-on", "steps"],
}
for job_name in target_jobs:
    job = indented_block(
        jobs,
        f"  {job_name}:",
        f"Action acceptance {job_name} job must be unique",
    )
    require_exact_mapping_keys(
        job,
        4,
        target_job_keys[job_name],
        f"Action acceptance {job_name} fields must remain narrowly scoped",
    )
    require(
        scalar_mapping(job, 4).get("needs") == "prepare-candidate"
        and scalar_mapping(job, 4).get("runs-on") == validated_runner,
        f"Action acceptance {job_name} must depend on preparation and use only the validated runner output",
    )
for job_name in support_jobs:
    job = indented_block(
        jobs,
        f"  {job_name}:",
        f"Action acceptance {job_name} job must be unique",
    )
    require(
        scalar_mapping(job, 4).get("runs-on") == "ubuntu-24.04",
        f"Action acceptance {job_name} must remain fixed to ubuntu-24.04",
    )
require(
    "inputs.acceptance_runner" not in "\n".join(
        re.findall(r"(?m)^.*runs-on:.*$", workflow)
    ),
    "Action acceptance must not interpolate the raw runner input into runs-on",
)
require(
    workflow.count(f"runs-on: {validated_runner}") == len(target_jobs)
    and workflow.count("runs-on: ubuntu-24.04") == len(support_jobs),
    "Action acceptance runner routing must remain complete and exclusive",
)
action_job = indented_block(
    jobs,
    "  action:",
    "Action acceptance matrix job must be unique",
)
action_strategy = indented_block(
    action_job,
    "    strategy:",
    "Action acceptance matrix strategy must be unique",
)
require(
    scalar_mapping(action_strategy, 6).get("fail-fast") == "false",
    "Action acceptance matrix must not hide sibling evidence",
)
action_entries = re.findall(
    r"(?ms)^          - scenario: ([^\n]+)\n(.*?)(?=^          - scenario:|\Z)",
    action_strategy,
)
require(
    [scenario for scenario, _ in action_entries]
    == ["standard-opt-out", "wildcard-docker", "github-artifacts"],
    "Action acceptance matrix must contain its three unique native-input scenarios",
)
expected_action_entries = {
    "standard-opt-out": {
        "mode": "block",
        "invocation_id": "action-standard-opt-out",
        "container_policy": "disable",
        "disable_broad_github_domains": "'true'",
        "allow_github_artifacts": "'false'",
        "allowlist": "''",
    },
    "wildcard-docker": {
        "mode": "block",
        "invocation_id": "action-wildcard-docker",
        "container_policy": "unsafe_preserve",
        "disable_broad_github_domains": "'false'",
        "allow_github_artifacts": "'false'",
        "allowlist": "|",
    },
    "github-artifacts": {
        "mode": "block",
        "invocation_id": "action-github-artifacts",
        "container_policy": "disable",
        "disable_broad_github_domains": "'false'",
        "allow_github_artifacts": "'true'",
        "allowlist": "''",
    },
}
for scenario, entry in action_entries:
    require(
        scalar_mapping(entry, 12) == expected_action_entries[scenario],
        f"Action acceptance {scenario} native-input contract changed",
    )
require(
    re.findall(r"(?m)^              ([^\n]+)$", action_entries[1][1])
    == ["*.docker.io"],
    "Action acceptance wildcard-Docker allowlist must remain exact",
)

action_job_blocks = {
    job_name: indented_block(
        jobs,
        f"  {job_name}:",
        f"Action acceptance {job_name} job must be unique",
    )
    for job_name in target_jobs
}
expected_action_steps = {
    "action": [
        "checkout",
        "install assembled Action bundle",
        "observe hosted runner fingerprint candidate",
        "classify bundled Action host compatibility",
        "require bundled Action activation",
        "activate bundled Fence agent",
        "create bounded GitHub artifact fixture",
        "upload bounded GitHub artifact under Fence",
        "verify Action lifecycle",
    ],
    "zero-input": [
        "checkout",
        "install assembled Action bundle",
        "observe hosted runner fingerprint candidate",
        "classify bundled Action host compatibility",
        "require bundled Action activation",
        "activate bundled Fence agent with strict defaults",
        "verify zero-input Action lifecycle",
    ],
    "nested-layout": [
        "checkout into nested Action path",
        "install assembled Action bundle",
        "observe hosted runner fingerprint candidate",
        "classify bundled Action host compatibility",
        "require bundled Action activation",
        "activate bundled Fence agent from nested path",
        "verify nested Action lifecycle",
    ],
    "setup-failure": [
        "checkout",
        "install assembled Action bundle",
        "observe hosted runner fingerprint candidate",
        "reject invalid setup before mutation",
    ],
    "tamper": [
        "checkout",
        "install assembled Action bundle",
        "observe hosted runner fingerprint candidate",
        "classify bundled Action host compatibility",
        "require bundled Action activation",
        "deny registered-path replacement and fail the post hook on drift",
    ],
    "action-finalization": [
        "checkout",
        "install assembled Action bundle",
        "observe hosted runner fingerprint candidate",
        "classify bundled Action host compatibility",
        "require bundled Action activation",
        "activate bundled Fence agent without post-ready warming",
    ],
}
for job_name, job in action_job_blocks.items():
    require(
        re.findall(r"(?m)^      - name: ([^\n]+)$", job)
        == expected_action_steps[job_name],
        f"Action acceptance {job_name} steps must remain complete and ordered",
    )
    checkout_name = "checkout into nested Action path" if job_name == "nested-layout" else "checkout"
    checkout = require_step_contract(
        job,
        checkout_name,
        ["uses", "with"],
        {"uses": checkout_action},
        f"Action acceptance {job_name} checkout",
    )
    checkout_with = indented_block(
        checkout,
        "        with:",
        f"Action acceptance {job_name} checkout inputs must be unique",
    )
    expected_checkout_inputs = {
        "ref": "${{ needs.prepare-candidate.outputs.action_ref }}",
        "persist-credentials": "false",
    }
    if job_name == "nested-layout":
        expected_checkout_inputs["path"] = "target/action-layout/owner/project/revision"
    require(
        scalar_mapping(checkout_with, 10) == expected_checkout_inputs,
        f"Action acceptance {job_name} must check out the exact candidate without persisted credentials",
    )
    install = require_step_contract(
        job,
        "install assembled Action bundle",
        ["if", "uses", "with"],
        {
            "if": "needs.prepare-candidate.outputs.source_candidate == 'true'",
            "uses": "actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c",
        },
        f"Action acceptance {job_name} candidate bundle installation",
    )
    install_with = indented_block(
        install,
        "        with:",
        f"Action acceptance {job_name} candidate bundle inputs must be unique",
    )
    install_path = (
        "target/action-layout/owner/project/revision/action"
        if job_name == "nested-layout"
        else "action"
    )
    require(
        scalar_mapping(install_with, 10)
        == {
            "name": "${{ needs.prepare-candidate.outputs.artifact_name }}",
            "path": install_path,
        },
        f"Action acceptance {job_name} must install only the reviewed candidate bundle",
    )
    observe_keys = ["run"]
    observe_scalars = {"run": "script/observe-hosted-runner"}
    if job_name == "nested-layout":
        observe_keys = ["working-directory", "run"]
        observe_scalars["working-directory"] = "target/action-layout/owner/project/revision"
    require_step_contract(
        job,
        "observe hosted runner fingerprint candidate",
        observe_keys,
        observe_scalars,
        f"Action acceptance {job_name} host observation",
    )

for job_name in ["action", "zero-input", "nested-layout", "tamper", "action-finalization"]:
    job = action_job_blocks[job_name]
    classifier_keys = ["id", "run"]
    classifier_scalars = {
        "id": "bundle-host",
        "run": "script/classify-action-bundle-host",
    }
    guard_keys = ["env", "run"]
    guard_scalars = {"run": "|"}
    if job_name == "nested-layout":
        classifier_keys = ["id", "working-directory", "run"]
        classifier_scalars["working-directory"] = "target/action-layout/owner/project/revision"
        guard_keys = ["working-directory", "env", "run"]
        guard_scalars["working-directory"] = "target/action-layout/owner/project/revision"
    require_step_contract(
        job,
        "classify bundled Action host compatibility",
        classifier_keys,
        classifier_scalars,
        f"Action acceptance {job_name} host classifier",
    )
    guard = require_step_contract(
        job,
        "require bundled Action activation",
        guard_keys,
        guard_scalars,
        f"Action acceptance {job_name} activation guard",
    )
    guard_env = indented_block(
        guard,
        "        env:",
        f"Action acceptance {job_name} activation guard environment must be unique",
    )
    require(
        scalar_mapping(guard_env, 10)
        == {
            "RUN_BUNDLE": "${{ steps.bundle-host.outputs.run_bundle }}",
            "CLASSIFICATION": "${{ steps.bundle-host.outputs.classification }}",
        }
        and literal_run_body(
            guard,
            f"Action acceptance {job_name} activation guard must use a literal run body",
        )
        == (
            '          if [[ "$RUN_BUNDLE" != "true" || "$CLASSIFICATION" != "bundle_compatible" ]]; then\n'
            '            echo "::error::bundled Action host classification did not authorize activation"\n'
            "            exit 1\n"
            "          fi\n"
        ),
        f"Action acceptance {job_name} activation guard must fail closed",
    )

