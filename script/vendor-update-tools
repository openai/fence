#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"
source "$DIR/script/lib/update-tools.bash"

# This is the intentional online update-tool lock refresh path.
unset CARGO_NET_OFFLINE

require_cmd curl
require_cmd tar

lockfile="$UPDATE_TOOLS_LOCK"
mkdir -p "$TOOLING_DIR"
tmpdir="$(make_temp_dir fence-update-tools)"
entries_file="$tmpdir/update-tools.entries"

cleanup() {
  remove_generated_path "$tmpdir" "temporary update-tool vendor directory"
}
trap cleanup EXIT

: > "$entries_file"

add_tool() {
  local name="$1"
  local binary="$2"
  local version
  local version_file="$TOOLING_DIR/${name}-version"
  version="$(read_version_file "$version_file")"
  if [[ -z "$version" ]]; then
    die "${version_file#$DIR/} is required"
  fi

  local url
  url="$(update_tool_expected_url "$name" "$version")"
  local crate_file="$tmpdir/${name}-${version}.crate"
  local extract_dir="$tmpdir/${name}-extract"
  local source_dir

  echo "fetching $url"
  fetch "$url" "$crate_file"
  local crate_sha256
  crate_sha256="$(sha256_file "$crate_file")"

  source_dir="$(update_tool_extract_crate "$name" "$version" "$crate_file" "$extract_dir")"

  local crate_lockfile_sha256
  crate_lockfile_sha256="$(sha256_file "$source_dir/Cargo.lock")"

  printf '%s|%s|%s|%s|%s|%s\n' \
    "$name" "$binary" "$version" "$url" "$crate_sha256" "$crate_lockfile_sha256" >> "$entries_file"
}

add_tool cargo-audit cargo-audit
add_tool cargo-deny cargo-deny

{
  echo "# Locked online update-path Cargo tools."
  echo "# Generated by script/vendor-update-tools."
  echo
  echo "[update_tools]"
  echo "lock_version = 1"
  echo
  first_tool=true
  while IFS='|' read -r name binary version url crate_sha256 crate_lockfile_sha256; do
    if [[ "$first_tool" == "true" ]]; then
      first_tool=false
    else
      echo
    fi
    echo "[[tools]]"
    echo "name = \"$name\""
    echo "binary = \"$binary\""
    echo "version = \"$version\""
    echo "url = \"$url\""
    echo "crate_sha256 = \"$crate_sha256\""
    echo "crate_lockfile_sha256 = \"$crate_lockfile_sha256\""
  done < "$entries_file"
} > "$lockfile"

script/validate-update-tools --ci
echo -e "${GREEN}update-tool locks refreshed:${OFF} ${UPDATE_TOOLS_LOCK#$DIR/}"
