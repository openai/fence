#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 1 ]]; then
  die "usage: script/update-action-bundle <vX.Y.Z[-prerelease]>"
fi

tag="$1"
repository="GrantBirki/fence"
signer_workflow="$repository/.github/workflows/release.yml"
source_ref="refs/heads/main"
artifact="fence_${tag}_linux-amd64"
manifest="$DIR/action/bundle-manifest.json"
binary="$DIR/action/bin/fence"

if ! [[ "$tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$ ]]; then
  die "Action bundle release must be an immutable semver tag such as v0.1.0-alpha.3 or v0.1.0"
fi
release_channel="stable"
if [[ "$tag" == *-* ]]; then
  release_channel="prerelease"
fi

require_cmd gh
require_cmd python3

tmpdir="$(make_temp_dir fence-action-bundle)"
cleanup() {
  remove_generated_path "$tmpdir" "temporary Action bundle directory"
}
trap cleanup EXIT

mkdir -p "$tmpdir/download" "$DIR/action/bin"
gh release view "$tag" --repo "$repository" --json tagName,url,targetCommitish,isPrerelease,isDraft,isImmutable > "$tmpdir/release.json"

source_commit="$(python3 - "$tmpdir/release.json" "$tag" "$release_channel" "$repository" <<'PY'
import json
import pathlib
import re
import sys

release = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
tag, release_channel, repository = sys.argv[2:]
if release["tagName"] != tag:
    raise SystemExit("Action bundle release tag does not match the requested tag")
if release["url"] != f"https://github.com/{repository}/releases/tag/{tag}":
    raise SystemExit("Action bundle release URL does not match the requested tag")
if release["isDraft"] is not False:
    raise SystemExit("Action bundle release must not be a draft")
if release["isImmutable"] is not True:
    raise SystemExit("Action bundle release must be immutable")
if release["isPrerelease"] is not (release_channel == "prerelease"):
    raise SystemExit("Action bundle release channel does not match the GitHub Release")
source_commit = release["targetCommitish"]
if not re.fullmatch(r"[0-9a-f]{40}", source_commit):
    raise SystemExit("Action bundle release target must be a full source commit SHA")
print(source_commit)
PY
)"

tag_commit="$(gh api "repos/${repository}/commits/${tag}" --jq '.sha')"
if ! [[ "$tag_commit" =~ ^[0-9a-f]{40}$ ]]; then
  die "Action bundle release tag must resolve to a full commit SHA"
fi
if [[ "$tag_commit" != "$source_commit" ]]; then
  die "Action bundle release tag does not resolve to the release source commit"
fi

gh release download "$tag" --repo "$repository" --pattern checksums.txt --pattern "$artifact" --dir "$tmpdir/download"

expected_sha256="$(awk -v artifact="$artifact" '$2 == artifact || $2 == "./" artifact { print $1 }' "$tmpdir/download/checksums.txt")"
if ! [[ "$expected_sha256" =~ ^[0-9a-f]{64}$ ]]; then
  die "release checksums.txt does not contain exactly one valid checksum for $artifact"
fi
actual_sha256="$(sha256_file "$tmpdir/download/$artifact")"
if [[ "$actual_sha256" != "$expected_sha256" ]]; then
  die "downloaded Action bundle checksum mismatch"
fi

gh attestation verify \
  "$tmpdir/download/$artifact" \
  --repo "$repository" \
  --signer-workflow "$signer_workflow" \
  --signer-digest "$source_commit" \
  --source-digest "$source_commit" \
  --source-ref "$source_ref" \
  --deny-self-hosted-runners >/dev/null

/usr/bin/install -m 0755 "$tmpdir/download/$artifact" "$binary"
python3 - "$tmpdir/release.json" "$manifest" "$repository" "$signer_workflow" "$artifact" "$actual_sha256" "$release_channel" "$tag_commit" "$source_ref" <<'PY'
import json
import pathlib
import re
import sys

release_path, manifest_path, repository, signer_workflow, artifact, sha256, release_channel, tag_commit, source_ref = sys.argv[1:]
release = json.loads(pathlib.Path(release_path).read_text(encoding="utf-8"))
if release["tagName"] not in artifact:
    raise SystemExit("release tag does not match downloaded Action artifact")
if release_channel not in {"prerelease", "stable"}:
    raise SystemExit("Action bundle release channel is invalid")
if release["isPrerelease"] is not (release_channel == "prerelease"):
    raise SystemExit("Action bundle release channel does not match the GitHub Release")
if release["isDraft"] is not False:
    raise SystemExit("Action bundle release must not be a draft")
if release["isImmutable"] is not True:
    raise SystemExit("Action bundle release must be immutable")
if not re.fullmatch(r"[0-9a-f]{40}", release["targetCommitish"]):
    raise SystemExit("Action bundle release target must be a full source commit SHA")
if tag_commit != release["targetCommitish"]:
    raise SystemExit("Action bundle release tag does not resolve to the release source commit")
manifest = {
    "schema_version": 3,
    "repository": repository,
    "release_tag": release["tagName"],
    "release_channel": release_channel,
    "release_url": release["url"],
    "release_is_draft": release["isDraft"],
    "release_is_immutable": release["isImmutable"],
    "release_tag_commit": tag_commit,
    "source_commit": release["targetCommitish"],
    "source_ref": source_ref,
    "artifact_name": artifact,
    "artifact_sha256": sha256,
    "bundle_path": "action/bin/fence",
    "signer_workflow": signer_workflow,
    "signer_digest": release["targetCommitish"],
    "attestation_verified": True,
}
pathlib.Path(manifest_path).write_text(
    json.dumps(manifest, indent=2, sort_keys=True) + "\n",
    encoding="utf-8",
)
PY

script/validate-action-bundle
echo -e "${GREEN}Action bundle updated:${OFF} $artifact"
