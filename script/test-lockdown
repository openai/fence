#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 1 ]]; then
  die "usage: script/test-lockdown <acl-reject|audit|local-control-reject|rollback|unsafe-preserve|standard>"
fi

scenario="$1"
case "$scenario" in
  acl-reject|audit|local-control-reject|rollback|unsafe-preserve|standard) ;;
  *) die "unknown lockdown evidence scenario: $scenario" ;;
esac

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "lockdown evidence scenarios run only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "lockdown evidence scenarios require Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/systemctl /usr/bin/systemd-run /usr/sbin/visudo; do
  if [[ ! -x "$required" ]]; then
    die "lockdown evidence requires executable $required"
  fi
done

target_root="$RUNNER_TEMP/fence-lockdown-target-$scenario"
mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo test --frozen --test lockdown --no-run

shopt -s nullglob
test_binaries=()
for candidate in "$target_root"/debug/deps/lockdown-*; do
  if [[ -f "$candidate" && -x "$candidate" ]]; then
    test_binaries+=("$candidate")
  fi
done
if [[ "${#test_binaries[@]}" -ne 1 ]]; then
  die "expected exactly one compiled lockdown evidence test binary"
fi

suffix="${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}"
invocation="lockdown-${scenario}-${suffix}"
unit="fence-evidence-${invocation}.service"
runtime_root="/run/fence-lockdown-evidence-${scenario}-${suffix}"
report="$runtime_root/$invocation/report.json"

test_environment=()
acl_fixture=""
if [[ "$scenario" == "acl-reject" ]]; then
  for required in /usr/bin/install /usr/bin/rmdir /usr/bin/setfacl; do
    if [[ ! -x "$required" ]]; then
      die "ACL rejection evidence requires executable $required"
    fi
  done
  acl_fixture="/run/fence-lockdown-acl-fixture-$suffix"
  sudo /usr/bin/install --directory --owner=root --group=root --mode=0750 "$acl_fixture"
  sudo /usr/bin/setfacl --modify user:runner:--x "$acl_fixture"
  if [[ "$(sudo /usr/bin/stat --format=%a:%U:%G "$acl_fixture")" != "750:root:root" ]]; then
    die "ACL rejection fixture metadata changed unexpectedly"
  fi
  test_environment+=("--setenv=FENCE_LOCKDOWN_ACL_FIXTURE=$acl_fixture")
fi

# This service mutates only a disposable hosted runner. Standard and degraded
# evidence deliberately leave successful lockdown state in place until VM
# teardown; no restore command is issued after verified evidence.
sudo /usr/bin/systemd-run \
  --quiet \
  --wait \
  --pipe \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  --setenv=FENCE_LOCKDOWN_WORKER=1 \
  "--setenv=FENCE_LOCKDOWN_UNIT=$unit" \
  "--setenv=FENCE_LOCKDOWN_ROOT=$runtime_root" \
  "--setenv=FENCE_LOCKDOWN_INVOCATION=$invocation" \
  "--setenv=FENCE_LOCKDOWN_SCENARIO=$scenario" \
  "${test_environment[@]}" \
  "${test_binaries[0]}" --ignored --exact lockdown_service_worker --nocapture

python3 -E - "$scenario" "$report" "$runtime_root/$invocation/ready.json" "/run/fence/$invocation/ready.json" <<'PY'
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message="evidence validation failed"):
    if not condition:
        raise SystemExit(message)

import json
import pathlib
import sys

scenario, report_path, test_ready_path, production_ready_path = sys.argv[1:]
if scenario in {"acl-reject", "local-control-reject"}:
    require(not pathlib.Path(report_path).exists())
    require(not pathlib.Path(test_ready_path).exists())
    require(not pathlib.Path(production_ready_path).exists())
    raise SystemExit(0)
report = json.loads(pathlib.Path(report_path).read_text(encoding="utf-8"))
require(report["status"] == "lockdown_evidence_test_only")
require(report["protection_available"] is False)
require(report["readiness_status"] == "not_emitted")
require(not pathlib.Path(test_ready_path).exists())
require(not pathlib.Path(production_ready_path).exists())
if scenario == "audit":
    require(report["assurance_status"] == "audit_observation_only")
    require(report["sudo_status"] == "preserved")
    require(report["container_status"] == "preserved")
elif scenario == "unsafe-preserve":
    require(report["assurance_status"] == "degraded_container_control_preserved")
    require(report["sudo_status"] == "disabled_verified")
    require(report["container_status"] == "preserved_unsafe")
elif scenario == "standard":
    require(report["assurance_status"] == "lockdown_controls_verified_test_only")
    require(report["sudo_status"] == "disabled_verified")
    require(report["container_status"] == "disabled_verified")
elif scenario == "rollback":
    require(report["setup_status"] == "failed_pre_ready")
    require(report["rollback_status"] == "rolled_back_pre_ready")
    require("rollback_error_code" not in report)
PY

if [[ -n "$acl_fixture" ]]; then
  sudo /usr/bin/rmdir "$acl_fixture"
fi

case "$scenario" in
  acl-reject|audit|local-control-reject|rollback)
    sudo --non-interactive /usr/bin/true
    docker ps --quiet >/dev/null
    ;;
  unsafe-preserve)
    if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
      die "unsafe-preserve evidence did not disable runner passwordless sudo"
    fi
    docker ps --quiet >/dev/null
    ;;
  standard)
    if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
      die "standard lockdown evidence did not disable runner passwordless sudo"
    fi
    if docker ps --quiet >/dev/null 2>&1; then
      die "standard lockdown evidence did not disable runner Docker access"
    fi
    ;;
esac

echo -e "${GREEN}hosted lockdown test evidence verified: $scenario${OFF}"
