#!/usr/bin/env bash

set -euo pipefail

source script/env "$@"
source "$DIR/script/lib/test-tools.bash"

ensure_rust_toolchain

# This is the intentional online test-tool refresh path.
unset CARGO_NET_OFFLINE

require_cmd curl
require_cmd tar

test_tools_dir="$DIR/vendor/test-tools"
cargo_llvm_cov_dir="$test_tools_dir/cargo-llvm-cov"
manifest="$test_tools_dir/manifest.toml"
lockfile="$TEST_TOOLS_LOCK"

if [[ ! -f "$lockfile" ]]; then
  die "missing test-tool lockfile: $lockfile"
fi

cargo_llvm_cov_version="$(read_version_file "$CARGO_LLVM_COV_VERSION_FILE")"
locked_cargo_llvm_cov_version="$(toml_value "$lockfile" "cargo_llvm_cov_version")"

if [[ -z "$cargo_llvm_cov_version" ]]; then
  die "${CARGO_LLVM_COV_VERSION_FILE#$DIR/} is required"
fi

if [[ "$locked_cargo_llvm_cov_version" != "$cargo_llvm_cov_version" ]]; then
  die "${TEST_TOOLS_LOCK#$DIR/} cargo-llvm-cov version mismatch (expected ${cargo_llvm_cov_version}, found ${locked_cargo_llvm_cov_version:-missing})"
fi

tmpdir="$(make_temp_dir fence-test-tools)"
cleanup() {
  remove_generated_path "$tmpdir" "temporary test-tool vendor directory"
}
trap cleanup EXIT

remove_generated_path "$test_tools_dir" "test-tool vendor directory"
mkdir -p "$TOOLING_DIR" "$cargo_llvm_cov_dir"

tool_entries="$tmpdir/cargo-llvm-cov-entries.toml"
: > "$tool_entries"

artifact_count=0
while IFS='|' read -r platform arch os target version url path expected_sha256; do
  if [[ -z "$platform" || -z "$arch" || -z "$os" || -z "$target" || -z "$version" || -z "$url" || -z "$path" || -z "$expected_sha256" ]]; then
    die "invalid cargo-llvm-cov entry in ${TEST_TOOLS_LOCK#$DIR/}"
  fi

  if [[ "$version" != "$cargo_llvm_cov_version" ]]; then
    die "cargo-llvm-cov lock entry version mismatch for ${platform}"
  fi

  if [[ "$path" != "vendor/test-tools/cargo-llvm-cov/cargo-llvm-cov-${target}.tar.gz" ]]; then
    die "cargo-llvm-cov lock entry has unexpected path for ${platform}: $path"
  fi
  reject_unsafe_relative_path "$path" "cargo-llvm-cov lock entry path for ${platform}"

  filename="${path##*/}"
  tmp_artifact="$tmpdir/$filename"

  echo "fetching $url"
  fetch "$url" "$tmp_artifact"

  actual_sha256="$(sha256_file "$tmp_artifact")"
  if [[ "$actual_sha256" != "$expected_sha256" ]]; then
    die "cargo-llvm-cov checksum mismatch for $filename (expected $expected_sha256, found $actual_sha256)"
  fi

  validate_tar_entries "$tmp_artifact" z
  if ! archive_contains "$tmp_artifact" z "cargo-llvm-cov"; then
    die "cargo-llvm-cov artifact missing executable: $filename"
  fi

  mv "$tmp_artifact" "$DIR/$path"

  {
    echo "[[cargo_llvm_cov]]"
    echo "platform = \"$platform\""
    echo "arch = \"$arch\""
    echo "os = \"$os\""
    echo "target = \"$target\""
    echo "version = \"$version\""
    echo "url = \"$url\""
    echo "path = \"$path\""
    echo "sha256 = \"$actual_sha256\""
    echo
  } >> "$tool_entries"

  artifact_count=$((artifact_count + 1))
done < <(test_tools_cargo_llvm_cov_entries "$lockfile")

if [[ "$artifact_count" -ne 4 ]]; then
  die "expected 4 cargo-llvm-cov entries in ${TEST_TOOLS_LOCK#$DIR/}, found $artifact_count"
fi

{
  echo "# Generated by script/vendor-test-tools."
  echo "# This manifest is validated by script/validate-test-tools."
  echo
  echo "[test_tools]"
  echo "manifest_version = 1"
  echo "cargo_llvm_cov_version = \"$cargo_llvm_cov_version\""
  echo
  cat "$tool_entries"
} > "$manifest"

script/validate-test-tools
echo -e "${GREEN}test tools vendored:${OFF} $test_tools_dir"
