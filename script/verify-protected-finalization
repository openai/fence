#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -gt 1 ]]; then
  die "usage: script/verify-protected-finalization [integration|action]"
fi
job_set="${1:-integration}"
case "$job_set" in
  integration|action) ;;
  *) die "finalization job set must be integration or action" ;;
esac
if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "protected finalization verification runs only in GitHub Actions"
fi
if [[ -z "${GITHUB_TOKEN:-}" || -z "${GITHUB_REPOSITORY:-}" || -z "${GITHUB_RUN_ID:-}" ]]; then
  die "protected finalization verification requires bounded GitHub run identity"
fi

require_cmd python3

FENCE_FINALIZATION_JOB_SET="$job_set" python3 -B -E - "$DIR" <<'PY'
import io
import json
import os
import sys
import time
import urllib.error
import urllib.request
import urllib.parse
import zipfile

sys.path.insert(0, os.path.join(sys.argv[1], "script", "lib"))

from protected_finalization import (
    ACTION_ZERO_INPUT_BURST_JOB,
    validate_action_zero_input_burst_job,
    validate_action_zero_input_burst_report,
    validate_finalization_jobs,
)

repository = os.environ["GITHUB_REPOSITORY"]
run_id = os.environ["GITHUB_RUN_ID"]
token = os.environ["GITHUB_TOKEN"]
job_set = os.environ["FENCE_FINALIZATION_JOB_SET"]
api_root = f"https://api.github.com/repos/{repository}"
authorization_marker = b"fence-results-storage-authorization-observed"
authorization_observed = False
structured_report_prefix = b"FENCE_REPORT_JSON="
max_structured_report_bytes = 16 * 1024
structured_report_fields = {
    "schema_version",
    "mode",
    "result",
    "controls",
    "network",
    "warnings",
    "omissions",
    "suggested_allowlist",
}


def request(path):
    return urllib.request.Request(
        f"{api_root}{path}",
        headers={
            "Accept": "application/vnd.github+json",
            "Authorization": f"Bearer {token}",
            "User-Agent": "fence-finalization-verifier",
            "X-GitHub-Api-Version": "2022-11-28",
        },
    )


class NoRedirect(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


def log_archive(job_id):
    opener = urllib.request.build_opener(NoRedirect)
    try:
        opener.open(request(f"/actions/jobs/{job_id}/logs"), timeout=15)
    except urllib.error.HTTPError as error:
        if error.code == 404:
            return None
        if error.code not in {301, 302, 303, 307, 308}:
            raise
        location = error.headers.get("Location", "")
    else:
        raise RuntimeError("job log endpoint did not return an immutable archive redirect")
    parsed = urllib.parse.urlparse(location)
    hostname = parsed.hostname or ""
    accepted_suffixes = (
        ".actions.githubusercontent.com",
        ".blob.core.windows.net",
        ".githubusercontent.com",
    )
    if parsed.scheme != "https" or not hostname.endswith(accepted_suffixes):
        raise RuntimeError("job log endpoint returned an unexpected archive location")
    unsigned = urllib.request.Request(
        location,
        headers={"User-Agent": "fence-finalization-verifier"},
    )
    unsigned_opener = urllib.request.build_opener(NoRedirect)
    try:
        with unsigned_opener.open(unsigned, timeout=20) as response:
            return response.read(8 * 1024 * 1024 + 1)
    except urllib.error.HTTPError as error:
        if error.code == 404:
            return None
        raise RuntimeError("job log archive download failed") from None
    except urllib.error.URLError:
        raise RuntimeError("job log archive download failed") from None


def unique_json_object(pairs):
    value = {}
    for key, item in pairs:
        if key in value:
            raise ValueError("structured report contained duplicate JSON fields")
        value[key] = item
    return value


def action_structured_reports(payload, job_name):
    reports = []
    for raw_line in io.BytesIO(payload):
        line = raw_line.rstrip(b"\r\n")
        marker_offset = line.find(structured_report_prefix)
        if marker_offset == -1:
            continue
        record = line[marker_offset:]
        if record.count(structured_report_prefix) != 1:
            raise SystemExit(
                f"protected finalization structured report marker was invalid: {job_name}"
            )
        if len(record) > max_structured_report_bytes:
            raise SystemExit(
                f"protected finalization structured report exceeded 16 KiB: {job_name}"
            )
        try:
            report = json.loads(
                record[len(structured_report_prefix):].decode("utf-8"),
                object_pairs_hook=unique_json_object,
            )
        except (UnicodeError, ValueError, json.JSONDecodeError):
            raise SystemExit(
                f"protected finalization structured report was invalid JSON: {job_name}"
            ) from None
        if not isinstance(report, dict) or set(report) != structured_report_fields:
            raise SystemExit(
                f"protected finalization structured report schema was invalid: {job_name}"
            )
        if type(report["schema_version"]) is not int or report["schema_version"] != 1:
            raise SystemExit(
                f"protected finalization structured report version was invalid: {job_name}"
            )
        expected_result = (
            "warning" if job_name == ACTION_ZERO_INPUT_BURST_JOB else "healthy"
        )
        if report["mode"] != "block" or report["result"] != expected_result:
            raise SystemExit(
                f"protected finalization structured report was not expected block evidence: "
                f"{job_name}"
            )
        controls = report["controls"]
        if (
            not isinstance(controls, dict)
            or controls.get("network") != "verified"
            or controls.get("sudo") != "disabled_verified"
            or controls.get("containers") != "disabled_verified"
            or controls.get("protection_available") is not True
            or controls.get("readiness") != "ready"
            or controls.get("resident_health") != "healthy"
        ):
            raise SystemExit(
                f"protected finalization structured report controls were invalid: {job_name}"
            )
        network = report["network"]
        if (
            not isinstance(network, list)
            or len(network) > 20
            or any(not isinstance(row, dict) for row in network)
        ):
            raise SystemExit(
                f"protected finalization structured network evidence was invalid: {job_name}"
            )
        if not isinstance(report["warnings"], dict) or not isinstance(report["omissions"], dict):
            raise SystemExit(
                f"protected finalization structured report metadata was invalid: {job_name}"
            )
        suggestions = report["suggested_allowlist"]
        if not isinstance(suggestions, list) or len(suggestions) > 20:
            raise SystemExit(
                f"protected finalization structured allowlist suggestions were invalid: "
                f"{job_name}"
            )
        reports.append(report)
        if len(reports) > 1:
            raise SystemExit(
                f"protected finalization structured report was duplicated: {job_name}"
            )
    return reports


with urllib.request.urlopen(request(f"/actions/runs/{run_id}/jobs?per_page=100"), timeout=15) as response:
    body = response.read(1024 * 1024 + 1)
if len(body) > 1024 * 1024:
    raise SystemExit("protected finalization job metadata exceeded its fixed bound")
document = json.loads(body)

try:
    jobs = validate_finalization_jobs(document, job_set)
    if job_set == "action":
        jobs[ACTION_ZERO_INPUT_BURST_JOB] = validate_action_zero_input_burst_job(document)
except ValueError as error:
    raise SystemExit(str(error)) from None

for name in sorted(jobs):
    job = jobs[name]
    archive = None
    for attempt in range(6):
        archive = log_archive(job["id"])
        if archive is not None:
            break
        if attempt == 5:
            raise SystemExit(f"protected finalization log archive was unavailable: {name}")
        time.sleep(5)
    if not archive or len(archive) > 8 * 1024 * 1024:
        raise SystemExit(f"protected finalization job log was empty or oversized: {name}")
    reports = []
    if zipfile.is_zipfile(io.BytesIO(archive)):
        with zipfile.ZipFile(io.BytesIO(archive)) as bundle:
            files = [
                entry for entry in bundle.infolist()
                if not entry.is_dir() and entry.file_size > 0
            ]
            if not files:
                raise SystemExit(f"protected finalization log archive had no nonempty files: {name}")
            if sum(entry.file_size for entry in files) > 16 * 1024 * 1024:
                raise SystemExit(f"protected finalization log archive expanded past its fixed bound: {name}")
            if job_set == "action":
                marker_observed = False
                for entry in files:
                    reports.extend(action_structured_reports(bundle.read(entry), name))
                    if len(reports) > 1:
                        raise SystemExit(
                            f"protected finalization structured report was duplicated: {name}"
                        )
            else:
                marker_observed = any(authorization_marker in bundle.read(entry) for entry in files)
    else:
        marker_observed = authorization_marker in archive
        if job_set == "action":
            reports = action_structured_reports(archive, name)
    if job_set == "action" and len(reports) != 1:
        raise SystemExit(
            f"protected finalization job must contain exactly one structured report: {name}"
        )
    if job_set == "action" and name == ACTION_ZERO_INPUT_BURST_JOB:
        try:
            validate_action_zero_input_burst_report(reports[0])
        except ValueError as error:
            raise SystemExit(str(error)) from None
    if job_set == "integration" and name.startswith("protected finalization "):
        authorization_observed = authorization_observed or marker_observed

print(f"{job_set} finalization and downloadable job logs verified")
if job_set == "action":
    print("bounded blocked-burst and final post-job evidence verified")
if authorization_observed:
    print("runner-authorized results storage was observed after Fence readiness")
PY
