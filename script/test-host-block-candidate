#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 0 ]]; then
  die "usage: script/test-host-block-candidate"
fi

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "host block candidate evidence runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "host block candidate evidence requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/systemctl /usr/bin/systemd-run /usr/sbin/nft; do
  if [[ ! -x "$required" ]]; then
    die "host block candidate evidence requires executable $required"
  fi
done

suffix="${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}"
invocation="host-documented-log-${suffix}"
unit="fence-evidence-${invocation}.service"
runtime_root="/run/fence-host-candidate-${suffix}"
report="$runtime_root/$invocation/report.json"
ready="$runtime_root/$invocation/ready.json"
production_ready="/run/fence/$invocation/ready.json"
target_root="$RUNNER_TEMP/fence-host-candidate-target"

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo test --frozen --test host_candidate --no-run

shopt -s nullglob
test_binaries=()
for candidate in "$target_root"/debug/deps/host_candidate-*; do
  if [[ -f "$candidate" && -x "$candidate" ]]; then
    test_binaries+=("$candidate")
  fi
done
if [[ "${#test_binaries[@]}" -ne 1 ]]; then
  die "expected exactly one compiled host block candidate test binary"
fi

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "host block candidate requires absent host inet fence_v0 table"
fi
if [[ -e "$production_ready" ]]; then
  die "host block candidate requires absent production readiness path"
fi

# This deliberately applies block policy on the disposable runner host with
# one explicit test allowance for GitHub's documented log/summary receiver.
# A successful job completion is evidence only for this candidate, not a
# selected built-in profile or public activation.
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  --setenv=FENCE_HOST_BLOCK_CANDIDATE_WORKER=1 \
  "--setenv=FENCE_HOST_BLOCK_CANDIDATE_UNIT=$unit" \
  "--setenv=FENCE_HOST_BLOCK_CANDIDATE_ROOT=$runtime_root" \
  "--setenv=FENCE_HOST_BLOCK_CANDIDATE_INVOCATION=$invocation" \
  "${test_binaries[0]}" --ignored --exact documented_results_receiver_host_block_candidate_worker --nocapture

python3 - "$report" "$ready" "$production_ready" <<'PY'
import json
import pathlib
import sys
import time

report_path, ready_path, production_ready_path = (pathlib.Path(item) for item in sys.argv[1:])
deadline = time.monotonic() + 20
ready = None
report = None
while time.monotonic() < deadline:
    if ready_path.exists() and report_path.exists():
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        report = json.loads(report_path.read_text(encoding="utf-8"))
        if (
            report.get("setup_status") == "resident_host_block_candidate_test_only"
            and report.get("readiness_status") == "host_block_candidate_ready_no_public_activation"
        ):
            break
    time.sleep(0.1)
assert ready is not None, "host block candidate readiness was not emitted"
assert report is not None, "host block candidate report was not emitted"
assert ready["status"] == "host_block_candidate_ready_no_public_activation"
assert ready["protection_available"] is False
assert report["status"] == "host_block_candidate_test_only"
assert report["mode"] == "block"
assert report["setup_status"] == "resident_host_block_candidate_test_only"
assert report["network_application_status"] == "applied"
assert report["network_verification_status"] == "verified"
assert report["sudo_status"] == "disabled_verified"
assert report["container_status"] == "disabled_verified"
assert report["readiness_status"] == "host_block_candidate_ready_no_public_activation"
assert report["protection_available"] is False
assert "documented_results_receiver_encoded_as_test_allowance_not_selected_profile" in report["limitations"]
assert not production_ready_path.exists()
PY

if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
  die "host block candidate did not disable runner passwordless sudo"
fi
if docker ps --quiet >/dev/null 2>&1; then
  die "host block candidate did not disable runner Docker access"
fi

sleep 6
python3 - "$report" <<'PY'
import json
import pathlib
import sys

report = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
assert report["critical_findings"] == [], report
PY

echo -e "${GREEN}documented-log host block candidate evidence verified${OFF}"
