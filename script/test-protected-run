#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 1 ]]; then
  die "usage: script/test-protected-run <standard|standard-finalization|standard-opt-out|unsafe-preserve|audit>"
fi

scenario="$1"
case "$scenario" in
  standard|standard-finalization|standard-opt-out|unsafe-preserve|audit) ;;
  *) die "unknown protected run scenario: $scenario" ;;
esac

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "protected block proof runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "protected block proof requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd curl
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/install /usr/bin/mount /usr/bin/systemctl /usr/bin/systemd-run /usr/bin/umount /usr/sbin/nft; do
  if [[ ! -x "$required" ]]; then
    die "protected block proof requires executable $required"
  fi
done

invocation="protected-${scenario}-${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}"
unit="fence-${invocation}.service"
directory="/run/fence/$invocation"
config="$directory/config.json"
ready="$directory/ready.json"
report="$directory/report.json"
dns_report="$directory/dns-report.json"
config_source="$RUNNER_TEMP/fence-protected-run-config.json"
target_root="$RUNNER_TEMP/fence-protected-run-target-$scenario"

report_failed_https_probe() {
  local hostname="$1"
  sleep 1
  python3 - "$report" "$dns_report" "$hostname" <<'PY'
import json
import pathlib
import sys

report_path = pathlib.Path(sys.argv[1])
dns_path = pathlib.Path(sys.argv[2])
hostname = sys.argv[3]

def read_document(path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return {}

report = read_document(report_path)
dns = read_document(dns_path)
materializations = [
    {
        "address": item.get("address"),
        "hostname": item.get("hostname"),
        "port": item.get("port"),
        "protocol": item.get("protocol"),
        "source_hostname": item.get("source_hostname"),
    }
    for item in report.get("materialized_allowances", [])
    if item.get("source_hostname") == hostname or item.get("hostname") == hostname
][:32]
findings = [
    {
        "classification": item.get("classification"),
        "family": item.get("family"),
        "protocol": item.get("protocol"),
        "remote_address": item.get("remote_address"),
        "remote_port": item.get("remote_port"),
        "rule_class": item.get("rule_class"),
    }
    for item in report.get("findings", [])
    if item.get("protocol") == "tcp" and item.get("remote_port") == 443
][:8]
observations = [
    {
        "hostname": item.get("hostname"),
        "occurrences": item.get("occurrences"),
        "policy_classification": item.get("policy_classification"),
        "query_type": item.get("query_type"),
        "resolved_addresses": item.get("resolved_addresses", [])[:32],
    }
    for item in dns.get("observations", [])
    if item.get("hostname") == hostname
][:4]
diagnostic = {
    "critical_codes": [item.get("code") for item in report.get("critical_findings", [])][:8],
    "dns_observations": observations,
    "hostname": hostname,
    "hostname_refresh_warnings": dns.get("hostname_refresh_warnings"),
    "materialization_request_rejections": dns.get("materialization_request_rejections"),
    "materialized_allowances": materializations,
    "rejected_tcp_443_findings": findings,
    "upstream_request_failures": dns.get("upstream_request_failures"),
}
print("bounded first-connect failure evidence: " + json.dumps(diagnostic, sort_keys=True, separators=(",", ":")))
PY
}

probe_https_once() {
  local url="$1"
  if curl --head --silent --show-error --max-time 10 --retry 0 --output /dev/null "$url"; then
    return 0
  fi
  report_failed_https_probe "${url#https://}"
  return 1
}

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "protected block proof requires absent host inet fence_v0 table"
fi
if [[ -e "$directory" ]]; then
  die "protected block proof requires absent production runtime directory"
fi

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo build --frozen --release --bin fence
binary="$target_root/release/fence"

python3 - "$config_source" "$invocation" "$scenario" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
invocation_id = sys.argv[2]
scenario = sys.argv[3]
document = {
    "schema_version": 1,
    "mode": "audit" if scenario == "audit" else "block",
    "invocation_id": invocation_id,
    "allowlist": [],
}
if scenario in {"standard", "standard-finalization"}:
    document["container_policy"] = "disable"
elif scenario == "standard-opt-out":
    document["container_policy"] = "disable"
    document["disable_broad_github_domains"] = True
elif scenario == "unsafe-preserve":
    document["container_policy"] = "unsafe_preserve"
path.write_text(
    json.dumps(document, sort_keys=True, separators=(",", ":")),
    encoding="utf-8",
)
PY

sudo /usr/bin/install -d -o root -g root -m 0755 /run/fence "$directory"
sudo /usr/bin/install -o root -g root -m 0600 "$config_source" "$config"

# The service intentionally remains resident after this script exits. The
# disposable hosted runner teardown is the only post-ready cleanup path.
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  "$binary" run --config "$config"

python3 - "$scenario" "$report" "$dns_report" "$ready" <<'PY'
import json
import pathlib
import re
import sys
import time

scenario = sys.argv[1]
report_path, dns_path, ready_path = (pathlib.Path(item) for item in sys.argv[2:])
expected_by_scenario = {
    "standard": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "ready": "ready",
        "protection_available": True,
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "standard-opt-out": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "ready": "ready",
        "protection_available": True,
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
        "bootstrap_hostnames": [
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "unsafe-preserve": {
        "mode": "block",
        "status": "protected_host_block_degraded",
        "resident": "resident_degraded",
        "ready": "ready_degraded",
        "protection_available": False,
        "sudo_status": "disabled_verified",
        "container_status": "preserved_unsafe",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "audit": {
        "mode": "audit",
        "status": "protected_host_audit_observation",
        "resident": "resident_observation_only",
        "ready": "ready_observation_only",
        "protection_available": False,
        "sudo_status": "preserved_verified",
        "container_status": "preserved_verified",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
}
expected_by_scenario["standard-finalization"] = expected_by_scenario["standard"]
expected = expected_by_scenario[scenario]
deadline = time.monotonic() + 30
report = None
dns = None
ready = None
while time.monotonic() < deadline:
    if report_path.exists() and dns_path.exists() and ready_path.exists():
        report = json.loads(report_path.read_text(encoding="utf-8"))
        dns = json.loads(dns_path.read_text(encoding="utf-8"))
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        if report.get("setup_status") == expected["resident"]:
            break
    time.sleep(0.1)

assert report is not None, "protected report was not emitted"
assert dns is not None, "protected DNS report was not emitted"
assert ready is not None, "protected readiness was not emitted"
assert report["status"] == expected["status"], report
assert report["runtime_evidence_schema_version"] == 4, report
assert report["mode"] == expected["mode"], report
assert report["setup_status"] == expected["resident"], report
assert report["readiness_status"] == expected["ready"], report
assert report["protection_available"] is expected["protection_available"], report
assert report["platform_profile_id"] == "github_hosted_workflow_bootstrap_v3", report
assert report["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v3", report
assert report["policy_hash_schema_version"] == 6, report
assert re.fullmatch(r"[0-9a-f]{64}", report["policy_hash"]), report
assert re.fullmatch(r"[0-9a-f]{64}", report["base_ruleset_hash"]), report
assert re.fullmatch(r"[0-9a-f]{64}", report["ruleset_hash"]), report
assert report["network_application_status"] == "applied", report
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == expected["sudo_status"], report
assert report["container_status"] == expected["container_status"], report
if scenario != "audit":
    assert len(report["materialized_allowances"]) >= 1, report
    assert report["bootstrap_hostnames"] == expected["bootstrap_hostnames"], report
assert report["critical_findings"] == [], report
resident = report["resident_health"]
assert resident["status"] == "healthy", resident
assert resident["resident_pid"] > 0, resident
assert resident["verification_sequence"] >= 1, resident
assert resident["last_successful_verification_unix_milliseconds"] > 0, resident
assert resident["verification_interval_seconds"] == 5, resident
assert resident["workers"] == [
    {"name": "docker_tcp_dns", "status": "running"},
    {"name": "docker_udp_dns", "status": "running"},
    {"name": "host_tcp_dns", "status": "running"},
    {"name": "host_udp_dns", "status": "running"},
    {"name": "process_attribution", "status": "running"},
], resident
assert ready["status"] == expected["ready"], ready
assert ready["runtime_evidence_schema_version"] == 4, ready
assert ready["mode"] == expected["mode"], ready
assert ready["protection_available"] is expected["protection_available"], ready
assert ready["platform_profile_id"] == "github_hosted_workflow_bootstrap_v3", ready
assert ready["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v3", ready
assert ready["policy_hash"] == report["policy_hash"], (ready, report)
assert ready["base_ruleset_hash"] == report["base_ruleset_hash"], (ready, report)
assert ready["resident_health"]["resident_pid"] == resident["resident_pid"], ready
assert dns["status"] == expected["status"], dns
assert dns["runtime_evidence_schema_version"] == 4, dns
assert dns["mode"] == expected["mode"], dns
assert dns["protection_available"] is expected["protection_available"], dns
assert dns["platform_profile_id"] == "github_hosted_workflow_bootstrap_v3", dns
assert dns["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v3", dns
assert dns["routing_status"] == "active", dns
assert dns["host_dns_routing"] == "direct_client_to_root_resident_mediator", dns
assert dns["docker_dns_routing"] == "local_root_resident_mediator", dns
assert dns["bootstrap_hostnames"] == expected["bootstrap_hostnames"], dns
assert isinstance(dns["materialization_batch_count"], int), dns
assert dns["materialization_batch_count"] >= 0, dns
assert dns["materialization_request_rejections"] == 0, dns
assert isinstance(dns["results_storage_authorization_count"], int), dns
assert dns["results_storage_authorization_count"] >= 0, dns
assert dns["results_storage_attribution_failures"] == 0, dns
assert dns["results_storage_request_rejections"] == 0, dns
assert isinstance(dns["runner_authorized_results_storage"], list), dns
assert isinstance(dns["bounded_githubapp_suffix_authorizations"], list), dns
assert dns["hostname_refresh_warnings"] == 0, dns
assert isinstance(dns["upstream_request_failures"], int), dns
assert dns["upstream_request_failures"] >= 0, dns
assert dns["resident_health"]["resident_pid"] == resident["resident_pid"], dns
assert isinstance(dns["materialization_update_max_milliseconds"], int), dns
assert dns["materialization_update_max_milliseconds"] >= 0, dns
if scenario == "audit":
    assert "audit_observation_only_no_containment_claim" in report["limitations"]
    assert "audit_preserves_passwordless_sudo_and_container_control" in report["limitations"]
    assert "later_workflow_code_retains_arbitrary_egress_in_audit_mode" in report["limitations"]
else:
    assert "bounded_actions_suffix_dns_authorization_remains_an_egress_limitation" in report["limitations"]
    assert "approved_workflow_bootstrap_https_destinations_remain_egress_channels" in report["limitations"]
    assert "runner_authorized_results_storage_accounts_remain_egress_channels" in report["limitations"]
    assert "static_results_storage_compatibility_account_remains_an_egress_channel" in report["limitations"]
    assert "root_resident_dns_upstream_channel_remains_an_egress_limitation" in report["limitations"]
    if scenario == "standard-opt-out":
        assert "dynamic_githubapp_suffix_authorization_disabled" in report["limitations"]
    else:
        assert "bounded_githubapp_suffix_dns_authorization_remains_an_egress_limitation" in report["limitations"]
if scenario == "unsafe-preserve":
    assert "container_control_preserved_invalidates_containment" in report["limitations"]
    assert "container_control_remains_available_to_later_workflow_code" in report["limitations"]
PY

case "$scenario" in
  standard)
    for url in \
      https://github.com \
      https://api.github.com \
      https://release-assets.githubusercontent.com \
      https://hosted-compute-watchdog-prod-eus-01.githubapp.com \
      https://productionresultssa19.blob.core.windows.net; do
      probe_https_once "$url"
    done
    ;;
  standard-opt-out)
    for url in \
      https://github.com \
      https://api.github.com \
      https://release-assets.githubusercontent.com \
      https://hosted-compute-watchdog-prod-eus-01.githubapp.com; do
      if curl --head --silent --show-error --max-time 3 --retry 0 --output /dev/null "$url" 2>/dev/null; then
        die "protected broad-domain opt-out unexpectedly allowed $url"
      fi
    done
    probe_https_once https://productionresultssa19.blob.core.windows.net
    ;;
esac

if [[ "$scenario" == "standard" ]]; then
  python3 <<'PY'
import socket

try:
    socket.getaddrinfo("productionresultssa99999.blob.core.windows.net", 443)
except socket.gaierror:
    pass
else:
    raise SystemExit("workflow process unexpectedly authorized a results-storage hostname")
PY
fi

case "$scenario" in
  standard|standard-finalization|standard-opt-out|unsafe-preserve)
    if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
      die "protected block proof did not disable runner passwordless sudo"
    fi
    ;;
  audit)
    sudo --non-interactive /usr/bin/true >/dev/null
    ;;
esac
case "$scenario" in
  standard|standard-finalization|standard-opt-out)
    if docker ps --quiet >/dev/null 2>&1; then
      die "protected standard-block proof did not disable runner Docker access"
    fi
    ;;
  unsafe-preserve|audit)
    docker ps --quiet >/dev/null
    ;;
esac

if [[ "$scenario" == "audit" ]]; then
  python3 <<'PY'
import socket
import time

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.connect(("192.0.2.10", 443))
sock.send(b"fence-audit-probe")
time.sleep(2)
PY
fi

sleep 6
python3 - "$scenario" "$report" "$dns_report" <<'PY'
import json
import pathlib
import sys

scenario = sys.argv[1]
report_path, dns_path = (pathlib.Path(item) for item in sys.argv[2:])
expected_by_scenario = {
    "standard": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
    },
    "standard-opt-out": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
    },
    "unsafe-preserve": {
        "mode": "block",
        "status": "protected_host_block_degraded",
        "resident": "resident_degraded",
        "sudo_status": "disabled_verified",
        "container_status": "preserved_unsafe",
    },
    "audit": {
        "mode": "audit",
        "status": "protected_host_audit_observation",
        "resident": "resident_observation_only",
        "sudo_status": "preserved_verified",
        "container_status": "preserved_verified",
    },
}
expected_by_scenario["standard-finalization"] = expected_by_scenario["standard"]
expected = expected_by_scenario[scenario]
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
assert report["status"] == expected["status"], report
assert report["mode"] == expected["mode"], report
assert report["setup_status"] == expected["resident"], report
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == expected["sudo_status"], report
assert report["container_status"] == expected["container_status"], report
assert report["critical_findings"] == [], report
assert report["resident_health"]["status"] == "healthy", report
assert report["resident_health"]["verification_sequence"] >= 2, report
assert dns["status"] == expected["status"], dns
assert isinstance(dns["materialization_batch_count"], int), dns
assert dns["materialization_batch_count"] >= 0, dns
assert dns["materialization_request_rejections"] == 0, dns
assert dns["results_storage_attribution_failures"] == 0, dns
if scenario == "standard":
    assert dns["results_storage_request_rejections"] >= 1, dns
else:
    assert dns["results_storage_request_rejections"] == 0, dns
if scenario == "standard-finalization":
    authorizations = dns["runner_authorized_results_storage"]
    if dns["results_storage_authorization_count"] > 0:
        assert authorizations, dns
        assert all(
            item["authorization_origin"] == "pinned_runner_worker_dns"
            for item in authorizations
        ), dns
        print("fence-results-storage-authorization-observed")
    else:
        assert not authorizations, dns
        print("fence-results-storage-authorization-not-observed")
assert isinstance(dns["upstream_request_failures"], int), dns
assert dns["upstream_request_failures"] >= 0, dns
assert dns["resident_health"]["verification_sequence"] >= 2, dns
assert isinstance(dns["materialization_update_max_milliseconds"], int), dns
assert dns["materialization_update_max_milliseconds"] >= 0, dns
if scenario == "audit":
    assert report["counters"]["total_violations"] >= 1, report
    assert report["counters"]["sampled_violations"] >= 1, report
    assert any(item["classification"] == "would_block" for item in report["findings"]), report
    attributed = [
        item for item in report["findings"]
        if item.get("remote_address") == "192.0.2.10"
        and item.get("remote_port") == 443
        and item.get("protocol") == "udp"
        and item.get("local_attribution", {}).get("status") == "attributed"
    ]
    assert attributed, report
    attribution = attributed[0]["local_attribution"]
    assert attribution["actor_class"] == "runner", attribution
    assert isinstance(attribution["pid"], int) and attribution["pid"] > 0, attribution
    assert attribution["executable_basename"].startswith("python3"), attribution
    assert len(attribution["parent_executable_basenames"]) <= 4, attribution
    assert set(attribution) == {
        "status",
        "actor_class",
        "pid",
        "executable_basename",
        "parent_executable_basenames",
    }, attribution
    assert "fence-audit-probe" not in json.dumps(report, sort_keys=True), report
    assert "fence-audit-probe" not in json.dumps(dns, sort_keys=True), dns
if scenario != "standard-finalization":
    print(json.dumps(report, sort_keys=True, separators=(",", ":")))
PY

echo -e "${GREEN}protected trusted-launcher block verified: $scenario${OFF}"
