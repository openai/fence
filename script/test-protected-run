#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 1 ]]; then
  die "usage: script/test-protected-run <standard|standard-finalization|standard-opt-out|unsafe-preserve|wildcard-docker|malformed-wildcard|audit>"
fi

scenario="$1"
case "$scenario" in
  standard|standard-finalization|standard-opt-out|unsafe-preserve|wildcard-docker|malformed-wildcard|audit) ;;
  *) die "unknown protected run scenario: $scenario" ;;
esac

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "protected block proof runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "protected block proof requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd curl
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/install /usr/bin/journalctl /usr/bin/mount /usr/bin/systemctl /usr/bin/systemd-run /usr/bin/umount /usr/sbin/nft; do
  if [[ ! -x "$required" ]]; then
    die "protected block proof requires executable $required"
  fi
done

invocation="protected-${scenario}-${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}"
unit="fence-${invocation}.service"
directory="/run/fence/$invocation"
config="$directory/config.json"
ready="$directory/ready.json"
report="$directory/report.json"
dns_report="$directory/dns-report.json"
config_source="$RUNNER_TEMP/fence-protected-run-config.json"
target_root="$RUNNER_TEMP/fence-protected-run-target-$scenario"
host_observation="$RUNNER_TEMP/fence-hosted-runner-observation.json"
wireserver_agent_observation="$RUNNER_TEMP/fence-wireserver-agent-observation.json"

report_failed_https_probe() {
  local hostname="$1"
  sleep 1
  python3 -E - "$report" "$dns_report" "$hostname" <<'PY'
import json
import pathlib
import sys

report_path = pathlib.Path(sys.argv[1])
dns_path = pathlib.Path(sys.argv[2])
hostname = sys.argv[3]

def read_document(path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return {}

report = read_document(report_path)
dns = read_document(dns_path)
materializations = [
    {
        "address": item.get("address"),
        "hostname": item.get("hostname"),
        "port": item.get("port"),
        "protocol": item.get("protocol"),
        "source_hostname": item.get("source_hostname"),
    }
    for item in report.get("materialized_allowances", [])
    if item.get("source_hostname") == hostname or item.get("hostname") == hostname
][:32]
findings = [
    {
        "classification": item.get("classification"),
        "family": item.get("family"),
        "protocol": item.get("protocol"),
        "remote_address": item.get("remote_address"),
        "remote_port": item.get("remote_port"),
        "rule_class": item.get("rule_class"),
    }
    for item in report.get("findings", [])
    if item.get("protocol") == "tcp" and item.get("remote_port") == 443
][:8]
observations = [
    {
        "hostname": item.get("hostname"),
        "occurrences": item.get("occurrences"),
        "policy_classification": item.get("policy_classification"),
        "query_type": item.get("query_type"),
        "resolved_addresses": item.get("resolved_addresses", [])[:32],
    }
    for item in dns.get("observations", [])
    if item.get("hostname") == hostname
][:4]
diagnostic = {
    "critical_codes": [item.get("code") for item in report.get("critical_findings", [])][:8],
    "dns_observations": observations,
    "hostname": hostname,
    "hostname_refresh_warnings": dns.get("hostname_refresh_warnings"),
    "materialization_request_rejections": dns.get("materialization_request_rejections"),
    "materialized_allowances": materializations,
    "rejected_tcp_443_findings": findings,
    "upstream_request_failures": dns.get("upstream_request_failures"),
}
print("bounded first-connect failure evidence: " + json.dumps(diagnostic, sort_keys=True, separators=(",", ":")))
PY
}

probe_https_once() {
  local url="$1"
  if curl --head --silent --show-error --max-time 10 --retry 0 --output /dev/null "$url"; then
    return 0
  fi
  report_failed_https_probe "${url#https://}"
  return 1
}

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "protected block proof requires absent host inet fence_v0 table"
fi
if [[ -e "$directory" ]]; then
  die "protected block proof requires absent production runtime directory"
fi

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo build --frozen --release --bin fence
binary="$target_root/release/fence"

python3 -E - "$config_source" "$invocation" "$scenario" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
invocation_id = sys.argv[2]
scenario = sys.argv[3]
document = {
    "schema_version": 1,
    "mode": "audit" if scenario == "audit" else "block",
    "invocation_id": invocation_id,
    "allowlist": [],
}
if scenario in {"standard", "standard-finalization"}:
    document["container_policy"] = "disable"
elif scenario == "standard-opt-out":
    document["container_policy"] = "disable"
    document["disable_broad_github_domains"] = True
elif scenario == "unsafe-preserve":
    document["container_policy"] = "unsafe_preserve"
elif scenario == "wildcard-docker":
    document["container_policy"] = "unsafe_preserve"
    document["allowlist"] = [{
        "destination_type": "hostname",
        "destination": "*.docker.io",
        "protocol": "tcp",
        "port": 443,
    }]
elif scenario == "malformed-wildcard":
    document["container_policy"] = "disable"
    document["allowlist"] = [{
        "destination_type": "hostname",
        "destination": "*.*.*.docker.io",
        "protocol": "tcp",
        "port": 443,
    }]
path.write_text(
    json.dumps(document, sort_keys=True, separators=(",", ":")),
    encoding="utf-8",
)
PY

sudo /usr/bin/install -d -o root -g root -m 0755 /run/fence "$directory"
sudo /usr/bin/install -o root -g root -m 0600 "$config_source" "$config"

# The service intentionally remains resident after this script exits. The
# disposable hosted runner teardown is the only post-ready cleanup path.
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  "$binary" run --config "$config"

if [[ "$scenario" == "malformed-wildcard" ]]; then
  service_output=""
  for _ in {1..100}; do
    service_output="$(sudo /usr/bin/journalctl --unit "$unit" --no-pager --output=cat 2>/dev/null || true)"
    if [[ "$service_output" == *'"code":"invalid_destination"'* ]]; then
      break
    fi
    sleep 0.1
  done
  if [[ "$service_output" != *'"code":"invalid_destination"'* ]]; then
    die "malformed wildcard proof did not emit invalid_destination"
  fi
  for _ in {1..50}; do
    if ! /usr/bin/systemctl is-active --quiet "$unit"; then
      break
    fi
    sleep 0.1
  done
  if /usr/bin/systemctl is-active --quiet "$unit"; then
    die "malformed wildcard proof unexpectedly left the source agent resident"
  fi
  for unexpected in "$ready" "$report" "$dns_report" "$directory/state.json"; do
    if [[ -e "$unexpected" ]]; then
      die "malformed wildcard proof unexpectedly wrote agent runtime evidence"
    fi
  done
  if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
    die "malformed wildcard proof unexpectedly created inet fence_v0"
  fi
  sudo --non-interactive /usr/bin/true >/dev/null
  docker ps --quiet >/dev/null
  echo -e "${GREEN}Malformed wildcard proof verified:${OFF} rejected before agent mutation"
  exit 0
fi

python3 -E - "$scenario" "$report" "$dns_report" "$ready" "$unit" <<'PY'
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message="evidence validation failed"):
    if not condition:
        raise SystemExit(message)

import json
import pathlib
import re
import subprocess
import sys
import time

scenario = sys.argv[1]
report_path, dns_path, ready_path = (pathlib.Path(item) for item in sys.argv[2:5])
unit = sys.argv[5]
expected_by_scenario = {
    "standard": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "ready": "ready",
        "protection_available": True,
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "standard-opt-out": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "ready": "ready",
        "protection_available": True,
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
        "bootstrap_hostnames": [
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "unsafe-preserve": {
        "mode": "block",
        "status": "protected_host_block_degraded",
        "resident": "resident_degraded",
        "ready": "ready_degraded",
        "protection_available": False,
        "sudo_status": "disabled_verified",
        "container_status": "preserved_unsafe",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "wildcard-docker": {
        "mode": "block",
        "status": "protected_host_block_degraded",
        "resident": "resident_degraded",
        "ready": "ready_degraded",
        "protection_available": False,
        "sudo_status": "disabled_verified",
        "container_status": "preserved_unsafe",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
    "audit": {
        "mode": "audit",
        "status": "protected_host_audit_observation",
        "resident": "resident_observation_only",
        "ready": "ready_observation_only",
        "protection_available": False,
        "sudo_status": "preserved_verified",
        "container_status": "preserved_verified",
        "bootstrap_hostnames": [
            "github.com",
            "api.github.com",
            "release-assets.githubusercontent.com",
            "hosted-compute-watchdog-prod-eus-01.githubapp.com",
            "vstoken.actions.githubusercontent.com",
            "pipelines.actions.githubusercontent.com",
            "payload.pipelines.actions.githubusercontent.com",
            "results-receiver.actions.githubusercontent.com",
            "actions-results-receiver-production.githubapp.com",
            "productionresultssa19.blob.core.windows.net",
        ],
    },
}
expected_by_scenario["standard-finalization"] = expected_by_scenario["standard"]
expected = expected_by_scenario[scenario]
deadline = time.monotonic() + 60
report = None
dns = None
ready = None
while time.monotonic() < deadline:
    if report_path.exists() and dns_path.exists() and ready_path.exists():
        report = json.loads(report_path.read_text(encoding="utf-8"))
        dns = json.loads(dns_path.read_text(encoding="utf-8"))
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        if report.get("setup_status") == expected["resident"]:
            break
    time.sleep(0.1)

if report is None or report.get("setup_status") != expected["resident"]:
    properties = subprocess.run(
        [
            "/usr/bin/systemctl",
            "show",
            unit,
            "--property=LoadState",
            "--property=ActiveState",
            "--property=SubState",
            "--property=Result",
            "--property=ExecMainCode",
            "--property=ExecMainStatus",
        ],
        check=False,
        capture_output=True,
        text=True,
    )
    unit_state = {}
    for line in properties.stdout.splitlines():
        key, separator, value = line.partition("=")
        if separator:
            unit_state[key] = value

    journal = subprocess.run(
        [
            "/usr/bin/journalctl",
            "--unit",
            unit,
            "--no-pager",
            "--output=cat",
            "--lines=20",
        ],
        check=False,
        capture_output=True,
        text=True,
    )
    service_error_codes = []
    for line in journal.stdout.splitlines():
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        code = entry.get("error", {}).get("code")
        if isinstance(code, str) and code not in service_error_codes:
            service_error_codes.append(code)

    diagnostic = {
        "critical_codes": [
            item.get("code")
            for item in (report or {}).get("critical_findings", [])
        ][:8],
        "dns_routing_status": (dns or {}).get("routing_status"),
        "network_application_status": (report or {}).get("network_application_status"),
        "network_verification_status": (report or {}).get("network_verification_status"),
        "readiness_status": (report or {}).get("readiness_status"),
        "report_present": report is not None,
        "service_error_codes": service_error_codes[:8],
        "setup_status": (report or {}).get("setup_status"),
        "unit_state": unit_state,
    }
    print("bounded protected startup evidence: " + json.dumps(
        diagnostic,
        sort_keys=True,
        separators=(",", ":"),
    ))

require(report is not None)
require(dns is not None)
require(ready is not None)
require(report["status"] == expected["status"])
require(report["runtime_evidence_schema_version"] == 5)
require(report["mode"] == expected["mode"])
require(report["setup_status"] == expected["resident"])
require(report["readiness_status"] == expected["ready"])
require(report["protection_available"] is expected["protection_available"])
require(report["platform_profile_id"] == "github_hosted_workflow_bootstrap_v4")
require(report["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v4")
require(report["policy_hash_schema_version"] == 8)
require(re.fullmatch(r"[0-9a-f]{64}", report["policy_hash"]))
require(re.fullmatch(r"[0-9a-f]{64}", report["base_ruleset_hash"]))
require(re.fullmatch(r"[0-9a-f]{64}", report["ruleset_hash"]))
require(report["network_application_status"] == "applied")
require(report["network_verification_status"] == "verified")
require(report["sudo_status"] == expected["sudo_status"])
require(report["container_status"] == expected["container_status"])
if scenario != "audit":
    require(len(report["materialized_allowances"]) >= 1)
    require(report["bootstrap_hostnames"] == expected["bootstrap_hostnames"])
require(report["critical_findings"] == [])
resident = report["resident_health"]
require(resident["status"] == "healthy")
require(resident["resident_pid"] > 0)
require(resident["verification_sequence"] >= 1)
require(resident["last_successful_verification_unix_milliseconds"] > 0)
require(resident["verification_interval_seconds"] == 5)
require(resident["workers"] == [
    {"name": "docker_tcp_dns", "status": "running"},
    {"name": "docker_udp_dns", "status": "running"},
    {"name": "host_tcp_dns", "status": "running"},
    {"name": "host_udp_dns", "status": "running"},
    {"name": "process_attribution", "status": "running"},
])
require(ready["status"] == expected["ready"])
require(ready["runtime_evidence_schema_version"] == 5)
require(ready["mode"] == expected["mode"])
require(ready["protection_available"] is expected["protection_available"])
require(ready["platform_profile_id"] == "github_hosted_workflow_bootstrap_v4")
require(ready["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v4")
require(ready["policy_hash_schema_version"] == 8)
require(ready["policy_hash"] == report["policy_hash"])
require(ready["base_ruleset_hash"] == report["base_ruleset_hash"])
require(ready["resident_health"]["resident_pid"] == resident["resident_pid"])
require(dns["status"] == expected["status"])
require(dns["runtime_evidence_schema_version"] == 5)
require(dns["mode"] == expected["mode"])
require(dns["protection_available"] is expected["protection_available"])
require(dns["platform_profile_id"] == "github_hosted_workflow_bootstrap_v4")
require(dns["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v4")
require(dns["proxy_policy_status"] == (
    "audit_forwards_while_simulating_name_authorization"
    if scenario == "audit"
    else "block_forwards_exact_roots_bounded_user_wildcard_names_actions_suffix_names_githubapp_suffix_names_results_storage_and_bounded_cname_descendants"
))
require(dns["routing_status"] == "active")
require(dns["host_dns_routing"] == "direct_client_to_root_resident_mediator")
require(dns["docker_dns_routing"] == "local_root_resident_mediator")
require(dns["bootstrap_hostnames"] == expected["bootstrap_hostnames"])
require(isinstance(dns["materialization_batch_count"], int))
require(dns["materialization_batch_count"] >= 0)
require(dns["materialization_request_rejections"] == 0)
require(isinstance(dns["results_storage_authorization_count"], int))
require(dns["results_storage_authorization_count"] >= 0)
require(dns["results_storage_attribution_failures"] == 0)
require(dns["results_storage_request_rejections"] == 0)
require(isinstance(dns["runner_authorized_results_storage"], list))
require(isinstance(dns["bounded_githubapp_suffix_authorizations"], list))
require(isinstance(dns["bounded_user_wildcard_authorizations"], list))
require(len(dns["bounded_user_wildcard_authorizations"]) <= 8)
require(isinstance(dns["bounded_user_wildcard_authorizations_truncated"], bool))
require(isinstance(dns["user_wildcard_request_rejections"], int))
require(dns["user_wildcard_request_rejections"] == 0)
require(dns["hostname_refresh_warnings"] == 0)
require(isinstance(dns["upstream_request_failures"], int))
require(dns["upstream_request_failures"] >= 0)
require(dns["resident_health"]["resident_pid"] == resident["resident_pid"])
require(isinstance(dns["materialization_update_max_milliseconds"], int))
require(dns["materialization_update_max_milliseconds"] >= 0)
if scenario == "audit":
    require("audit_observation_only_no_containment_claim" in report["limitations"])
    require("audit_preserves_passwordless_sudo_and_container_control" in report["limitations"])
    require("later_workflow_code_retains_arbitrary_egress_in_audit_mode" in report["limitations"])
else:
    require("bounded_actions_suffix_dns_authorization_remains_an_egress_limitation" in report["limitations"])
    require("approved_workflow_bootstrap_https_destinations_remain_egress_channels" in report["limitations"])
    require("runner_authorized_results_storage_accounts_remain_egress_channels" in report["limitations"])
    require("static_results_storage_compatibility_account_remains_an_egress_channel" in report["limitations"])
    require("root_resident_dns_upstream_channel_remains_an_egress_limitation" in report["limitations"])
    if scenario == "standard-opt-out":
        require("dynamic_githubapp_suffix_authorization_disabled" in report["limitations"])
    else:
        require("bounded_githubapp_suffix_dns_authorization_remains_an_egress_limitation" in report["limitations"])
if scenario in {"unsafe-preserve", "wildcard-docker"}:
    require("container_control_preserved_invalidates_containment" in report["limitations"])
    require("container_control_remains_available_to_later_workflow_code" in report["limitations"])
if scenario == "wildcard-docker":
    require("bounded_user_wildcard_dns_authorization_remains_an_egress_limitation" in report["limitations"])
    require(dns["bounded_user_wildcard_authorizations"] == [])
    require(dns["bounded_user_wildcard_authorizations_truncated"] is False)
    require(dns["user_wildcard_request_rejections"] == 0)
else:
    require(dns["bounded_user_wildcard_authorizations"] == [])
    require(dns["bounded_user_wildcard_authorizations_truncated"] is False)
PY

wireserver_observer_pid=""
if [[ "$scenario" == "audit" ]]; then
  script/observe-wireserver-agent "$host_observation" "$wireserver_agent_observation" &
  wireserver_observer_pid="$!"
fi

case "$scenario" in
  standard)
    for url in \
      https://github.com \
      https://api.github.com \
      https://release-assets.githubusercontent.com \
      https://hosted-compute-watchdog-prod-eus-01.githubapp.com \
      https://productionresultssa19.blob.core.windows.net; do
      probe_https_once "$url"
    done
    ;;
  standard-opt-out)
    for url in \
      https://github.com \
      https://api.github.com \
      https://release-assets.githubusercontent.com \
      https://hosted-compute-watchdog-prod-eus-01.githubapp.com; do
      if curl --head --silent --show-error --max-time 3 --retry 0 --output /dev/null "$url" 2>/dev/null; then
        die "protected broad-domain opt-out unexpectedly allowed $url"
      fi
    done
    probe_https_once https://productionresultssa19.blob.core.windows.net
    ;;
  wildcard-docker)
    probe_https_once https://auth.docker.io
    probe_https_once https://registry-1.docker.io
    ;;
esac

if [[ "$scenario" == "standard" ]]; then
  python3 -E <<'PY'
import socket

try:
    socket.getaddrinfo("productionresultssa99999.blob.core.windows.net", 443)
except socket.gaierror:
    pass
else:
    raise SystemExit("workflow process unexpectedly authorized a results-storage hostname")

for address, port in [
    ("168.63.129.16", 80),
    ("168.63.129.16", 32526),
    ("169.254.169.254", 80),
]:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(2)
    try:
        sock.connect((address, port))
    except OSError:
        pass
    else:
        raise SystemExit(f"workflow process unexpectedly connected to {address}:{port}")
    finally:
        sock.close()
PY
fi

case "$scenario" in
  standard|standard-finalization|standard-opt-out|unsafe-preserve|wildcard-docker)
    if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
      die "protected block proof did not disable runner passwordless sudo"
    fi
    ;;
  audit)
    sudo --non-interactive /usr/bin/true >/dev/null
    ;;
esac
case "$scenario" in
  standard|standard-finalization|standard-opt-out)
    if docker ps --quiet >/dev/null 2>&1; then
      die "protected standard-block proof did not disable runner Docker access"
    fi
    ;;
  unsafe-preserve|wildcard-docker|audit)
    docker ps --quiet >/dev/null
    ;;
esac

if [[ "$scenario" == "audit" ]]; then
  python3 -E <<'PY'
import socket
import time

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.connect(("192.0.2.10", 443))
sock.send(b"fence-audit-probe")
time.sleep(2)
PY
fi

sleep 6
if [[ -n "$wireserver_observer_pid" ]]; then
  wait "$wireserver_observer_pid"
fi
python3 -E - "$scenario" "$report" "$dns_report" "$host_observation" "$wireserver_agent_observation" <<'PY'
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message="evidence validation failed"):
    if not condition:
        raise SystemExit(message)

import json
import pathlib
import sys

scenario = sys.argv[1]
report_path, dns_path, host_observation_path, wireserver_observation_path = (
    pathlib.Path(item) for item in sys.argv[2:]
)
expected_by_scenario = {
    "standard": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
    },
    "standard-opt-out": {
        "mode": "block",
        "status": "protected_host_block",
        "resident": "resident_protected",
        "sudo_status": "disabled_verified",
        "container_status": "disabled_verified",
    },
    "unsafe-preserve": {
        "mode": "block",
        "status": "protected_host_block_degraded",
        "resident": "resident_degraded",
        "sudo_status": "disabled_verified",
        "container_status": "preserved_unsafe",
    },
    "wildcard-docker": {
        "mode": "block",
        "status": "protected_host_block_degraded",
        "resident": "resident_degraded",
        "sudo_status": "disabled_verified",
        "container_status": "preserved_unsafe",
    },
    "audit": {
        "mode": "audit",
        "status": "protected_host_audit_observation",
        "resident": "resident_observation_only",
        "sudo_status": "preserved_verified",
        "container_status": "preserved_verified",
    },
}
expected_by_scenario["standard-finalization"] = expected_by_scenario["standard"]
expected = expected_by_scenario[scenario]
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
require(report["status"] == expected["status"])
require(report["mode"] == expected["mode"])
require(report["setup_status"] == expected["resident"])
require(report["network_verification_status"] == "verified")
require(report["sudo_status"] == expected["sudo_status"])
require(report["container_status"] == expected["container_status"])
require(report["critical_findings"] == [])
require(report["resident_health"]["status"] == "healthy")
require(report["resident_health"]["verification_sequence"] >= 2)
require(dns["status"] == expected["status"])
require(isinstance(dns["materialization_batch_count"], int))
require(dns["materialization_batch_count"] >= 0)
require(dns["materialization_request_rejections"] == 0)
require(dns["results_storage_attribution_failures"] == 0)
require(dns["user_wildcard_request_rejections"] == 0)
require(dns["bounded_user_wildcard_authorizations_truncated"] is False)
if scenario == "standard":
    require(dns["results_storage_request_rejections"] >= 1)
else:
    require(dns["results_storage_request_rejections"] == 0)
if scenario == "standard-finalization":
    authorizations = dns["runner_authorized_results_storage"]
    if dns["results_storage_authorization_count"] > 0:
        require(authorizations)
        require(all(
            item["authorization_origin"] == "pinned_runner_worker_dns"
            for item in authorizations
        ))
        print("fence-results-storage-authorization-observed")
    else:
        require(not authorizations)
        print("fence-results-storage-authorization-not-observed")
if scenario == "wildcard-docker":
    authorized = set(dns["bounded_user_wildcard_authorizations"])
    require({"auth.docker.io", "registry-1.docker.io"}.issubset(authorized))
    wildcard_materializations = [
        item for item in report["materialized_allowances"]
        if item.get("source_hostname") in {"auth.docker.io", "registry-1.docker.io"}
    ]
    require(wildcard_materializations)
    require(all(
        item["protocol"] == "tcp"
        and item["port"] == 443
        and "user" in item["origins"]
        for item in wildcard_materializations
    ))
    observations = [
        item for item in dns["observations"]
        if item.get("hostname") in {"auth.docker.io", "registry-1.docker.io"}
    ]
    require(observations)
    require(all(
        item["policy_classification"] == "user_wildcard_allowlist"
        for item in observations
    ))
require(isinstance(dns["upstream_request_failures"], int))
require(dns["upstream_request_failures"] >= 0)
require(dns["resident_health"]["verification_sequence"] >= 2)
require(isinstance(dns["materialization_update_max_milliseconds"], int))
require(dns["materialization_update_max_milliseconds"] >= 0)
if scenario == "audit":
    require(report["counters"]["total_violations"] >= 1)
    require(report["counters"]["sampled_violations"] >= 1)
    require(any(item["classification"] == "would_block" for item in report["findings"]))
    attributed = [
        item for item in report["findings"]
        if item.get("remote_address") == "192.0.2.10"
        and item.get("remote_port") == 443
        and item.get("protocol") == "udp"
        and item.get("local_attribution", {}).get("status") == "attributed"
    ]
    require(attributed)
    attribution = attributed[0]["local_attribution"]
    require(attribution["actor_class"] == "runner")
    require(isinstance(attribution["pid"], int) and attribution["pid"] > 0)
    require(attribution["executable_basename"].startswith("python3"))
    require(len(attribution["parent_executable_basenames"]) <= 4)
    require(set(attribution) == {
        "status",
        "actor_class",
        "pid",
        "executable_basename",
        "parent_executable_basenames",
    })
    observation = json.loads(host_observation_path.read_text(encoding="utf-8"))
    require(observation["schema_version"] == 4)
    azure_agent = observation["systemd"]["azure_platform_agent"]
    require(azure_agent["name"] == "walinuxagent.service")
    require(azure_agent["active_state"] == "active")
    require(azure_agent["sub_state"] == "running")
    require(azure_agent["configured_user_class"] == "root_or_default")
    require(azure_agent["process_owner_class"] == "root")
    require(azure_agent["process_status"] == "observed")
    wireserver_findings = [
        item for item in report["findings"]
        if item.get("remote_address") == "168.63.129.16"
        and item.get("protocol") == "tcp"
        and item.get("remote_port") in {80, 32526}
    ]
    observed_ports = {item["remote_port"] for item in wireserver_findings}
    wireserver_observation = json.loads(
        wireserver_observation_path.read_text(encoding="utf-8")
    )
    require(wireserver_observation["schema_version"] == 1)
    require(wireserver_observation["status"] == "wireserver_agent_observation_only")
    require(wireserver_observation["control_group"] == "/azure.slice/walinuxagent.service")
    require(wireserver_observation["destination"] == "168.63.129.16")
    require(wireserver_observation["observations_truncated"] is False)
    agent_socket_ports = {
        item["port"] for item in wireserver_observation["observations"]
    }
    diagnostic = {
        "agent_control_group": azure_agent["control_group"],
        "agent_processes": [
            {
                "executable_basename": process["executable_basename"],
                "pid": process["pid"],
            }
            for process in azure_agent["processes"]
        ],
        "agent_socket_observations": wireserver_observation["observations"],
        "agent_socket_ports": sorted(agent_socket_ports),
        "observed_ports": sorted(observed_ports),
        "wireserver_attribution": [
            {
                "actor_class": item.get("local_attribution", {}).get("actor_class"),
                "executable_basename": item.get("local_attribution", {}).get("executable_basename"),
                "pid": item.get("local_attribution", {}).get("pid"),
                "port": item["remote_port"],
                "status": item.get("local_attribution", {}).get("status"),
            }
            for item in wireserver_findings
        ],
    }
    print("fence-wireserver-agent-correlation=" + json.dumps(
        diagnostic,
        sort_keys=True,
        separators=(",", ":"),
    ))
    require(not observed_ports, "natural WireServer traffic was reported as blocked")
    require(not any(
        item.get("local_attribution", {}).get("actor_class") == "runner"
        for item in wireserver_findings
    ), "WireServer traffic was attributed to the runner")
    if agent_socket_ports:
        print("fence-wireserver-agent-attribution-observed")
    else:
        print("fence-wireserver-agent-attribution-not-observed")
    require("fence-audit-probe" not in json.dumps(report, sort_keys=True))
    require("fence-audit-probe" not in json.dumps(dns, sort_keys=True))
if scenario != "standard-finalization":
    print(json.dumps(report, sort_keys=True, separators=(",", ":")))
PY

echo -e "${GREEN}protected trusted-launcher block verified: $scenario${OFF}"
