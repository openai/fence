#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 0 ]]; then
  die "usage: script/test-protected-run"
fi

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "protected standard-block proof runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "protected standard-block proof requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/install /usr/bin/systemctl /usr/bin/systemd-run /usr/bin/resolvectl /usr/sbin/nft; do
  if [[ ! -x "$required" ]]; then
    die "protected standard-block proof requires executable $required"
  fi
done

invocation="protected-run-${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}"
unit="fence-${invocation}.service"
directory="/run/fence/$invocation"
config="$directory/config.json"
ready="$directory/ready.json"
report="$directory/report.json"
dns_report="$directory/dns-report.json"
config_source="$RUNNER_TEMP/fence-protected-run-config.json"
target_root="$RUNNER_TEMP/fence-protected-run-target"

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "protected standard-block proof requires absent host inet fence_v0 table"
fi
if [[ -e "$directory" ]]; then
  die "protected standard-block proof requires absent production runtime directory"
fi

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo build --frozen --release --bin fence
binary="$target_root/release/fence"

python3 - "$config_source" "$invocation" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
invocation_id = sys.argv[2]
document = {
    "schema_version": 1,
    "mode": "block",
    "invocation_id": invocation_id,
    "container_policy": "disable",
    "allowances": [],
}
path.write_text(
    json.dumps(document, sort_keys=True, separators=(",", ":")),
    encoding="utf-8",
)
PY

sudo /usr/bin/install -d -o root -g root -m 0755 /run/fence "$directory"
sudo /usr/bin/install -o root -g root -m 0600 "$config_source" "$config"

# The service intentionally remains resident after this script exits. The
# disposable hosted runner teardown is the only post-ready cleanup path.
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  "$binary" run --config "$config"

python3 - "$report" "$dns_report" "$ready" <<'PY'
import json
import pathlib
import re
import sys
import time

report_path, dns_path, ready_path = (pathlib.Path(item) for item in sys.argv[1:])
deadline = time.monotonic() + 30
report = None
dns = None
ready = None
while time.monotonic() < deadline:
    if report_path.exists() and dns_path.exists() and ready_path.exists():
        report = json.loads(report_path.read_text(encoding="utf-8"))
        dns = json.loads(dns_path.read_text(encoding="utf-8"))
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        if report.get("setup_status") == "resident_protected":
            break
    time.sleep(0.1)

assert report is not None, "protected report was not emitted"
assert dns is not None, "protected DNS report was not emitted"
assert ready is not None, "protected readiness was not emitted"
assert report["status"] == "protected_host_block", report
assert report["mode"] == "block", report
assert report["setup_status"] == "resident_protected", report
assert report["readiness_status"] == "ready", report
assert report["protection_available"] is True, report
assert report["selected_platform_profile_id"] == "github_hosted_job_status_v1", report
assert report["policy_hash_schema_version"] == 3, report
assert re.fullmatch(r"[0-9a-f]{64}", report["policy_hash"]), report
assert re.fullmatch(r"[0-9a-f]{64}", report["base_ruleset_hash"]), report
assert re.fullmatch(r"[0-9a-f]{64}", report["ruleset_hash"]), report
assert report["network_application_status"] == "applied", report
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
assert len(report["materialized_https_allowances"]) >= 1, report
assert report["critical_findings"] == [], report
assert ready["status"] == "ready", ready
assert ready["mode"] == "block", ready
assert ready["protection_available"] is True, ready
assert ready["selected_platform_profile_id"] == "github_hosted_job_status_v1", ready
assert ready["policy_hash"] == report["policy_hash"], (ready, report)
assert ready["base_ruleset_hash"] == report["base_ruleset_hash"], (ready, report)
assert dns["status"] == "protected_host_block", dns
assert dns["mode"] == "block", dns
assert dns["protection_available"] is True, dns
assert dns["selected_platform_profile_id"] == "github_hosted_job_status_v1", dns
assert dns["routing_status"] == "active", dns
assert dns["host_dns_routing"] == "local_root_resident_mediator", dns
assert dns["docker_dns_routing"] == "local_root_resident_mediator", dns
assert "bounded_actions_suffix_dns_authorization_remains_an_egress_limitation" in report["limitations"]
assert "approved_status_https_destinations_remain_egress_channels" in report["limitations"]
assert "root_resident_dns_upstream_channel_remains_an_egress_limitation" in report["limitations"]
assert "standard_block_only_until_audit_and_unsafe_preserve_are_activated" in report["limitations"]
PY

if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
  die "protected standard-block proof did not disable runner passwordless sudo"
fi
if docker ps --quiet >/dev/null 2>&1; then
  die "protected standard-block proof did not disable runner Docker access"
fi

sleep 6
python3 - "$report" "$dns_report" <<'PY'
import json
import pathlib
import sys

report_path, dns_path = (pathlib.Path(item) for item in sys.argv[1:])
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
assert report["status"] == "protected_host_block", report
assert report["setup_status"] == "resident_protected", report
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
assert report["critical_findings"] == [], report
assert dns["status"] == "protected_host_block", dns
print(json.dumps(report, sort_keys=True, separators=(",", ":")))
PY

echo -e "${GREEN}protected trusted-launcher standard block verified${OFF}"
