#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -ne 0 ]]; then
  die "usage: script/test-profile-candidate"
fi

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "broad GitHub compatibility profile evidence runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "broad GitHub compatibility profile evidence requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/systemctl /usr/bin/systemd-run /usr/sbin/nft; do
  if [[ ! -x "$required" ]]; then
    die "broad GitHub compatibility profile evidence requires executable $required"
  fi
done

suffix="${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}-${PROFILE_CANDIDATE_REPLICA:-trial}"
invocation="profile-candidate-${GITHUB_RUN_ATTEMPT:-attempt}-${PROFILE_CANDIDATE_REPLICA:-trial}"
unit="fence-evidence-${invocation}.service"
runtime_root="/run/fence-profile-candidate-${suffix}"
report="$runtime_root/$invocation/report.json"
ready="$runtime_root/$invocation/ready.json"
production_ready="/run/fence/$invocation/ready.json"
target_root="$RUNNER_TEMP/fence-profile-candidate-target"

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo test --frozen --test profile_candidate --no-run

shopt -s nullglob
test_binaries=()
for candidate in "$target_root"/debug/deps/profile_candidate-*; do
  if [[ -f "$candidate" && -x "$candidate" ]]; then
    test_binaries+=("$candidate")
  fi
done
if [[ "${#test_binaries[@]}" -ne 1 ]]; then
  die "expected exactly one compiled broad GitHub compatibility profile test binary"
fi

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "broad GitHub compatibility profile evidence requires absent host inet fence_v0 table"
fi
if [[ -e "$production_ready" ]]; then
  die "broad GitHub compatibility profile evidence requires absent production readiness path"
fi

# This applies block policy on a disposable hosted runner using only the
# explicit, non-default compatibility candidate. The resident controls are
# deliberately left installed for GitHub to prove terminal job completion.
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  --setenv=FENCE_PROFILE_CANDIDATE_WORKER=1 \
  "--setenv=FENCE_PROFILE_CANDIDATE_UNIT=$unit" \
  "--setenv=FENCE_PROFILE_CANDIDATE_ROOT=$runtime_root" \
  "--setenv=FENCE_PROFILE_CANDIDATE_INVOCATION=$invocation" \
  "${test_binaries[0]}" --ignored --exact broad_compatibility_profile_host_block_candidate_worker --nocapture

python3 - "$report" "$ready" "$production_ready" <<'PY'
import json
import pathlib
import sys
import time

report_path, ready_path, production_ready_path = (pathlib.Path(item) for item in sys.argv[1:])
deadline = time.monotonic() + 20
ready = None
report = None
while time.monotonic() < deadline:
    if ready_path.exists() and report_path.exists():
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        report = json.loads(report_path.read_text(encoding="utf-8"))
        if (
            report.get("setup_status") == "resident_host_block_candidate_test_only"
            and report.get("readiness_status") == "host_block_candidate_ready_no_public_activation"
        ):
            break
    time.sleep(0.1)
assert ready is not None, "broad GitHub compatibility profile candidate readiness was not emitted"
assert report is not None, "broad GitHub compatibility profile candidate report was not emitted"
assert ready["status"] == "host_block_candidate_ready_no_public_activation"
assert ready["protection_available"] is False
assert report["status"] == "host_block_candidate_test_only"
assert report["mode"] == "block"
assert report["setup_status"] == "resident_host_block_candidate_test_only"
assert report["network_application_status"] == "applied"
assert report["network_verification_status"] == "verified"
assert report["sudo_status"] == "disabled_verified"
assert report["container_status"] == "disabled_verified"
assert report["readiness_status"] == "host_block_candidate_ready_no_public_activation"
assert report["protection_available"] is False
assert report["platform_profile"]["id"] == "github_hosted_compatibility_candidate_v1"
assert report["platform_profile"]["selection_status"] == "explicit_broad_candidate_not_default"
assert len(report["platform_profile"]["requested_allowances"]) == 8
assert len(report["platform_profile"]["effective_allowances"]) >= 1
assert len(report["platform_profile"]["frozen_resolution_results"]) == 8
assert "candidate_profile_explicit_not_default" in report["limitations"]
assert "candidate_is_intentionally_broader_than_job_status_only" in report["limitations"]
assert "no_public_activation" in report["limitations"]
assert "candidate_permits_results_storage_compatibility_scope" in report["limitations"]
assert "permitted_compatibility_channels_are_an_exfiltration_limitation" in report["limitations"]
assert not production_ready_path.exists()
PY

if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
  die "broad GitHub compatibility profile candidate did not disable runner passwordless sudo"
fi
if docker ps --quiet >/dev/null 2>&1; then
  die "broad GitHub compatibility profile candidate did not disable runner Docker access"
fi

sleep 6
python3 - "$report" <<'PY'
import json
import pathlib
import sys

report = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
assert report["critical_findings"] == [], report
PY

echo -e "${GREEN}broad GitHub compatibility profile candidate evidence verified${OFF}"
