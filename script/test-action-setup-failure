#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "Action setup-failure evidence runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "Action setup-failure evidence requires Linux x86_64"
fi

require_cmd node
require_cmd sudo
require_cmd systemctl
if [[ ! -x /usr/sbin/nft ]]; then
  die "Action setup-failure evidence requires /usr/sbin/nft"
fi

temporary_directory="$(make_temp_dir fence-action-setup-failure "$RUNNER_TEMP")"
trap 'remove_generated_path "$temporary_directory" "Action setup-failure scratch directory"' EXIT

state="$temporary_directory/state"
summary="$temporary_directory/summary"
stdout="$temporary_directory/stdout"
stderr="$temporary_directory/stderr"
: >"$state"
: >"$summary"

if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "Action setup-failure evidence requires no preexisting inet fence_v0 table"
fi
if [[ -e /run/fence/Action_Invalid || -e /run/fence/action-invalid ]]; then
  die "Action setup-failure evidence requires no preexisting invalid runtime directory"
fi

if INPUT_CONFIG='{"schema_version":1,"mode":"audit","invocation_id":"Action_Invalid","allowlist":[]}' \
  GITHUB_STATE="$state" \
  GITHUB_STEP_SUMMARY="$summary" \
  node action/main.cts >"$stdout" 2>"$stderr"; then
  die "Action setup unexpectedly accepted an invalid invocation slug"
fi

grep -q "config invocation_id must use the Fence lowercase slug grammar" "$stderr"
if [[ -s "$stdout" || -s "$state" || -s "$summary" ]]; then
  die "Action setup-failure evidence unexpectedly emitted success state"
fi
if [[ -e /run/fence/Action_Invalid || -e /run/fence/action-invalid ]]; then
  die "Action setup-failure evidence unexpectedly created a runtime directory"
fi
if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "Action setup-failure evidence unexpectedly created inet fence_v0"
fi

wildcard_invocation="fence-12345-2"
if [[ -e "/run/fence/$wildcard_invocation" ]]; then
  die "Action setup-failure evidence requires no preexisting wildcard runtime directory"
fi
: >"$state"
: >"$summary"
: >"$stdout"
: >"$stderr"
if INPUT_CONFIG='' \
  INPUT_ALLOWLIST='*.*.*.docker.io' \
  GITHUB_RUN_ID='12345' \
  GITHUB_RUN_ATTEMPT='2' \
  GITHUB_STATE="$state" \
  GITHUB_STEP_SUMMARY="$summary" \
  node action/main.cts >"$stdout" 2>"$stderr"; then
  die "Action setup unexpectedly accepted an unbounded wildcard hostname"
fi

grep -q "allowlist line 1: allowlist hostname entries must be valid exact names or bounded wildcard patterns" "$stderr"
if [[ -s "$stdout" || -s "$state" || -s "$summary" ]]; then
  die "Action wildcard setup-failure evidence unexpectedly emitted success state"
fi
if [[ -e "/run/fence/$wildcard_invocation" ]]; then
  die "Action wildcard setup-failure evidence unexpectedly created a runtime directory"
fi
if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "Action wildcard setup-failure evidence unexpectedly created inet fence_v0"
fi

cidr_invocation="fence-12346-2"
if [[ -e "/run/fence/$cidr_invocation" ]]; then
  die "Action setup-failure evidence requires no preexisting CIDR runtime directory"
fi
: >"$state"
: >"$summary"
: >"$stdout"
: >"$stderr"
if INPUT_CONFIG='' \
  INPUT_ALLOWLIST='cidr 192.0.2.1/24 tcp 443' \
  GITHUB_RUN_ID='12346' \
  GITHUB_RUN_ATTEMPT='2' \
  GITHUB_STATE="$state" \
  GITHUB_STEP_SUMMARY="$summary" \
  node action/main.cts >"$stdout" 2>"$stderr"; then
  die "Action setup unexpectedly accepted a CIDR network with host bits"
fi

grep -q "allowlist line 1: allowlist cidr entries must identify a canonical IP network without host bits" "$stderr"
if [[ -s "$stdout" || -s "$state" || -s "$summary" ]]; then
  die "Action CIDR setup-failure evidence unexpectedly emitted success state"
fi
if [[ -e "/run/fence/$cidr_invocation" ]]; then
  die "Action CIDR setup-failure evidence unexpectedly created a runtime directory"
fi
if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "Action CIDR setup-failure evidence unexpectedly created inet fence_v0"
fi

native_limit_invocation="fence-12347-2"
native_limit_unit="fence-$native_limit_invocation.service"
if [[ -e "/run/fence/$native_limit_invocation" || -e "/run/fence-launcher/$native_limit_invocation" ]]; then
  die "Action setup-failure evidence requires no preexisting allowlist-limit runtime state"
fi
if [[ "$(systemctl show "$native_limit_unit" --property=LoadState --value)" != "not-found" ]]; then
  die "Action setup-failure evidence requires an unused allowlist-limit transient service name"
fi
if ! sudo --non-interactive /usr/bin/true; then
  die "Action setup-failure evidence requires available passwordless sudo"
fi

native_limit_entries=()
for ((index = 0; index < 65; index++)); do
  native_limit_entries+=("ip 192.0.2.$index tcp 443")
done
printf -v native_limit_allowlist '%s\n' "${native_limit_entries[@]}"

: >"$state"
: >"$summary"
: >"$stdout"
: >"$stderr"
if INPUT_CONFIG='' \
  INPUT_ALLOWLIST="$native_limit_allowlist" \
  INPUT_INVOCATION_ID="$native_limit_invocation" \
  GITHUB_RUN_ID='12347' \
  GITHUB_RUN_ATTEMPT='2' \
  GITHUB_STATE="$state" \
  GITHUB_STEP_SUMMARY="$summary" \
  node action/main.cts >"$stdout" 2>"$stderr"; then
  die "Action setup unexpectedly accepted more than 64 unique native allowlist entries"
fi

if ! grep -q "allowlist line 65: allowlist input must contain no more than 64 unique entries" "$stderr"; then
  die "Action allowlist-limit setup-failure evidence did not report the unique-entry limit"
fi
if [[ -s "$stdout" || -s "$state" || -s "$summary" ]]; then
  die "Action allowlist-limit setup-failure evidence unexpectedly emitted success state"
fi
if [[ -e "/run/fence/$native_limit_invocation" || -e "/run/fence-launcher/$native_limit_invocation" ]]; then
  die "Action allowlist-limit setup-failure evidence unexpectedly created runtime state"
fi
if [[ "$(systemctl show "$native_limit_unit" --property=LoadState --value)" != "not-found" ]]; then
  die "Action allowlist-limit setup-failure evidence unexpectedly created a transient service"
fi
if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "Action allowlist-limit setup-failure evidence unexpectedly created inet fence_v0"
fi
if ! sudo --non-interactive /usr/bin/true; then
  die "Action allowlist-limit setup-failure evidence unexpectedly disabled passwordless sudo"
fi

assert_invalid_artifact_input() {
  local label="$1"
  local invocation="$2"
  local mode="$3"
  local value="$4"
  local expected_error="$5"
  local unit="fence-$invocation.service"

  if [[ -e "/run/fence/$invocation" || -e "/run/fence-launcher/$invocation" ]]; then
    die "Action $label setup-failure evidence requires no preexisting runtime state"
  fi
  if [[ "$(systemctl show "$unit" --property=LoadState --value)" != "not-found" ]]; then
    die "Action $label setup-failure evidence requires an unused transient service name"
  fi

  : >"$state"
  : >"$summary"
  : >"$stdout"
  : >"$stderr"
  if INPUT_CONFIG='' \
    INPUT_MODE="$mode" \
    INPUT_INVOCATION_ID="$invocation" \
    INPUT_ALLOW_GITHUB_ARTIFACTS="$value" \
    GITHUB_STATE="$state" \
    GITHUB_STEP_SUMMARY="$summary" \
    node action/main.cts >"$stdout" 2>"$stderr"; then
    die "Action setup unexpectedly accepted $label"
  fi

  if ! grep -Fq "$expected_error" "$stderr"; then
    die "Action $label setup-failure evidence did not report the expected configuration error"
  fi
  if [[ -s "$stdout" || -s "$state" || -s "$summary" ]]; then
    die "Action $label setup-failure evidence unexpectedly emitted success state"
  fi
  if [[ -e "/run/fence/$invocation" || -e "/run/fence-launcher/$invocation" ]]; then
    die "Action $label setup-failure evidence unexpectedly created runtime state"
  fi
  if [[ "$(systemctl show "$unit" --property=LoadState --value)" != "not-found" ]]; then
    die "Action $label setup-failure evidence unexpectedly created a transient service"
  fi
  if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
    die "Action $label setup-failure evidence unexpectedly created inet fence_v0"
  fi
  if ! sudo --non-interactive /usr/bin/true; then
    die "Action $label setup-failure evidence unexpectedly disabled passwordless sudo"
  fi
}

assert_invalid_artifact_input \
  "malformed GitHub artifact compatibility" \
  "action-invalid-github-artifact-boolean" \
  "block" \
  "TRUE" \
  "allow_github_artifacts input must be either true or false"

assert_invalid_artifact_input \
  "audit-mode GitHub artifact compatibility" \
  "action-invalid-github-artifact-audit" \
  "audit" \
  "true" \
  "allow_github_artifacts input can only be used with block mode"

runtime_failure_invocation="action-runtime-failure"
runtime_failure_unit="fence-$runtime_failure_invocation.service"
if [[ "$(systemctl show "$runtime_failure_unit" --property=LoadState --value)" != "not-found" ]]; then
  die "Action runtime-failure evidence requires an unused transient service name"
fi
: >"$state"
: >"$summary"
: >"$stdout"
: >"$stderr"
if INPUT_CONFIG='{"schema_version":1,"mode":"block","invocation_id":"action-runtime-failure","platform_profile":"unsupported","allowlist":[]}' \
  GITHUB_STATE="$state" \
  GITHUB_STEP_SUMMARY="$summary" \
  node action/main.cts >"$stdout" 2>"$stderr"; then
  die "Action setup unexpectedly accepted an unsupported source profile"
fi

grep -q "Fence resident service exited before readiness" "$stderr"
grep -q "Fence resident error code: invalid_platform_profile" "$stdout"
if grep -q "readiness was not emitted before the timeout" "$stderr"; then
  die "Action runtime failure waited for the full readiness timeout"
fi
if [[ -e "/run/fence/$runtime_failure_invocation" || -e "/run/fence-launcher/$runtime_failure_invocation" ]]; then
  die "Action runtime-failure evidence left provisional runtime state"
fi
if sudo --non-interactive /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "Action runtime-failure evidence unexpectedly created inet fence_v0"
fi
if ! sudo --non-interactive /usr/bin/true; then
  die "Action runtime-failure evidence unexpectedly disabled passwordless sudo"
fi
runtime_failure_status="$(systemctl show "$runtime_failure_unit" \
  --property=LoadState \
  --property=ActiveState \
  --property=Result \
  --property=ExecMainStatus)"
grep -qx "LoadState=loaded" <<<"$runtime_failure_status"
grep -qx "ActiveState=failed" <<<"$runtime_failure_status"
grep -qx "Result=exit-code" <<<"$runtime_failure_status"
grep -qx "ExecMainStatus=1" <<<"$runtime_failure_status"

echo -e "${GREEN}Action setup-failure evidence verified:${OFF} invalid wrapper inputs and source profile fail before mutation"
