#!/usr/bin/env bash

set -euo pipefail

source script/env "$@"

ensure_rust_toolchain
require_cmd cargo
require_cmd zig
require_cmd cargo-zigbuild

expected_zig="$(read_version_file "$ZIG_VERSION_FILE")"
if [[ -z "$expected_zig" ]]; then
  die "${ZIG_VERSION_FILE#$DIR/} is required"
fi

actual_zig="$(zig version)"
if [[ "$actual_zig" != "$expected_zig" ]]; then
  die "zig version mismatch (expected ${expected_zig}, found ${actual_zig})"
fi

expected_zigbuild="$(read_version_file "$CARGO_ZIGBUILD_VERSION_FILE")"
if [[ -z "$expected_zigbuild" ]]; then
  die "${CARGO_ZIGBUILD_VERSION_FILE#$DIR/} is required"
fi

actual_zigbuild_output="$(cargo-zigbuild --version 2>/dev/null || true)"
actual_zigbuild="${actual_zigbuild_output#cargo-zigbuild }"
actual_zigbuild="${actual_zigbuild%% *}"
if [[ "$actual_zigbuild" != "$expected_zigbuild" ]]; then
  die "cargo-zigbuild version mismatch (expected ${expected_zigbuild}, found ${actual_zigbuild:-unknown})"
fi

if [[ -n "${VERIFY_RUST_TARGETS:-}" ]]; then
  IFS=',' read -r -a targets <<< "$VERIFY_RUST_TARGETS"
  for target in "${targets[@]}"; do
    if [[ -n "$target" ]] && ! rust_target_installed "$target"; then
      die "rust target not installed: $target"
    fi
  done
fi

echo -e "${GREEN}release toolchain verified${OFF}"
