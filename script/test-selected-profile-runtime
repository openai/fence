#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -gt 1 ]]; then
  die "usage: script/test-selected-profile-runtime [healthy|worker-failure]"
fi
scenario="${1:-healthy}"
if [[ "$scenario" != "healthy" && "$scenario" != "worker-failure" ]]; then
  die "selected-profile runtime scenario must be healthy or worker-failure"
fi

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "DNS-mediated selected-profile runtime evidence runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "DNS-mediated selected-profile runtime evidence requires Linux x86_64"
fi

ensure_rust_toolchain
require_cmd cargo
require_cmd docker
require_cmd python3
require_cmd sudo

for required in /usr/bin/mount /usr/bin/systemctl /usr/bin/systemd-run /usr/bin/umount /usr/sbin/nft; do
  if [[ ! -x "$required" ]]; then
    die "DNS-mediated selected-profile runtime evidence requires executable $required"
  fi
done

suffix="${GITHUB_RUN_ID:-run}-${GITHUB_RUN_ATTEMPT:-attempt}-${SELECTED_PROFILE_RUNTIME_REPLICA:-trial}"
invocation="selected-profile-${GITHUB_RUN_ATTEMPT:-attempt}-${SELECTED_PROFILE_RUNTIME_REPLICA:-trial}"
unit="fence-evidence-${invocation}.service"
runtime_root="/run/fence-selected-profile-runtime-${suffix}"
directory="$runtime_root/$invocation"
report="$directory/report.json"
dns_report="$directory/dns-report.json"
ready="$directory/ready.json"
production_ready="/run/fence/$invocation/ready.json"
target_root="$RUNNER_TEMP/fence-selected-profile-runtime-target"

report_selected_profile_failure() {
  local status="$?"
  if [[ -x /usr/bin/journalctl ]]; then
    echo "bounded selected-profile service diagnostics:" >&2
    /usr/bin/journalctl --no-pager --output=cat --lines=40 --unit "$unit" >&2 || true
  fi
  return "$status"
}
trap report_selected_profile_failure ERR

mkdir -p "$target_root"
export CARGO_TARGET_DIR="$target_root"
cargo test --frozen --test selected_profile_runtime --no-run

shopt -s nullglob
test_binaries=()
for candidate in "$target_root"/debug/deps/selected_profile_runtime-*; do
  if [[ -f "$candidate" && -x "$candidate" ]]; then
    test_binaries+=("$candidate")
  fi
done
if [[ "${#test_binaries[@]}" -ne 1 ]]; then
  die "expected exactly one compiled DNS-mediated selected-profile runtime binary"
fi

if sudo /usr/sbin/nft list table inet fence_v0 >/dev/null 2>&1; then
  die "DNS-mediated selected-profile runtime evidence requires absent host inet fence_v0 table"
fi
if [[ -e "$production_ready" ]]; then
  die "DNS-mediated selected-profile runtime evidence requires absent production readiness path"
fi

# This applies the planner-selected profile on a disposable runner and
# intentionally leaves controls resident so the platform conclusion tests the
# test-only runtime realization.
worker_failure_environment=()
if [[ "$scenario" == "worker-failure" ]]; then
  worker_failure_environment+=(--setenv=FENCE_SELECTED_PROFILE_RUNTIME_INJECT_WORKER_FAILURE=1)
fi
sudo /usr/bin/systemd-run \
  --quiet \
  --collect \
  --property=Type=exec \
  --unit "$unit" \
  --setenv=FENCE_SELECTED_PROFILE_RUNTIME_WORKER=1 \
  "--setenv=FENCE_SELECTED_PROFILE_RUNTIME_UNIT=$unit" \
  "--setenv=FENCE_SELECTED_PROFILE_RUNTIME_ROOT=$runtime_root" \
  "--setenv=FENCE_SELECTED_PROFILE_RUNTIME_INVOCATION=$invocation" \
  "${worker_failure_environment[@]}" \
  "${test_binaries[0]}" --ignored --exact selected_profile_runtime_worker --nocapture

python3 - "$report" "$dns_report" "$ready" "$production_ready" "$scenario" <<'PY'
import json
import pathlib
import re
import sys
import time

report_path, dns_path, ready_path, production_path = (pathlib.Path(item) for item in sys.argv[1:5])
scenario = sys.argv[5]
deadline = time.monotonic() + 30
report = None
dns = None
ready = None
while time.monotonic() < deadline:
    if report_path.exists() and dns_path.exists() and ready_path.exists():
        report = json.loads(report_path.read_text(encoding="utf-8"))
        dns = json.loads(dns_path.read_text(encoding="utf-8"))
        ready = json.loads(ready_path.read_text(encoding="utf-8"))
        resident_status = report.get("resident_health", {}).get("status")
        if (
            report.get("setup_status") == "resident_selected_profile_runtime_test_only"
            and (scenario != "worker-failure" or resident_status == "critical")
        ):
            break
    time.sleep(0.1)
assert report is not None, "DNS-mediated block report was not emitted"
assert dns is not None, "DNS-mediated block DNS report was not emitted"
assert ready is not None, "DNS-mediated block test readiness was not emitted"
assert report["status"] == "selected_profile_runtime_test_only"
assert report["runtime_evidence_schema_version"] == 3
assert report["mode"] == "block"
assert report["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v2"
assert report["platform_profile_id"] == "github_hosted_workflow_bootstrap_v2"
assert report["policy_hash_schema_version"] == 5
assert re.fullmatch(r"[0-9a-f]{64}", report["policy_hash"])
assert re.fullmatch(r"[0-9a-f]{64}", report["base_ruleset_hash"])
assert re.fullmatch(r"[0-9a-f]{64}", report["ruleset_hash"])
assert report["bootstrap_hostnames"] == [
    "github.com",
    "api.github.com",
    "release-assets.githubusercontent.com",
    "hosted-compute-watchdog-prod-eus-01.githubapp.com",
    "vstoken.actions.githubusercontent.com",
    "pipelines.actions.githubusercontent.com",
    "payload.pipelines.actions.githubusercontent.com",
    "results-receiver.actions.githubusercontent.com",
    "actions-results-receiver-production.githubapp.com",
]
assert report["network_application_status"] == "applied"
assert report["network_verification_status"] == "verified"
assert report["sudo_status"] == "disabled_verified"
assert report["container_status"] == "disabled_verified"
assert report["dns_upstream_policy"] == "root_resident_mediator_only_udp_53"
assert report["materialization_status"] == "bounded_ttl_exact_host_and_cname_transport_policy"
assert len(report["materialized_allowances"]) >= 1
assert all(item["protocol"] == "tcp" and item["port"] == 443 for item in report["materialized_allowances"])
resident = report["resident_health"]
assert resident["status"] == ("critical" if scenario == "worker-failure" else "healthy"), resident
assert resident["resident_pid"] > 0, resident
assert resident["verification_sequence"] >= 1, resident
assert resident["last_successful_verification_unix_milliseconds"] > 0, resident
assert resident["verification_interval_seconds"] == 5, resident
expected_workers = [
    {"name": "docker_tcp_dns", "status": "running"},
    {"name": "docker_udp_dns", "status": "running"},
    {"name": "host_tcp_dns", "status": "running"},
    {
        "name": "host_udp_dns",
        "status": "failed" if scenario == "worker-failure" else "running",
    },
    {"name": "process_attribution", "status": "running"},
]
assert resident["workers"] == expected_workers, resident
assert ready["status"] == "selected_profile_runtime_ready_no_public_activation"
assert ready["runtime_evidence_schema_version"] == 3
assert ready["protection_available"] is False
assert ready["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v2"
assert ready["platform_profile_id"] == "github_hosted_workflow_bootstrap_v2"
assert ready["policy_hash_schema_version"] == 5
assert ready["policy_hash"] == report["policy_hash"]
assert ready["base_ruleset_hash"] == report["base_ruleset_hash"]
assert ready["resident_health"]["resident_pid"] == resident["resident_pid"]
assert ready["resident_health"]["status"] == "healthy", ready
assert dns["status"] == "selected_profile_runtime_test_only"
assert dns["runtime_evidence_schema_version"] == 3
assert dns["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v2"
assert dns["platform_profile_id"] == "github_hosted_workflow_bootstrap_v2"
assert dns["authorized_domain_patterns"] == [
    "*.actions.githubusercontent.com",
    "actions-results-receiver-production.githubapp.com",
    "productionresultssa<1-to-5-decimal-digits>.blob.core.windows.net",
]
assert dns["bootstrap_hostnames"] == [
    "github.com",
    "api.github.com",
    "release-assets.githubusercontent.com",
    "hosted-compute-watchdog-prod-eus-01.githubapp.com",
    "vstoken.actions.githubusercontent.com",
    "pipelines.actions.githubusercontent.com",
    "payload.pipelines.actions.githubusercontent.com",
    "results-receiver.actions.githubusercontent.com",
    "actions-results-receiver-production.githubapp.com",
]
assert isinstance(dns["materialization_batch_count"], int)
assert dns["materialization_batch_count"] >= 0
assert dns["materialization_request_rejections"] == 0
assert dns["results_storage_authorization_count"] >= 0
assert dns["results_storage_attribution_failures"] == 0
assert dns["results_storage_request_rejections"] == 0
assert len(dns["runner_authorized_results_storage"]) <= 4
assert isinstance(dns["upstream_request_failures"], int)
assert dns["upstream_request_failures"] >= 0
assert dns["resident_health"]["resident_pid"] == resident["resident_pid"]
assert isinstance(dns["materialization_update_max_milliseconds"], int)
assert dns["materialization_update_max_milliseconds"] >= 0
assert dns["mode"] == "block"
assert dns["proxy_policy_status"] == "block_forwards_exact_roots_bounded_actions_suffix_names_runner_authorized_results_storage_and_bounded_cname_descendants"
assert dns["answer_attribution_status"] == "bounded_reportable_hostname_answers_only"
assert len(dns["bounded_actions_suffix_authorizations"]) <= 8
assert dns["bounded_actions_suffix_authorizations_truncated"] is False
assert all(
    1 <= len(hostname.removesuffix(".actions.githubusercontent.com").split(".")) <= 2
    for hostname in dns["bounded_actions_suffix_authorizations"]
)
assert "test_only_evidence_path_does_not_activate_default_planning_descriptor" in dns["limitations"]
assert "bounded_actions_suffix_dns_authorization_remains_an_egress_limitation" in dns["limitations"]
assert "actions_suffix_authorizations_are_limited_to_8_unique_names_and_two_prefix_labels" in dns["limitations"]
assert "block_dns_queries_are_canonicalized_before_upstream_forwarding" in dns["limitations"]
assert "dns_query_timing_and_count_remain_egress_limitations" in dns["limitations"]
assert "post_ready_codeload_traffic_is_not_authorized" in dns["limitations"]
assert "runner_authorized_results_storage_accounts_remain_egress_channels" in dns["limitations"]
assert "cname_descendants_are_bounded_ttl_derived_authorizations" in dns["limitations"]
assert "dns_cname_descendants_may_delegate_to_external_dns_operator_names" in dns["limitations"]
assert "bootstrap_roots_refresh_every_5_seconds" in dns["limitations"]
assert "https_materialization_expiry_includes_30_second_refresh_overlap" in dns["limitations"]
assert "approved_workflow_bootstrap_https_destinations_remain_egress_channels" in dns["limitations"]
assert "resolved_workflow_bootstrap_ip_addresses_may_serve_additional_destinations" in dns["limitations"]
assert "test_only_evidence_path_does_not_activate_default_planning_descriptor" in report["limitations"]
assert "bounded_actions_suffix_dns_authorization_remains_an_egress_limitation" in report["limitations"]
assert "actions_suffix_authorizations_are_limited_to_8_unique_names_and_two_prefix_labels" in report["limitations"]
assert "block_dns_queries_are_canonicalized_before_upstream_forwarding" in report["limitations"]
assert "dns_query_timing_and_count_remain_egress_limitations" in report["limitations"]
assert "post_ready_codeload_traffic_is_not_authorized" in report["limitations"]
assert "runner_authorized_results_storage_accounts_remain_egress_channels" in report["limitations"]
assert "cname_descendants_are_bounded_ttl_derived_authorizations" in report["limitations"]
assert "bootstrap_roots_refresh_every_5_seconds" in report["limitations"]
assert "https_materialization_expiry_includes_30_second_refresh_overlap" in report["limitations"]
assert "dns_cname_descendants_may_delegate_to_external_dns_operator_names" in report["limitations"]
assert "approved_workflow_bootstrap_https_destinations_remain_egress_channels" in report["limitations"]
assert "resolved_workflow_bootstrap_ip_addresses_may_serve_additional_destinations" in report["limitations"]
assert "root_resident_dns_upstream_channel_remains_an_egress_limitation" in report["limitations"]
if scenario == "worker-failure":
    assert any(item["code"] == "resident_worker_test_failure" for item in report["critical_findings"]), report
else:
    assert report["critical_findings"] == [], report
assert not production_path.exists()
PY

# Unrelated traffic and a syntactically valid results-storage request from the
# workflow process must be refused locally.
python3 <<'PY'
import random
import socket
import struct

for hostname in (
    b"codeload.github.com",
    b"productionresultssa17.blob.core.windows.net",
    b"uploads.github.com",
    b"lookalike.payload.pipelines.actions.githubusercontent.com",
):
    identifier = random.randrange(0, 65536)
    question = b"".join(bytes([len(label)]) + label for label in hostname.split(b".")) + b"\x00"
    packet = struct.pack("!HHHHHH", identifier, 0x0100, 1, 0, 0, 0) + question + struct.pack("!HH", 1, 1)
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.settimeout(2)
    sock.sendto(packet, ("127.0.0.1", 53))
    response, _ = sock.recvfrom(4096)
    assert struct.unpack("!H", response[:2])[0] == identifier
    assert struct.unpack("!H", response[2:4])[0] & 0x000F == 5
PY

if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
  die "DNS-mediated selected-profile runtime evidence did not disable runner passwordless sudo"
fi
if docker ps --quiet >/dev/null 2>&1; then
  die "DNS-mediated selected-profile runtime evidence did not disable runner Docker access"
fi

sleep 6
python3 - "$report" "$dns_report" "$production_ready" "$scenario" <<'PY'
import json
import pathlib
import sys

report_path, dns_path, production_path = (pathlib.Path(item) for item in sys.argv[1:4])
scenario = sys.argv[4]
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
assert report["network_verification_status"] == "verified", report
assert report["sudo_status"] == "disabled_verified", report
assert report["container_status"] == "disabled_verified", report
if scenario == "worker-failure":
    assert report["resident_health"]["status"] == "critical", report
    assert report["resident_health"]["verification_sequence"] == 1, report
    assert any(item["code"] == "resident_worker_test_failure" for item in report["critical_findings"]), report
    assert any(item["status"] == "failed" for item in report["resident_health"]["workers"]), report
else:
    assert report["critical_findings"] == [], report
    assert report["resident_health"]["status"] == "healthy", report
    assert report["resident_health"]["verification_sequence"] >= 2, report
assert dns["blocked_non_profile_query_count"] >= 4, dns
assert dns["results_storage_request_rejections"] >= 1, dns
assert dns["results_storage_attribution_failures"] == 0, dns
if scenario == "worker-failure":
    assert dns["resident_health"]["status"] == "critical", dns
else:
    assert dns["resident_health"]["verification_sequence"] >= 2, dns
assert not production_path.exists()
print(json.dumps(report, sort_keys=True, separators=(",", ":")))
PY

echo -e "${GREEN}DNS-mediated selected-profile runtime evidence verified${OFF}"
