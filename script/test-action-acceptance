#! /usr/bin/env bash

set -euo pipefail

source script/env "$@"

if [[ $# -lt 1 || $# -gt 2 ]]; then
  die "usage: script/test-action-acceptance <standard|standard-opt-out|unsafe-preserve|wildcard-docker|audit> [invocation-id]"
fi

scenario="$1"
case "$scenario" in
  standard|standard-opt-out|unsafe-preserve|wildcard-docker|audit) ;;
  *) die "unknown Action acceptance scenario: $scenario" ;;
esac

if [[ "${CI:-}" != "true" || "${GITHUB_ACTIONS:-}" != "true" ]]; then
  die "Action acceptance runs only on disposable GitHub Actions runners"
fi
if [[ "$PLATFORM" != "linux" || "$ARCH" != "x86_64" ]]; then
  die "Action acceptance requires Linux x86_64"
fi

require_cmd docker
require_cmd curl
require_cmd findmnt
require_cmd python3
require_cmd sudo

invocation="${2:-action-$scenario}"
directory="/run/fence/$invocation"
ready="$directory/ready.json"
report="$directory/report.json"
dns_report="$directory/dns-report.json"
launcher_directory="/run/fence-launcher/$invocation"
launcher_integrity="$launcher_directory/integrity.json"

probe_https_once() {
  local url="$1"
  curl --head --silent --show-error --max-time 10 --retry 0 --output /dev/null "$url"
}

assert_action_runtime_immutable() {
  local action_root="$DIR/action"
  local replacement="$RUNNER_TEMP/fence-action-replacement-$invocation"
  local options
  local target

  printf '%s\n' 'replacement' >"$replacement"
  options="$(findmnt --noheadings --mountpoint "$action_root" --output OPTIONS)"
  for required in ro nodev nosuid; do
    if [[ ",$options," != *",$required,"* ]]; then
      die "Fence Action runtime mount is missing $required"
    fi
  done
  for relative in main.cts post.cts lib.cts log.cts bundle-manifest.json bin/fence; do
    target="$action_root/$relative"
    if printf '%s\n' 'tamper' >>"$target" 2>/dev/null; then
      die "Fence Action runtime allowed overwrite: $relative"
    fi
    if rm -f "$target" 2>/dev/null; then
      die "Fence Action runtime allowed unlink: $relative"
    fi
    if chmod u+w "$target" 2>/dev/null; then
      die "Fence Action runtime allowed chmod: $relative"
    fi
    if mv "$target" "$target.moved" 2>/dev/null; then
      die "Fence Action runtime allowed rename: $relative"
    fi
    if cp "$replacement" "$target" 2>/dev/null; then
      die "Fence Action runtime allowed replacement: $relative"
    fi
  done
  rm -f "$replacement"
  python3 -E - "$launcher_integrity" <<'PY'
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message="evidence validation failed"):
    if not condition:
        raise SystemExit(message)

import json
import pathlib
import stat
import sys

integrity_path = pathlib.Path(sys.argv[1])
metadata = integrity_path.stat()
require(stat.S_IMODE(metadata.st_mode) == 0o444)
require(metadata.st_uid == 0)
integrity = json.loads(integrity_path.read_text(encoding="utf-8"))
require(integrity["schema_version"] == 2)
require(len(integrity["files"]) == 6)
require(1 <= len(integrity["path_guards"]) <= 16)
for guard in integrity["path_guards"]:
    require(set(guard) == {"path", "device", "inode"})
    require(guard["device"].isdigit())
    require(guard["inode"].isdigit())
PY
}

python3 -E - "$scenario" "$report" "$dns_report" "$ready" "action/bundle-manifest.json" <<'PY'
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message="evidence validation failed"):
    if not condition:
        raise SystemExit(message)

import json
import pathlib
import re
import sys
import time

expected_workers = [
    {"name": "docker_tcp_dns", "status": "running"},
    {"name": "docker_udp_dns", "status": "running"},
    {"name": "host_tcp_dns", "status": "running"},
    {"name": "host_udp_dns", "status": "running"},
    {"name": "process_attribution", "status": "running"},
]


def assert_resident_health(document, expected_pid=None, minimum_sequence=1):
    health = document["resident_health"]
    require(health["status"] == "healthy")
    require(isinstance(health["resident_pid"], int) and health["resident_pid"] > 0)
    if expected_pid is not None:
        require(health["resident_pid"] == expected_pid)
    require(health["verification_sequence"] >= minimum_sequence)
    require(health["verification_interval_seconds"] == 5)
    verified_at = health["last_successful_verification_unix_milliseconds"]
    now = int(time.time() * 1000)
    require(now - 20_000 <= verified_at <= now + 5_000)
    require(health["workers"] == expected_workers)
    return health["resident_pid"]

scenario = sys.argv[1]
report_path, dns_path, ready_path, manifest_path = (pathlib.Path(item) for item in sys.argv[2:])
expected = {
    "standard": ("block", "protected_host_block", "resident_protected", "ready", True, "disabled_verified", "disabled_verified"),
    "standard-opt-out": ("block", "protected_host_block", "resident_protected", "ready", True, "disabled_verified", "disabled_verified"),
    "unsafe-preserve": ("block", "protected_host_block_degraded", "resident_degraded", "ready_degraded", False, "disabled_verified", "preserved_unsafe"),
    "wildcard-docker": ("block", "protected_host_block_degraded", "resident_degraded", "ready_degraded", False, "disabled_verified", "preserved_unsafe"),
    "audit": ("audit", "protected_host_audit_observation", "resident_observation_only", "ready_observation_only", False, "preserved_verified", "preserved_verified"),
}[scenario]
mode, status, resident, readiness, protection, sudo_status, container_status = expected
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
ready = json.loads(ready_path.read_text(encoding="utf-8"))
manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
require(manifest["schema_version"] == 3)
require(manifest["release_is_draft"] is False)
require(manifest["release_is_immutable"] is True)
require(manifest["release_tag_commit"] == manifest["source_commit"])
require(manifest["source_ref"] == "refs/heads/main")
require(manifest["signer_digest"] == manifest["source_commit"])
require(manifest["release_channel"] == "stable")
require(report["mode"] == mode)
require(report["status"] == status)
require(report["setup_status"] == resident)
require(report["readiness_status"] == readiness)
require(report["protection_available"] is protection)
require(report["sudo_status"] == sudo_status)
require(report["container_status"] == container_status)
require(report["network_verification_status"] == "verified")
require(report["critical_findings"] == [])
require(ready["status"] == readiness)
require(dns["routing_status"] == "active")
require(report["runtime_evidence_schema_version"] == 5)
require(report["policy_hash_schema_version"] == 8)
require(report["platform_profile_id"] == "github_hosted_workflow_bootstrap_v4")
require(report["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v4")
require(ready["runtime_evidence_schema_version"] == 5)
require(ready["policy_hash_schema_version"] == 8)
require(ready["platform_profile_id"] == "github_hosted_workflow_bootstrap_v4")
require(ready["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v4")
require(dns["runtime_evidence_schema_version"] == 5)
require(dns["platform_profile_id"] == "github_hosted_workflow_bootstrap_v4")
require(dns["profile_realization_id"] == "github_hosted_workflow_bootstrap_dns_provenance_v4")
require(dns["host_dns_routing"] == "direct_client_to_root_resident_mediator")
require(dns["docker_dns_routing"] == "local_root_resident_mediator")
expected_proxy_policy = (
    "audit_forwards_while_simulating_name_authorization"
    if mode == "audit"
    else "block_forwards_exact_roots_bounded_user_wildcard_names_actions_suffix_names_githubapp_suffix_names_results_storage_and_bounded_cname_descendants"
)
require(dns["proxy_policy_status"] == expected_proxy_policy)
wildcard_authorizations = dns["bounded_user_wildcard_authorizations"]
require(isinstance(wildcard_authorizations, list))
require(len(wildcard_authorizations) <= 8)
require(wildcard_authorizations == sorted(set(wildcard_authorizations)))
require(all(
    isinstance(hostname, str)
    and "*" not in hostname
    and re.fullmatch(r"(?=.{1,253}$)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.)*[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?", hostname)
    for hostname in wildcard_authorizations
))
require(dns["bounded_user_wildcard_authorizations_truncated"] is False)
require(dns["user_wildcard_request_rejections"] == 0)
require(all("*" not in item["hostname"] for item in dns["observations"]))
wildcard_policy = dns["hostname_policy"]["user_wildcards"]
if scenario == "wildcard-docker":
    require(wildcard_policy == [{
        "pattern": "*.docker.io",
        "suffix": "docker.io",
        "prefix_labels": 1,
        "transports": [{"protocol": "tcp", "port": 443}],
    }])
    require(wildcard_authorizations == [])
    require("bounded_user_wildcard_dns_authorization_remains_an_egress_limitation" in report["limitations"])
else:
    require(wildcard_policy == [])
    require(wildcard_authorizations == [])
require(len(dns["runner_authorized_results_storage"]) <= 4)
require(dns["results_storage_authorization_count"] == len(dns["runner_authorized_results_storage"]))
require(dns["results_storage_attribution_failures"] == 0)
require(dns["results_storage_request_rejections"] == 0)
require(dns["runner_authorized_results_storage_truncated"] is False)
require(all(
    item["authorization_origin"] == "pinned_runner_worker_dns"
    for item in dns["runner_authorized_results_storage"]
))
resident_pid = assert_resident_health(report)
assert_resident_health(ready, resident_pid)
assert_resident_health(dns, resident_pid)
broad_roots = {"github.com", "api.github.com", "release-assets.githubusercontent.com"}
bootstrap_roots = set(dns["bootstrap_hostnames"])
if scenario == "standard-opt-out":
    require(broad_roots.isdisjoint(bootstrap_roots))
else:
    require(broad_roots.issubset(bootstrap_roots))
PY

case "$scenario" in
  standard|standard-opt-out|unsafe-preserve|wildcard-docker)
    if sudo --non-interactive /usr/bin/true >/dev/null 2>&1; then
      die "Fence Action did not disable runner passwordless sudo"
    fi
    ;;
  audit)
    sudo --non-interactive /usr/bin/true >/dev/null
    ;;
esac
case "$scenario" in
  standard|standard-opt-out)
    if docker ps --quiet >/dev/null 2>&1; then
      die "Fence Action standard block did not disable Docker access"
    fi
    ;;
  unsafe-preserve|wildcard-docker|audit)
    docker ps --quiet >/dev/null
    ;;
esac

if [[ "$scenario" == "wildcard-docker" ]]; then
  probe_https_once https://auth.docker.io
  probe_https_once https://registry-1.docker.io
fi

if [[ "$scenario" == "audit" ]]; then
  python3 -E <<'PY'
import socket

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.sendto(b"fence-action-audit-probe", ("192.0.2.10", 443))
PY
  curl --head --silent --show-error --max-time 10 --retry 0 https://www.google.com >/dev/null
fi

if [[ "$scenario" == "standard" ]]; then
  assert_action_runtime_immutable
fi

sleep 6
python3 -E - "$scenario" "$report" "$dns_report" <<'PY'
import sys

if sys.flags.optimize != 0:
    raise SystemExit("Python optimization must be disabled")

def require(condition, message="evidence validation failed"):
    if not condition:
        raise SystemExit(message)

import json
import pathlib
import sys
import time

expected_workers = [
    {"name": "docker_tcp_dns", "status": "running"},
    {"name": "docker_udp_dns", "status": "running"},
    {"name": "host_tcp_dns", "status": "running"},
    {"name": "host_udp_dns", "status": "running"},
    {"name": "process_attribution", "status": "running"},
]

scenario = sys.argv[1]
report_path, dns_path = (pathlib.Path(item) for item in sys.argv[2:])
report = json.loads(report_path.read_text(encoding="utf-8"))
dns = json.loads(dns_path.read_text(encoding="utf-8"))
require(report["runtime_evidence_schema_version"] == 5)
require(report["policy_hash_schema_version"] == 8)
require(report["network_verification_status"] == "verified")
require(report["critical_findings"] == [])
resident = report["resident_health"]
require(resident["status"] == "healthy")
require(resident["verification_sequence"] >= 2)
require(resident["verification_interval_seconds"] == 5)
require(resident["workers"] == expected_workers)
verified_at = resident["last_successful_verification_unix_milliseconds"]
now = int(time.time() * 1000)
require(now - 20_000 <= verified_at <= now + 5_000)
require(dns["runtime_evidence_schema_version"] == 5)
require(dns["resident_health"]["resident_pid"] == resident["resident_pid"])
require(dns["resident_health"]["workers"] == expected_workers)
require(dns["resident_health"]["verification_sequence"] >= 2)
require("fence-action-audit-probe" not in json.dumps(report, sort_keys=True))
require("fence-action-audit-probe" not in json.dumps(dns, sort_keys=True))
require(dns["materialization_request_rejections"] == 0)
require(dns["user_wildcard_request_rejections"] == 0)
require(dns["bounded_user_wildcard_authorizations_truncated"] is False)
wildcard_authorizations = dns["bounded_user_wildcard_authorizations"]
require(wildcard_authorizations == sorted(set(wildcard_authorizations)))
require(len(wildcard_authorizations) <= 8)
require(all("*" not in hostname for hostname in wildcard_authorizations))
if scenario == "wildcard-docker":
    require({"auth.docker.io", "registry-1.docker.io"}.issubset(wildcard_authorizations))
    wildcard_materializations = [
        item for item in report["materialized_allowances"]
        if item.get("source_hostname") in {"auth.docker.io", "registry-1.docker.io"}
    ]
    require(wildcard_materializations)
    require(all(
        item["protocol"] == "tcp"
        and item["port"] == 443
        and "user" in item["origins"]
        for item in wildcard_materializations
    ))
    wildcard_observations = [
        item for item in dns["observations"]
        if item.get("hostname") in {"auth.docker.io", "registry-1.docker.io"}
    ]
    require(wildcard_observations)
    require(all(
        item["policy_classification"] == "user_wildcard_allowlist"
        for item in wildcard_observations
    ))
else:
    require(wildcard_authorizations == [])
if scenario == "audit":
    require(report["counters"]["total_violations"] >= 1)
    require(report["counters"]["sampled_violations"] >= 1)
    require(any(item["classification"] == "would_block" for item in report["findings"]))
    require(dns["excluded_unretained_query_count"] == 0)
    require(any(
        item["hostname"] == "www.google.com"
        and item["policy_classification"] == "outside_policy"
        and item["query_type"] in {"a", "aaaa"}
        for item in dns["observations"]
    ))
    require(any(
        item["classification"] == "would_block"
        and item["protocol"] == "tcp"
        and item["remote_port"] == 443
        for item in report["findings"]
    ))
PY

echo -e "${GREEN}Action acceptance verified:${OFF} $scenario"
